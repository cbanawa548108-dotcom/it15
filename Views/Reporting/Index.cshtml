@using CRLFruitstandESS.Models.ViewModels
@using CRLFruitstandESS.Models
@model ReportingViewModel
@{
    ViewData["Title"] = "Reporting";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
    .page-content { background:#0f172a !important; min-height:100vh; }
    .rpt-header {
        background:linear-gradient(135deg,#1e293b 0%,#0f172a 100%);
        border:1px solid #334155; padding:2.5rem 2rem;
        border-radius:14px; color:white; margin-bottom:2rem;
        position:relative; overflow:hidden;
    }
    .rpt-header::before {
        content:''; position:absolute; top:-60px; right:-60px;
        width:300px; height:300px;
        background:radial-gradient(circle,rgba(59,130,246,.12) 0%,transparent 70%);
        border-radius:50%; pointer-events:none;
    }
    .rpt-header > div { position:relative; z-index:1; }
    .dark-card {
        background:#1e293b; border:1px solid #334155;
        border-radius:14px; padding:1.75rem; margin-bottom:1.5rem;
        transition:all .3s ease;
    }
    .section-title {
        font-size:1.1rem; font-weight:700; color:#f1f5f9;
        display:flex; align-items:center; gap:.75rem; margin:0 0 1.5rem;
    }
    .dark-input {
        width:100%; padding:.75rem 1rem; background:#0f172a;
        border:1px solid #334155; border-radius:8px; color:#f1f5f9;
        font-size:.9rem; box-sizing:border-box; outline:none;
        transition:border-color .2s,box-shadow .2s;
    }
    .dark-input:focus { border-color:#3b82f6; box-shadow:0 0 0 3px rgba(59,130,246,.15); }
    .form-label { display:block; margin-bottom:.4rem; font-size:.75rem; font-weight:700;
        text-transform:uppercase; letter-spacing:.07em; color:#64748b; }
    .tab-bar { display:flex; gap:.5rem; margin-bottom:1.5rem; flex-wrap:wrap; }
    .tab-btn {
        padding:.6rem 1.25rem; border-radius:8px; font-size:.85rem; font-weight:600;
        border:1px solid #334155; background:#0f172a; color:#94a3b8;
        cursor:pointer; text-decoration:none; transition:all .2s ease; outline:none;
    }
    .tab-btn:hover, .tab-btn.active {
        border-color:#3b82f6; color:#f1f5f9; background:#1e293b;
        box-shadow:0 0 0 1px #3b82f6;
    }
    .tab-btn:active { transform:scale(.97); }
    .kpi-row { display:grid; grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); gap:1.25rem; margin-bottom:1.5rem; }
    .kpi-tile {
        background:#0f172a; border:1px solid #334155; border-radius:10px;
        padding:1.25rem; transition:border-color .2s;
    }
    .kpi-tile:hover { border-color:#475569; }
    .kpi-tile .kt-label { font-size:.72rem; font-weight:700; text-transform:uppercase;
        letter-spacing:.08em; color:#64748b; margin-bottom:.6rem; }
    .kpi-tile .kt-value { font-size:1.7rem; font-weight:800; color:#f1f5f9; line-height:1; }
    .dark-table-wrap { overflow-x:auto; border-radius:10px; border:1px solid #334155; }
    .dark-table { width:100%; border-collapse:collapse; font-size:.875rem; }
    .dark-table thead tr { background:#0f172a; }
    .dark-table thead th { padding:.875rem 1rem; text-align:left; font-size:.72rem;
        font-weight:700; text-transform:uppercase; letter-spacing:.07em;
        color:#64748b; border-bottom:1px solid #334155; white-space:nowrap; }
    .dark-table tbody tr { border-bottom:1px solid #1e293b; transition:background .2s; }
    .dark-table tbody tr:hover { background:#1e293b; }
    .dark-table tbody td { padding:.75rem 1rem; color:#cbd5e1; }
    .badge-pill { display:inline-block; padding:.25rem .65rem; border-radius:20px;
        font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.05em; }
    .btn-export {
        display:inline-flex; align-items:center; gap:.5rem;
        padding:.75rem 1.5rem; border-radius:8px; font-size:.875rem;
        font-weight:700; cursor:pointer; text-decoration:none;
        border:none; transition:all .2s ease; outline:none;
    }
    .btn-excel { background:#10b981; color:white; }
    .btn-excel:hover  { background:#059669; transform:translateY(-2px); box-shadow:0 6px 20px rgba(16,185,129,.4); }
    .btn-excel:active { transform:scale(.97); }
    .btn-pdf   { background:#ef4444; color:white; }
    .btn-pdf:hover    { background:#dc2626; transform:translateY(-2px); box-shadow:0 6px 20px rgba(239,68,68,.4); }
    .btn-pdf:active   { transform:scale(.97); }
    .btn-filter { background:#3b82f6; color:white; }
    .btn-filter:hover  { background:#2563eb; transform:translateY(-2px); box-shadow:0 6px 20px rgba(59,130,246,.4); }
    .btn-filter:active { transform:scale(.97); }
    .tab-panel { display:none; }
    .tab-panel.active { display:block; }
    .sev-info     { background:rgba(59,130,246,.15); color:#93c5fd; border:1px solid rgba(59,130,246,.3); }
    .sev-warning  { background:rgba(245,158,11,.15);  color:#fcd34d; border:1px solid rgba(245,158,11,.3); }
    .sev-critical { background:rgba(239,68,68,.15);   color:#fca5a5; border:1px solid rgba(239,68,68,.3); }
</style>
}

<!-- HEADER -->
<div class="rpt-header">
    <div>
        <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#3b82f6;display:block;margin-bottom:.5rem;">Analytics &amp; Compliance</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 .5rem;color:#f1f5f9;">Reporting Module</h1>
        <p style="margin:0;font-size:.95rem;color:#94a3b8;">Auto-generated reports, transaction history, audit trails &amp; exports</p>
    </div>
</div>

<!-- FILTER BAR -->
<div class="dark-card">
    <form method="get" action="@Url.Action("Index","Reporting")" style="display:flex;flex-wrap:wrap;gap:1.25rem;align-items:flex-end;">
        <div style="flex:1;min-width:160px;">
            <label class="form-label">From</label>
            <input type="date" name="from" value="@Model.DateFrom.ToString("yyyy-MM-dd")" class="dark-input" />
        </div>
        <div style="flex:1;min-width:160px;">
            <label class="form-label">To</label>
            <input type="date" name="to" value="@Model.DateTo.ToString("yyyy-MM-dd")" class="dark-input" />
        </div>
        <div style="flex:1;min-width:160px;">
            <label class="form-label">Report Type</label>
            <select name="reportType" class="dark-input">
                @if (Model.ReportType == "financial") { <option value="financial" selected>Financial</option> } else { <option value="financial">Financial</option> }
                @if (Model.ReportType == "sales")     { <option value="sales"     selected>Sales</option>     } else { <option value="sales">Sales</option>         }
                @if (Model.ReportType == "inventory") { <option value="inventory" selected>Inventory</option> } else { <option value="inventory">Inventory</option> }
                @if (Model.ReportType == "audit")     { <option value="audit"     selected>Audit</option>     } else { <option value="audit">Audit</option>         }
            </select>
        </div>
        <div style="display:flex;gap:.75rem;flex-wrap:wrap;">
            <button type="submit" class="btn-export btn-filter">
                <i class="bi bi-funnel-fill"></i> Apply
            </button>
            <a href="@Url.Action("ExportExcel","Reporting",new{from=Model.DateFrom.ToString("yyyy-MM-dd"),to=Model.DateTo.ToString("yyyy-MM-dd"),reportType=Model.ReportType})"
               class="btn-export btn-excel">
                <i class="bi bi-file-earmark-excel-fill"></i> Excel
            </a>
            <a href="@Url.Action("ExportPdf","Reporting",new{from=Model.DateFrom.ToString("yyyy-MM-dd"),to=Model.DateTo.ToString("yyyy-MM-dd"),reportType=Model.ReportType})"
               class="btn-export btn-pdf">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF
            </a>
        </div>
    </form>
</div>

<!-- KPI SUMMARY -->
<div class="kpi-row">
    <div class="kpi-tile" style="border-top:3px solid #3b82f6;">
        <div class="kt-label">Total Revenue</div>
        <div class="kt-value" style="color:#60a5fa;">₱@Model.TotalRevenue.ToString("N0")</div>
    </div>
    <div class="kpi-tile" style="border-top:3px solid #ef4444;">
        <div class="kt-label">Total Expenses</div>
        <div class="kt-value" style="color:#fca5a5;">₱@Model.TotalExpenses.ToString("N0")</div>
    </div>
    <div class="kpi-tile" style="border-top:3px solid @(Model.NetProfit>=0?"#10b981":"#ef4444");">
        <div class="kt-label">Net Profit</div>
        <div class="kt-value" style="color:@(Model.NetProfit>=0?"#34d399":"#fca5a5");">₱@Model.NetProfit.ToString("N0")</div>
    </div>
    <div class="kpi-tile" style="border-top:3px solid #f59e0b;">
        <div class="kt-label">Gross Margin</div>
        <div class="kt-value" style="color:#fcd34d;">@Model.GrossMargin.ToString("F1")%</div>
    </div>
    <div class="kpi-tile" style="border-top:3px solid #8b5cf6;">
        <div class="kt-label">Transactions</div>
        <div class="kt-value" style="color:#c4b5fd;">@(Model.Revenues.Count + Model.Expenses.Count + Model.Sales.Count)</div>
    </div>
    <div class="kpi-tile" style="border-top:3px solid #06b6d4;">
        <div class="kt-label">Audit Entries</div>
        <div class="kt-value" style="color:#67e8f9;">@Model.AuditLog.Count</div>
    </div>
</div>

<!-- TABS -->
<div class="tab-bar">
    <a class="tab-btn active" onclick="switchTab('financial',this)" href="#">📊 Financial</a>
    <a class="tab-btn" onclick="switchTab('sales',this)" href="#">🛒 Sales</a>
    <a class="tab-btn" onclick="switchTab('inventory',this)" href="#">📦 Inventory</a>
    <a class="tab-btn" onclick="switchTab('suppliers',this)" href="#">🚚 Suppliers</a>
    <a class="tab-btn" onclick="switchTab('audit',this)" href="#">🔍 Audit Trail</a>
</div>

<!-- ── FINANCIAL TAB ── -->
<div id="tab-financial" class="tab-panel active">
    <div class="dark-card">
        <p class="section-title"><i class="bi bi-cash-stack" style="color:#3b82f6;font-size:1.3rem;"></i> Revenue Transactions</p>
        @if (Model.Revenues.Any())
        {
            <div class="dark-table-wrap">
                <table class="dark-table">
                    <thead><tr><th>Date</th><th>Source</th><th>Category</th><th>Amount</th><th>Notes</th><th>Recorded By</th></tr></thead>
                    <tbody>
                        @foreach (var r in Model.Revenues)
                        {
                            <tr>
                                <td style="color:#94a3b8;">@r.TransactionDate.ToString("MMM dd, yyyy")</td>
                                <td style="color:#f1f5f9;font-weight:500;">@r.Source</td>
                                <td><span class="badge-pill" style="background:rgba(59,130,246,.15);color:#93c5fd;border:1px solid rgba(59,130,246,.3);">@r.Category</span></td>
                                <td style="color:#34d399;font-weight:700;">₱@r.Amount.ToString("N0")</td>
                                <td style="color:#64748b;font-size:.82rem;">@(r.Notes ?? "—")</td>
                                <td style="color:#64748b;">@r.RecordedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p style="color:#475569;text-align:center;padding:2rem;">No revenue records for this period.</p> }
    </div>

    <div class="dark-card">
        <p class="section-title"><i class="bi bi-receipt" style="color:#ef4444;font-size:1.3rem;"></i> Expense Transactions</p>
        @if (Model.Expenses.Any())
        {
            <div class="dark-table-wrap">
                <table class="dark-table">
                    <thead><tr><th>Date</th><th>Description</th><th>Category</th><th>Amount</th><th>Supplier</th><th>Recorded By</th></tr></thead>
                    <tbody>
                        @foreach (var e in Model.Expenses)
                        {
                            <tr>
                                <td style="color:#94a3b8;">@e.ExpenseDate.ToString("MMM dd, yyyy")</td>
                                <td style="color:#f1f5f9;font-weight:500;">@e.Description</td>
                                <td><span class="badge-pill" style="background:rgba(239,68,68,.15);color:#fca5a5;border:1px solid rgba(239,68,68,.3);">@e.Category</span></td>
                                <td style="color:#fca5a5;font-weight:700;">₱@e.Amount.ToString("N0")</td>
                                <td style="color:#64748b;">@(e.Supplier ?? "—")</td>
                                <td style="color:#64748b;">@e.RecordedBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p style="color:#475569;text-align:center;padding:2rem;">No expense records for this period.</p> }
    </div>
</div>

<!-- ── SALES TAB ── -->
<div id="tab-sales" class="tab-panel">
    <div class="dark-card">
        <p class="section-title"><i class="bi bi-cart-check" style="color:#10b981;font-size:1.3rem;"></i> Sales Transactions</p>
        @if (Model.Sales.Any())
        {
            <div class="dark-table-wrap">
                <table class="dark-table">
                    <thead><tr><th>Date &amp; Time</th><th>Cashier</th><th>Total</th><th>Paid</th><th>Change</th><th>Status</th></tr></thead>
                    <tbody>
                        @foreach (var s in Model.Sales)
                        {
                            <tr>
                                <td style="color:#94a3b8;">@s.SaleDate.ToString("MMM dd, yyyy HH:mm")</td>
                                <td style="color:#f1f5f9;font-weight:500;">@(s.Cashier?.FullName ?? s.CashierId)</td>
                                <td style="color:#34d399;font-weight:700;">₱@s.TotalAmount.ToString("N0")</td>
                                <td style="color:#cbd5e1;">₱@s.AmountPaid.ToString("N0")</td>
                                <td style="color:#cbd5e1;">₱@s.Change.ToString("N0")</td>
                                <td>
                                    <span class="badge-pill" style="background:@(s.Status=="Completed"?"rgba(16,185,129,.15)":"rgba(239,68,68,.15)");color:@(s.Status=="Completed"?"#34d399":"#fca5a5");border:1px solid @(s.Status=="Completed"?"rgba(16,185,129,.3)":"rgba(239,68,68,.3)");">@s.Status</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p style="color:#475569;text-align:center;padding:2rem;">No sales for this period.</p> }
    </div>
</div>

<!-- ── INVENTORY TAB ── -->
<div id="tab-inventory" class="tab-panel">
    <div class="dark-card">
        <p class="section-title"><i class="bi bi-box-seam" style="color:#f59e0b;font-size:1.3rem;"></i> Stock Movement Log</p>
        @if (Model.StockMovements.Any())
        {
            <div class="dark-table-wrap">
                <table class="dark-table">
                    <thead><tr><th>Date</th><th>Product</th><th>Type</th><th>Qty</th><th>Before</th><th>After</th><th>By</th></tr></thead>
                    <tbody>
                        @foreach (var m in Model.StockMovements)
                        {
                            var mvColor = m.Type == MovementType.StockIn || m.Type == MovementType.Return ? "#34d399"
                                        : m.Type == MovementType.Damaged ? "#fca5a5" : "#cbd5e1";
                            <tr>
                                <td style="color:#94a3b8;">@m.MovementDate.ToString("MMM dd HH:mm")</td>
                                <td style="color:#f1f5f9;font-weight:500;">@(m.Product?.Name ?? "—")</td>
                                <td><span class="badge-pill" style="background:rgba(245,158,11,.15);color:#fcd34d;border:1px solid rgba(245,158,11,.3);">@m.Type</span></td>
                                <td style="color:@mvColor;font-weight:700;">@m.Quantity</td>
                                <td style="color:#64748b;">@m.PreviousStock</td>
                                <td style="color:#94a3b8;">@m.NewStock</td>
                                <td style="color:#64748b;">@(m.PerformedBy ?? "System")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p style="color:#475569;text-align:center;padding:2rem;">No stock movements for this period.</p> }
    </div>
</div>

<!-- ── SUPPLIERS TAB ── -->
<div id="tab-suppliers" class="tab-panel">
    <div class="dark-card">
        <p class="section-title"><i class="bi bi-truck" style="color:#8b5cf6;font-size:1.3rem;"></i> Supplier Deliveries</p>
        @if (Model.SupplierDeliveries.Any())
        {
            <div class="dark-table-wrap">
                <table class="dark-table">
                    <thead><tr><th>Date</th><th>Supplier</th><th>Product</th><th>Qty</th><th>Unit Cost</th><th>Total</th><th>Ref #</th></tr></thead>
                    <tbody>
                        @foreach (var d in Model.SupplierDeliveries)
                        {
                            <tr>
                                <td style="color:#94a3b8;">@d.DeliveryDate.ToString("MMM dd, yyyy")</td>
                                <td style="color:#f1f5f9;font-weight:500;">@(d.Supplier?.Name ?? "—")</td>
                                <td style="color:#cbd5e1;">@(d.Product?.Name ?? "—")</td>
                                <td style="color:#fcd34d;font-weight:700;">@d.Quantity</td>
                                <td style="color:#cbd5e1;">₱@d.UnitCost.ToString("N2")</td>
                                <td style="color:#fca5a5;font-weight:700;">₱@d.TotalCost.ToString("N0")</td>
                                <td style="color:#64748b;font-size:.82rem;">@(d.ReferenceNumber ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p style="color:#475569;text-align:center;padding:2rem;">No deliveries for this period.</p> }
    </div>

    <div class="dark-card">
        <p class="section-title"><i class="bi bi-credit-card" style="color:#06b6d4;font-size:1.3rem;"></i> Supplier Payments</p>
        @if (Model.SupplierPayments.Any())
        {
            <div class="dark-table-wrap">
                <table class="dark-table">
                    <thead><tr><th>Date</th><th>Supplier</th><th>Amount</th><th>Method</th><th>Ref #</th><th>Paid By</th></tr></thead>
                    <tbody>
                        @foreach (var p in Model.SupplierPayments)
                        {
                            <tr>
                                <td style="color:#94a3b8;">@p.PaymentDate.ToString("MMM dd, yyyy")</td>
                                <td style="color:#f1f5f9;font-weight:500;">@(p.Supplier?.Name ?? "—")</td>
                                <td style="color:#fca5a5;font-weight:700;">₱@p.Amount.ToString("N0")</td>
                                <td style="color:#cbd5e1;">@p.PaymentMethod</td>
                                <td style="color:#64748b;font-size:.82rem;">@(p.ReferenceNumber ?? "—")</td>
                                <td style="color:#64748b;">@p.PaidBy</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p style="color:#475569;text-align:center;padding:2rem;">No payments for this period.</p> }
    </div>
</div>

<!-- ── AUDIT TAB ── -->
<div id="tab-audit" class="tab-panel">
    <div class="dark-card">
        <p class="section-title"><i class="bi bi-shield-lock" style="color:#06b6d4;font-size:1.3rem;"></i> Audit Trail</p>
        @if (Model.AuditLog.Any())
        {
            <div class="dark-table-wrap">
                <table class="dark-table">
                    <thead><tr><th>Timestamp</th><th>User</th><th>Module</th><th>Action</th><th>Description</th><th>Severity</th></tr></thead>
                    <tbody>
                        @foreach (var a in Model.AuditLog)
                        {
                            <tr>
                                <td style="color:#94a3b8;white-space:nowrap;">@a.Timestamp.ToString("MMM dd HH:mm")</td>
                                <td style="color:#f1f5f9;font-weight:500;">@a.User</td>
                                <td><span class="badge-pill" style="background:rgba(139,92,246,.15);color:#c4b5fd;border:1px solid rgba(139,92,246,.3);">@a.Module</span></td>
                                <td style="color:#cbd5e1;">@a.Action</td>
                                <td style="color:#64748b;font-size:.82rem;">@a.Description</td>
                                <td><span class="badge-pill sev-@a.Severity">@a.Severity.ToUpper()</span></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else { <p style="color:#475569;text-align:center;padding:2rem;">No audit entries for this period.</p> }
    </div>
</div>

@section Scripts {
<script>
    function switchTab(name, el) {
        event.preventDefault();
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        el.classList.add('active');
    }
    // Auto-activate tab matching reportType
    const rt = '@Model.ReportType';
    const map = { financial:'financial', sales:'sales', inventory:'inventory', audit:'audit' };
    if (map[rt]) {
        const btn = [...document.querySelectorAll('.tab-btn')].find(b => b.getAttribute('onclick')?.includes("'" + map[rt] + "'"));
        if (btn) { document.querySelectorAll('.tab-panel').forEach(p=>p.classList.remove('active')); document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active')); document.getElementById('tab-'+map[rt]).classList.add('active'); btn.classList.add('active'); }
    }
</script>
}
