@model IEnumerable<CRLFruitstandESS.Models.ViewModels.SupplierViewModel>
@{
    ViewData["Title"] = "Suppliers";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="suppliers-container">
    <!-- Header Section -->
    <div class="suppliers-header">
        <div class="header-content">
            <span class="header-eyebrow">
                <span class="eyebrow-pulse"></span>
                Supply Chain Management
            </span>
            <h1 class="header-title">Supplier Directory</h1>
            <p class="header-subtitle">Manage and track your suppliers and their product inventory</p>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a href="/Supplier/Create" class="btn-add-supplier">
                <i class="bi bi-plus-lg"></i>
                <span>Add Supplier</span>
            </a>
        }
    </div>

    <!-- Stats Grid -->
    <div class="suppliers-stats">
        <div class="stat-item stat-blue">
            <div class="stat-glow"></div>
            <div class="stat-icon"><i class="bi bi-building"></i></div>
            <div class="stat-info">
                <div class="stat-value">@Model.Count()</div>
                <div class="stat-label">Total Suppliers</div>
            </div>
        </div>
        <div class="stat-item stat-green">
            <div class="stat-glow"></div>
            <div class="stat-icon"><i class="bi bi-check-circle"></i></div>
            <div class="stat-info">
                <div class="stat-value">@Model.Count(s => s.IsActive)</div>
                <div class="stat-label">Active</div>
            </div>
        </div>
        <div class="stat-item stat-purple">
            <div class="stat-glow"></div>
            <div class="stat-icon"><i class="bi bi-box-seam"></i></div>
            <div class="stat-info">
                <div class="stat-value">@Model.Sum(s => s.ProductCount)</div>
                <div class="stat-label">Products</div>
            </div>
        </div>
        <div class="stat-item stat-gold">
            <div class="stat-glow"></div>
            <div class="stat-icon"><i class="bi bi-percent"></i></div>
            <div class="stat-info">
                <div class="stat-value">@(Model.Count() > 0 ? Math.Round((decimal)Model.Count(s => s.IsActive) / Model.Count() * 100, 0).ToString("F0") + "%" : "0%")</div>
                <div class="stat-label">Active Rate</div>
            </div>
        </div>
    </div>

    <!-- Suppliers Card -->
    <div class="suppliers-card">
        <div class="card-header">
            <div class="header-info">
                <h3>All Suppliers</h3>
                <p>@Model.Count() total suppliers</p>
            </div>
        </div>
        
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h4>No suppliers found</h4>
                    <p>Start by adding your first supplier to your directory</p>
                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <a href="/Supplier/Create" class="btn-empty-create">
                            <i class="bi bi-plus-lg"></i> Create Supplier
                        </a>
                    }
                </div>
            }
            else
            {
                <div class="table-wrapper">
                    <table class="suppliers-table">
                        <thead>
                            <tr>
                                <th style="width: 18%;"><i class="bi bi-shop"></i> Supplier Name</th>
                                <th style="width: 15%;"><i class="bi bi-person"></i> Contact</th>
                                <th style="width: 14%;"><i class="bi bi-telephone"></i> Phone</th>
                                <th style="width: 18%;"><i class="bi bi-envelope"></i> Email</th>
                                <th style="width: 12%;"><i class="bi bi-geo-alt"></i> City</th>
                                <th style="width: 10%;"><i class="bi bi-box"></i> Products</th>
                                <th style="width: 10%;"><i class="bi bi-toggle-on"></i> Status</th>
                                <th style="width: 13%;">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var supplier in Model)
                            {
                                <tr class="supplier-row">
                                    <td class="name-cell">
                                        <span class="supplier-badge">@supplier.Name.First().ToString().ToUpper()</span>
                                        <strong>@supplier.Name</strong>
                                    </td>
                                    <td>@(supplier.ContactPerson ?? "—")</td>
                                    <td><code>@(supplier.Phone ?? "—")</code></td>
                                    <td class="email-cell">@(supplier.Email ?? "—")</td>
                                    <td>@(supplier.City ?? "—")</td>
                                    <td>
                                        <span class="product-badge">@supplier.ProductCount</span>
                                    </td>
                                    <td>
                                        @if (supplier.IsActive)
                                        {
                                            <span class="status-badge active">
                                                <i class="bi bi-check-circle-fill"></i> Active
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="status-badge inactive">
                                                <i class="bi bi-x-circle-fill"></i> Inactive
                                            </span>
                                        }
                                    </td>
                                    <td class="actions-cell">
                                        <a href="/Supplier/Details/@supplier.Id" class="action-btn view" title="View Details">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                        {
                                            <a href="/Supplier/Edit/@supplier.Id" class="action-btn edit" title="Edit">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a href="/Inventory/PaySupplier/@supplier.Id" class="action-btn pay" title="Pay Supplier">
                                                💵
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
<style>
@@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

/* ─── Container ───────────────────────────────── */
.suppliers-container {
    padding: 2rem 2.5rem;
    font-family: 'DM Sans', sans-serif;
    max-width: 1400px;
    margin: 0 auto;
}

/* ─── Header ──────────────────────────────────── */
.suppliers-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2.5rem;
    flex-wrap: wrap;
    gap: 2rem;
}

.header-content {
    flex: 1;
}

.header-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #64b5f6;
    margin-bottom: 0.8rem;
}

.eyebrow-pulse {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #42a5f5;
    box-shadow: 0 0 10px #42a5f5;
    animation: pulse 2s ease-in-out infinite;
}

@@keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
}

.header-title {
    font-family: 'Syne', sans-serif;
    font-size: clamp(1.8rem, 4vw, 2.5rem);
    font-weight: 800;
    color: #f0f4ff;
    margin: 0 0 0.4rem 0;
    line-height: 1.2;
}

.header-subtitle {
    color: #8fadd8;
    font-size: 1rem;
    margin: 0;
}

.btn-add-supplier {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 1rem 1.5rem;
    background: linear-gradient(135deg, #1b5e20, #2e7d32);
    border: 1px solid rgba(102, 187, 106, 0.3);
    border-radius: 14px;
    color: #c8e6c9;
    text-decoration: none;
    font-size: 0.95rem;
    font-weight: 600;
    transition: all 0.3s ease;
    box-shadow: 0 4px 20px rgba(46, 125, 50, 0.3);
}

.btn-add-supplier:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(46, 125, 50, 0.5);
    color: #fff;
}

/* ─── Stats Grid ──────────────────────────────── */
.suppliers-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    margin-bottom: 2.5rem;
}

.stat-item {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
}

.stat-item:hover {
    border-color: rgba(255, 255, 255, 0.15);
    transform: translateY(-4px);
}

.stat-glow {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    pointer-events: none;
}

.stat-blue .stat-glow {
    background: radial-gradient(circle, rgba(66, 165, 245, 0.15), transparent 70%);
}

.stat-green .stat-glow {
    background: radial-gradient(circle, rgba(102, 187, 106, 0.15), transparent 70%);
}

.stat-purple .stat-glow {
    background: radial-gradient(circle, rgba(192, 132, 252, 0.15), transparent 70%);
}

.stat-gold .stat-glow {
    background: radial-gradient(circle, rgba(255, 167, 38, 0.15), transparent 70%);
}

.stat-icon {
    width: 50px;
    height: 50px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
}

.stat-blue .stat-icon {
    background: rgba(66, 165, 245, 0.15) !important;
    color: #64b5f6 !important;
    box-shadow: 0 0 16px rgba(66,165,245,.2);
}

.stat-green .stat-icon {
    background: rgba(102, 187, 106, 0.15) !important;
    color: #81c784 !important;
    box-shadow: 0 0 16px rgba(102,187,106,.2);
}

.stat-purple .stat-icon {
    background: rgba(192, 132, 252, 0.15) !important;
    color: #ce93d8 !important;
    box-shadow: 0 0 16px rgba(192,132,252,.2);
}

.stat-gold .stat-icon {
    background: rgba(255, 167, 38, 0.15) !important;
    color: #ffb74d !important;
    box-shadow: 0 0 16px rgba(255,167,38,.2);
}

.stat-item .stat-value {
    font-family: 'Syne', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: #f0f4ff;
    line-height: 1;
}

.stat-item .stat-label {
    font-size: 0.85rem;
    color: #8fadd8;
    margin-top: 4px;
    text-transform: uppercase;
    letter-spacing: .06em;
    font-weight: 600;
}

/* ─── Suppliers Card ──────────────────────────── */
.suppliers-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
}

.card-header {
    padding: 1.5rem 2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(255, 255, 255, 0.02);
}

.header-info h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #f0f4ff;
    margin: 0 0 0.3rem 0;
}

.header-info p {
    color: #8fadd8;
    font-size: 0.9rem;
    margin: 0;
}

.card-body {
    padding: 0;
}

/* ─── Table ───────────────────────────────── */
.table-wrapper {
    overflow-x: auto;
    padding: 0;
}

.suppliers-table {
    width: 100%;
    border-collapse: separate;
    border-spacing: 0;
    font-size: 0.92rem;
    table-layout: fixed;
}

.suppliers-table th {
    padding: 1rem 1rem;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #64b5f6;
    background: rgba(255, 255, 255, 0.04);
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.suppliers-table th i {
    margin-right: 6px;
    color: #42a5f5;
}

.suppliers-table td {
    padding: 1rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    color: #cfd8dc;
    vertical-align: middle;
    overflow: hidden;
    text-overflow: ellipsis;
}

.supplier-row {
    transition: background 0.2s ease;
}

.supplier-row:hover {
    background: rgba(66, 165, 245, 0.08);
}

.supplier-row:last-child td {
    border-bottom: none;
}

/* ─── Table Cells ──────────────────────────── */
.name-cell {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 600;
    color: #f0f4ff;
}

.supplier-badge {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: linear-gradient(135deg, #42a5f5, #1976d2);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-weight: 700;
    font-size: 0.9rem;
    flex-shrink: 0;
}

.email-cell {
    word-break: break-all;
    max-width: 100%;
    font-size: 0.85rem;
}

.product-badge {
    display: inline-block;
    background: rgba(192, 132, 252, 0.15);
    color: #ce93d8;
    padding: 0.4rem 0.9rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    border: 1px solid rgba(192, 132, 252, 0.3);
}

.status-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 0.5rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    white-space: nowrap;
}

.status-badge.active {
    background: rgba(102, 187, 106, 0.15);
    color: #81c784;
    border: 1px solid rgba(102, 187, 106, 0.3);
}

.status-badge.inactive {
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
    border: 1px solid rgba(239, 68, 68, 0.3);
}

/* ─── Actions ──────────────────────────────── */
.actions-cell {
    display: flex;
    gap: 0.5rem;
}

.action-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    transition: all 0.2s ease;
    border: 1px solid transparent;
}

.action-btn.view {
    background: rgba(66, 165, 245, 0.15);
    color: #64b5f6;
    border-color: rgba(66, 165, 245, 0.3);
}

.action-btn.view:hover {
    background: rgba(66, 165, 245, 0.25);
    color: #90caf9;
    border-color: rgba(66, 165, 245, 0.5);
}

.action-btn.edit {
    background: rgba(255, 167, 38, 0.15);
    color: #ffb74d;
    border-color: rgba(255, 167, 38, 0.3);
}

.action-btn.edit:hover {
    background: rgba(255, 167, 38, 0.25);
    color: #ffd54f;
    border-color: rgba(255, 167, 38, 0.5);
}

.action-btn.pay {
    background: rgba(76, 175, 80, 0.15);
    color: #81c784;
    border-color: rgba(76, 175, 80, 0.3);
}

.action-btn.pay:hover {
    background: rgba(76, 175, 80, 0.25);
    color: #a5d6a7;
    border-color: rgba(76, 175, 80, 0.5);
}

/* ─── Empty State ──────────────────────────── */
.empty-state {
    padding: 4rem 2rem;
    text-align: center;
    color: #8fadd8;
}

.empty-icon {
    font-size: 4rem;
    opacity: 0.3;
    margin-bottom: 1rem;
}

.empty-state h4 {
    font-family: 'Syne', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    color: #f0f4ff;
    margin: 0 0 0.5rem 0;
}

.empty-state p {
    margin: 0 0 1.5rem 0;
    font-size: 0.95rem;
}

.btn-empty-create {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1.5rem;
    background: rgba(66, 165, 245, 0.15);
    border: 1px solid rgba(66, 165, 245, 0.3);
    border-radius: 10px;
    color: #64b5f6;
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 600;
    transition: all 0.2s ease;
}

.btn-empty-create:hover {
    background: rgba(66, 165, 245, 0.25);
    border-color: rgba(66, 165, 245, 0.5);
    color: #90caf9;
}

/* ─── Code Styling ───────────────────────────── */
code {
    background: rgba(255, 255, 255, 0.03);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    color: #90caf9;
    font-family: 'Courier New', monospace;
    font-size: 0.85rem;
    white-space: nowrap;
}

/* ─── Responsive Design ───────────────────────── */
@@media (max-width: 1024px) {
    .suppliers-stats {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .suppliers-table th,
    .suppliers-table td {
        padding: 0.75rem 0.5rem;
        font-size: 0.85rem;
    }
}

@@media (max-width: 768px) {
    .suppliers-container {
        padding: 1rem 1rem;
    }
    
    .suppliers-header {
        flex-direction: column;
    }
    
    .btn-add-supplier {
        width: 100%;
        justify-content: center;
    }
    
    .suppliers-stats {
        grid-template-columns: 1fr;
    }
    
    .header-title {
        font-size: 1.5rem;
    }
    
    .table-wrapper {
        overflow-x: auto;
    }
    
    .suppliers-table {
        font-size: 0.8rem;
        min-width: 900px;
    }
}

@@media (max-width: 480px) {
    .suppliers-container {
        padding: 0.75rem;
    }
    
    .suppliers-stats {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }
    
    .stat-item {
        flex-direction: column;
        text-align: center;
        padding: 1rem;
    }
    
    .stat-icon {
        width: 40px;
        height: 40px;
        font-size: 1.2rem;
    }
    
    .stat-value {
        font-size: 1.4rem;
    }
    
    .header-title {
        font-size: 1.2rem;
    }
    
    .name-cell {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.5rem;
    }
    
    .supplier-badge {
        width: 28px;
        height: 28px;
        font-size: 0.8rem;
    }
}
</style>
}