<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CRL Fruitstand POS</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/Cashier.css" asp-append-version="true" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <nav class="pos-navbar">
        <div class="brand">🍓 CRL Fruitstand POS</div>
        <div class="nav-links">
            <a href="/Cashier/POS"><i class="bi bi-grid-3x3-gap"></i> POS</a>
            <a href="/Cashier/DailySummary"><i class="bi bi-bar-chart"></i> Summary</a>
            @if (User.IsInRole("Admin"))
            {
                <a href="/AdminDashboard"><i class="bi bi-speedometer2"></i> Admin</a>
            }
            <form asp-action="Logout" asp-controller="Account" method="post" style="margin:0; display: inline;">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn" title="Sign Out" style="background: none; border: none; color: inherit; cursor: pointer; padding: 0; font: inherit;">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>