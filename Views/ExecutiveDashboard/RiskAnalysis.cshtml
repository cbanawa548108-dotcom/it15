@using CRLFruitstandESS.Models.ViewModels
@using CRLFruitstandESS.Models.Executive
@model RiskAnalysisViewModel
@{
    ViewData["Title"] = "Risk Analysis";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
    <style>
        .page-content { background: #0f172a !important; min-height: 100vh; }

        .risk-header {
            background: linear-gradient(135deg, #1e293b 0%, #0f172a 100%);
            border: 1px solid #334155;
            padding: 2.5rem 2rem;
            border-radius: 14px;
            color: white;
            margin-bottom: 2rem;
            position: relative;
            overflow: hidden;
        }
        .risk-header::before {
            content: '';
            position: absolute;
            top: -60px; right: -60px;
            width: 300px; height: 300px;
            background: radial-gradient(circle, rgba(59,130,246,0.15) 0%, transparent 70%);
            border-radius: 50%;
            pointer-events: none;
        }
        .risk-header > div { position: relative; z-index: 1; }

        .dark-card {
            background: #1e293b;
            border: 1px solid #334155;
            border-radius: 14px;
            padding: 1.75rem;
            margin-bottom: 2rem;
            transition: all 0.3s ease;
        }
        .dark-card:hover {
            border-color: #475569;
            box-shadow: 0 8px 32px rgba(0,0,0,0.4);
            transform: translateY(-2px);
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: #f1f5f9;
            display: flex;
            align-items: center;
            gap: 0.75rem;
            margin: 0 0 1.5rem 0;
        }

        .stat-tile {
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 10px;
            padding: 1.5rem;
            transition: border-color 0.2s ease;
        }
        .stat-tile:hover { border-color: #3b82f6; }
        .stat-tile .label {
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #64748b;
            margin-bottom: 0.75rem;
        }
        .stat-tile .value {
            font-size: 2.25rem;
            font-weight: 800;
            color: #f1f5f9;
            line-height: 1;
            margin-bottom: 0.5rem;
        }
        .stat-tile .sub { font-size: 0.85rem; font-weight: 600; }

        .risk-bar-track {
            height: 8px;
            background: #0f172a;
            border-radius: 4px;
            overflow: hidden;
            margin: 0.5rem 0 1.25rem;
        }
        .risk-bar-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.5s cubic-bezier(0.4,0,0.2,1);
        }

        .badge-pill {
            display: inline-block;
            padding: 0.3rem 0.75rem;
            border-radius: 20px;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }

        .dark-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
        .dark-table thead tr { background: #0f172a; }
        .dark-table thead th {
            padding: 1rem 1.25rem;
            text-align: left;
            font-size: 0.75rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            color: #64748b;
            border-bottom: 1px solid #334155;
        }
        .dark-table tbody tr {
            border-bottom: 1px solid #1e293b;
            transition: background 0.2s ease;
        }
        .dark-table tbody tr:hover { background: #1e293b; }
        .dark-table tbody td { padding: 1rem 1.25rem; color: #cbd5e1; }

        .dark-input {
            width: 100%;
            padding: 0.875rem 1rem;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 8px;
            color: #f1f5f9;
            font-size: 0.95rem;
            box-sizing: border-box;
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            outline: none;
        }
        .dark-input:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        }
        .dark-input option { background: #1e293b; }

        .btn-primary-dark {
            padding: 0.875rem 2rem;
            background: #3b82f6;
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 700;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            transition: all 0.2s ease;
            outline: none;
        }
        .btn-primary-dark:hover  { background: #2563eb; transform: translateY(-2px); box-shadow: 0 6px 20px rgba(59,130,246,0.45); }
        .btn-primary-dark:active { background: #1d4ed8; transform: translateY(0) scale(0.98); box-shadow: none; }
        .btn-primary-dark:focus-visible { box-shadow: 0 0 0 3px rgba(59,130,246,0.5); }

        .btn-ghost-dark {
            padding: 0.875rem 2rem;
            background: transparent;
            color: #94a3b8;
            border: 1px solid #334155;
            border-radius: 8px;
            font-size: 0.95rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            outline: none;
        }
        .btn-ghost-dark:hover  { border-color: #64748b; color: #f1f5f9; background: #1e293b; box-shadow: 0 0 0 1px #64748b; }
        .btn-ghost-dark:active { background: #0f172a; transform: scale(0.98); }
        .btn-ghost-dark:focus-visible { box-shadow: 0 0 0 3px rgba(100,116,139,0.4); }

        .form-label { display: block; margin-bottom: 0.5rem; font-weight: 600; color: #94a3b8; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.05em; }
    </style>
}

<!-- HEADER -->
<div class="risk-header">
    <div>
        <span style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:0.1em;color:#3b82f6;display:block;margin-bottom:0.5rem;">Risk Management</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 0.5rem 0;color:#f1f5f9;">Risk Analysis Dashboard</h1>
        <p style="margin:0;font-size:1rem;color:#94a3b8;">Comprehensive business risk assessment &amp; mitigation strategies</p>
    </div>
</div>

@if (Model?.RiskAssessments == null || Model.RiskAssessments.Count == 0)
{
    <div style="padding:2.5rem;border-radius:14px;background:#1e293b;border:1px solid #334155;border-left:4px solid #3b82f6;">
        <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem;">
            <span style="font-size:2rem;">📊</span>
            <h4 style="margin:0;color:#f1f5f9;font-size:1.25rem;">Insufficient Data</h4>
        </div>
        <p style="margin:0 0 0.75rem;color:#94a3b8;">Risk analysis requires at least 7 days of historical revenue and expense data.</p>
        <small style="color:#64748b;display:flex;align-items:center;gap:0.5rem;"><i class="bi bi-lightbulb" style="color:#3b82f6;"></i> Tip: Go to Cashier Dashboard to record sales or Inventory Dashboard to record expenses.</small>
    </div>
}
else
{
    <!-- OVERALL RISK SCORE -->
    <div class="dark-card">
        <p class="section-title">
            <i class="bi bi-shield-check" style="color:#3b82f6;font-size:1.4rem;"></i> Overall Risk Assessment
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.25rem;">
            <div class="stat-tile" style="border-left:3px solid #3b82f6;">
                <div class="label">Risk Score</div>
                <div class="value">@Model.OverallRiskScore.ToString("F2")</div>
                <div class="sub" style="color:#3b82f6;">out of 1.00</div>
            </div>
            <div class="stat-tile" style="border-left:3px solid @((Model.OverallRiskScore >= 0.7) ? "#ef4444" : (Model.OverallRiskScore >= 0.5) ? "#f59e0b" : "#10b981");">
                <div class="label">Status</div>
                <div class="value" style="font-size:1.75rem;">@Model.OverallRiskStatus</div>
                <div class="sub">
                    @if (Model.OverallRiskScore >= 0.7) { <span style="color:#ef4444;">🔴 High Risk</span> }
                    else if (Model.OverallRiskScore >= 0.5) { <span style="color:#f59e0b;">🟡 Medium Risk</span> }
                    else { <span style="color:#10b981;">🟢 Low Risk</span> }
                </div>
            </div>
            <div class="stat-tile" style="border-left:3px solid #10b981;">
                <div class="label">Active Risks</div>
                <div class="value">@Model.RiskAssessments.Count()</div>
                <div class="sub" style="color:#10b981;">categories monitored</div>
            </div>
        </div>
    </div>

    <!-- HIGHEST RISK -->
    @if (Model.HighestRisk != null)
    {
        <div class="dark-card" style="border-left:4px solid #ef4444;background:linear-gradient(135deg,#1e293b 0%,#1a1a2e 100%);">
            <p class="section-title" style="color:#fca5a5;">
                <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;font-size:1.4rem;"></i> Highest Risk: @Model.HighestRisk.RiskCategory
            </p>
            <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1.25rem;margin-bottom:1.5rem;">
                <div class="stat-tile" style="border-left:3px solid #ef4444;">
                    <div class="label">Risk Score</div>
                    <div class="value" style="color:#fca5a5;">@Model.HighestRisk.RiskScore.ToString("F2")</div>
                </div>
                <div class="stat-tile" style="border-left:3px solid #ef4444;">
                    <div class="label">Probability</div>
                    <div class="value" style="color:#fca5a5;">@((Model.HighestRisk.Probability * 100).ToString("F0"))%</div>
                </div>
                <div class="stat-tile" style="border-left:3px solid #ef4444;">
                    <div class="label">Impact</div>
                    <div class="value" style="color:#fca5a5;">@((Model.HighestRisk.Impact * 100).ToString("F0"))%</div>
                </div>
            </div>
            @if (Model.HighestRisk.Insights.Any())
            {
                <div style="padding-top:1.25rem;border-top:1px solid #334155;">
                    <p style="margin:0 0 0.75rem;font-weight:700;color:#fca5a5;display:flex;align-items:center;gap:0.5rem;font-size:0.9rem;">
                        <i class="bi bi-lightbulb-fill" style="color:#ef4444;"></i> Key Insights
                    </p>
                    <ul style="margin:0;padding-left:1.5rem;display:flex;flex-direction:column;gap:0.4rem;">
                        @foreach (var insight in Model.HighestRisk.Insights.Take(3))
                        {
                            <li style="color:#94a3b8;font-size:0.9rem;">@insight</li>
                        }
                    </ul>
                </div>
            }
        </div>
    }

    <!-- ALL RISK CATEGORIES -->
    <div style="margin-bottom:2rem;">
        <p class="section-title" style="color:#f1f5f9;">
            <i class="bi bi-list-check" style="color:#3b82f6;font-size:1.4rem;"></i> All Risk Categories
        </p>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:1.25rem;">
            @foreach (var risk in Model.RiskAssessments.OrderByDescending(r => r.RiskScore))
            {
                var accentColor = risk.Status == "red" ? "#ef4444" : risk.Status == "yellow" ? "#f59e0b" : "#10b981";
                <div class="dark-card" style="margin-bottom:0;border-top:3px solid @accentColor;">
                    <div style="display:flex;justify-content:space-between;align-items:start;margin-bottom:1rem;">
                        <h5 style="margin:0;color:#f1f5f9;font-size:1rem;font-weight:700;">@risk.RiskCategory</h5>
                        <span class="badge-pill" style="background:@(risk.Status == "red" ? "rgba(239,68,68,0.15)" : risk.Status == "yellow" ? "rgba(245,158,11,0.15)" : "rgba(16,185,129,0.15)");color:@accentColor;border:1px solid @accentColor;">@risk.Status</span>
                    </div>
                    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:0.4rem;">
                        <small style="color:#64748b;font-weight:600;font-size:0.8rem;">RISK SCORE</small>
                        <strong style="color:#f1f5f9;font-size:1.1rem;">@risk.RiskScore.ToString("F2")</strong>
                    </div>
                    <div class="risk-bar-track">
                        <div class="risk-bar-fill" style="width:@(risk.RiskScore * 100)%;background:linear-gradient(to right,@accentColor,@accentColor);opacity:0.85;"></div>
                    </div>
                    <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;margin-bottom:0.75rem;">
                        <div style="background:#0f172a;border-radius:8px;padding:0.875rem;border:1px solid #334155;">
                            <small style="color:#64748b;font-size:0.75rem;font-weight:700;text-transform:uppercase;display:block;margin-bottom:0.4rem;">Probability</small>
                            <span style="color:#f1f5f9;font-weight:700;font-size:1.1rem;">@((risk.Probability * 100).ToString("F0"))%</span>
                        </div>
                        <div style="background:#0f172a;border-radius:8px;padding:0.875rem;border:1px solid #334155;">
                            <small style="color:#64748b;font-size:0.75rem;font-weight:700;text-transform:uppercase;display:block;margin-bottom:0.4rem;">Impact</small>
                            <span style="color:#f1f5f9;font-weight:700;font-size:1.1rem;">@((risk.Impact * 100).ToString("F0"))%</span>
                        </div>
                    </div>
                    @if (risk.Volatility.HasValue)
                    {
                        <div style="padding-top:0.75rem;border-top:1px solid #334155;font-size:0.85rem;">
                            <span style="color:#64748b;">Volatility: </span>
                            <strong style="color:#94a3b8;">@risk.Volatility.Value.ToString("F1")%</strong>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    <!-- RISK REGISTER -->
    @if (Model?.RiskRegister != null && Model.RiskRegister.Any())
    {
        <div class="dark-card">
            <p class="section-title">
                <i class="bi bi-table" style="color:#8b5cf6;font-size:1.4rem;"></i> Risk Register
            </p>
            <div style="overflow-x:auto;border-radius:10px;border:1px solid #334155;">
                <table class="dark-table">
                    <thead>
                        <tr>
                            <th>Risk Name</th>
                            <th>Category</th>
                            <th>Priority</th>
                            <th>Status</th>
                            <th>Owner</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.RiskRegister.OrderByDescending(r => r.Priority).Take(10))
                        {
                            <tr>
                                <td style="color:#f1f5f9;font-weight:500;">@item.RiskName</td>
                                <td>
                                    <span class="badge-pill" style="background:rgba(139,92,246,0.15);color:#a78bfa;border:1px solid rgba(139,92,246,0.3);">@item.Category</span>
                                </td>
                                <td>
                                    <span class="badge-pill" style="background:@(item.Priority == "high" ? "rgba(239,68,68,0.15)" : item.Priority == "medium" ? "rgba(245,158,11,0.15)" : "rgba(16,185,129,0.15)");color:@(item.Priority == "high" ? "#fca5a5" : item.Priority == "medium" ? "#fcd34d" : "#6ee7b7");border:1px solid @(item.Priority == "high" ? "rgba(239,68,68,0.3)" : item.Priority == "medium" ? "rgba(245,158,11,0.3)" : "rgba(16,185,129,0.3)");">@item.Priority.ToUpper()</span>
                                </td>
                                <td style="color:#94a3b8;">@item.Status</td>
                                <td style="color:#64748b;">@(item.Owner ?? "Unassigned")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <!-- CREATE RISK ALERT -->
    <div class="dark-card">
        <p class="section-title">
            <i class="bi bi-plus-circle-dotted" style="color:#3b82f6;font-size:1.4rem;"></i> Create Risk Alert
        </p>
        <form method="post" action="@Url.Action("AddRiskAlert", "ExecutiveDashboard")">
            @Html.AntiForgeryToken()
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:1.25rem;margin-bottom:1.5rem;">
                <div>
                    <label class="form-label">Alert Title</label>
                    <input type="text" name="title" class="dark-input" placeholder="e.g., Supply Chain Disruption Risk" required />
                </div>
                <div>
                    <label class="form-label">Severity Level</label>
                    <select name="severity" class="dark-input" required>
                        <option value="info">ℹ️ Info</option>
                        <option value="warning">⚠️ Warning</option>
                        <option value="critical">🚨 Critical</option>
                    </select>
                </div>
                <div>
                    <label class="form-label">Risk Category</label>
                    <select name="category" class="dark-input" required>
                        <option value="">Select category...</option>
                        <option value="revenue">💰 Revenue</option>
                        <option value="expenses">💸 Expenses</option>
                        <option value="profitability">📈 Profitability</option>
                        <option value="inventory">📦 Inventory</option>
                        <option value="operational">⚙️ Operational</option>
                        <option value="external">🌍 External/Market</option>
                    </select>
                </div>
                <div style="grid-column:1/-1;">
                    <label class="form-label">Alert Description</label>
                    <textarea name="message" class="dark-input" placeholder="Provide detailed information about this risk..." required rows="4" style="resize:vertical;"></textarea>
                </div>
            </div>
            <div style="display:flex;gap:1rem;">
                <button type="submit" class="btn-primary-dark">
                    <i class="bi bi-exclamation-triangle-fill"></i> Create Alert
                </button>
                <button type="reset" class="btn-ghost-dark">Reset</button>
            </div>
        </form>
    </div>
}
