@model CRLFruitstandESS.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Cashier Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-header">
    <div>
        <span class="dash-label">Point of Sale Terminal</span>
        <h1 class="dash-title">Cashier Dashboard</h1>
        <p class="dash-sub">@Model.WelcomeMessage</p>
    </div>
    <div class="dash-badge cashier-badge">
        <i class="bi bi-cart"></i> @Model.Role
    </div>
</div>

@if (Model.Alerts?.Any() == true)
{
    <div class="alerts-container">
        @foreach (var alert in Model.Alerts)
        {
            <div class="alert-card alert-@alert.Type">
                <div class="alert-icon"><i class="bi bi-info-circle-fill"></i></div>
                <div class="alert-content">
                    <h4>@alert.Title</h4>
                    <p>@alert.Message</p>
                </div>
            </div>
        }
    </div>
}

<!-- Today's Stats -->
<div class="stats-grid three-col">
    <div class="stat-card highlight-green">
        <div class="stat-icon si-green">
            <i class="bi bi-currency-dollar"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">₱@Model.TodaysRevenue.ToString("N0")</div>
            <div class="stat-label">Your Sales Today</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon si-blue">
            <i class="bi bi-receipt"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">@Model.TodaysTransactions</div>
            <div class="stat-label">Transactions</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon si-purple">
            <i class="bi bi-clock-history"></i>
        </div>
        <div class="stat-info">
            <div class="stat-value">@DateTime.Now.ToString("HH:mm")</div>
            <div class="stat-label">Current Time</div>
        </div>
    </div>
</div>

<!-- Main Action -->
<div class="main-action-container">
    <a href="/Cashier" class="btn-main-action">
        <i class="bi bi-cart-plus-fill"></i>
        <span>Start New Sale</span>
    </a>
</div>

<!-- Quick Actions -->
<div class="dashboard-card">
    <div class="card-header">
        <h3><i class="bi bi-lightning-charge"></i> Quick Actions</h3>
    </div>
    <div class="card-body">
        <div class="quick-actions-grid cashier">
            @foreach (var action in Model.QuickActions)
            {
                <a href="@action.Url" class="quick-action-btn action-@action.Color">
                    <i class="bi @action.Icon"></i>
                    <span>@action.Label</span>
                </a>
            }
        </div>
    </div>
</div>

@section Styles {
<style>
    .cashier-badge {
        background: linear-gradient(135deg, #8b5cf6, #7c3aed);
    }

    .three-col {
        grid-template-columns: repeat(3, 1fr);
    }

    .highlight-green {
        border: 2px solid rgba(34, 197, 94, 0.3);
        background: rgba(34, 197, 94, 0.05);
    }

    .main-action-container {
        margin: 2rem 0;
        text-align: center;
    }

    .btn-main-action {
        display: inline-flex;
        align-items: center;
        gap: 1rem;
        padding: 1.5rem 3rem;
        background: linear-gradient(135deg, #22c55e, #16a34a);
        color: white;
        border-radius: 16px;
        font-size: 1.25rem;
        font-weight: 700;
        text-decoration: none;
        box-shadow: 0 10px 40px rgba(34, 197, 94, 0.3);
        transition: all 0.3s;
    }

    .btn-main-action:hover {
        transform: translateY(-3px);
        box-shadow: 0 15px 50px rgba(34, 197, 94, 0.4);
    }

    .btn-main-action i {
        font-size: 1.5rem;
    }

    .quick-actions-grid.cashier {
        grid-template-columns: repeat(2, 1fr);
    }

    @@media (max-width: 768px) {
        .three-col {
            grid-template-columns: 1fr;
        }
    }
</style>
}