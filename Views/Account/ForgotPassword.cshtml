@model CRLFruitstandESS.Models.ViewModels.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-page">
    <div class="login-card">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <img src="/images/logo_cropped.png" style="width:140px;height:140px;object-fit:contain;border-radius:50%;mix-blend-mode:screen;filter:brightness(1.1) drop-shadow(0 0 20px rgba(59,130,246,0.6));margin:0 auto 0.75rem;display:block;" />
            <h1>Forgot Password</h1>
            <p class="sub">Enter your registered email and we'll send a 6-digit reset code</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);
                        border-radius:8px;padding:0.875rem 1rem;margin-bottom:1.25rem;
                        color:#f87171;font-size:0.875rem;">
                @Html.ValidationSummary(false, "", new { style = "list-style:none;padding:0;margin:0;" })
            </div>
        }

        <form asp-action="ForgotPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <div class="form-group">
                <label asp-for="Email">Email Address</label>
                <input asp-for="Email" class="form-input" type="email"
                       placeholder="your@email.com" autofocus autocomplete="email" />
                <span asp-validation-for="Email" class="field-error"></span>
            </div>
            <button type="submit" class="login-btn">Send Reset Code</button>
        </form>

        <div style="margin-top:1.5rem;text-align:center;">
            <a href="/Account/Login" style="color:#8fadd8;font-size:.85rem;">← Back to Login</a>
        </div>
    </div>
</div>






