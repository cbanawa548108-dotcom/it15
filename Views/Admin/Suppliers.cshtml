@using CRLFruitstandESS.Models
@model List<Supplier>
@{ ViewData["Title"] = "Supplier Management"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }
@section Styles {
<style>
.page-content{background:#060d1a!important;min-height:100vh}
.adm-header{background:linear-gradient(135deg,#0f2044,#0a1628);border:1px solid #1e3a6e;padding:2.5rem 2rem;border-radius:14px;margin-bottom:2rem}
.blue-card{background:#0d1f3c;border:1px solid #1e3a6e;border-radius:14px;padding:1.75rem;margin-bottom:1.5rem}
.dark-input{padding:.65rem 1rem;background:#060d1a;border:1px solid #1e3a6e;border-radius:8px;color:#e2e8f0;font-size:.875rem;outline:none;transition:border-color .2s,box-shadow .2s}
.dark-input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.2)}
.btn-blue{display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.5rem;background:#2563eb;color:white;border:none;border-radius:8px;font-size:.875rem;font-weight:700;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.btn-blue:hover{background:#1d4ed8;transform:translateY(-1px);box-shadow:0 4px 16px rgba(37,99,235,.4)}
.btn-ghost{display:inline-flex;align-items:center;gap:.4rem;padding:.45rem .875rem;background:transparent;color:#64748b;border:1px solid #1e3a6e;border-radius:6px;font-size:.78rem;font-weight:600;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.btn-ghost:hover{border-color:#3b82f6;color:#93c5fd}
.adm-table{width:100%;border-collapse:collapse;font-size:.875rem}
.adm-table thead tr{background:#060d1a}
.adm-table thead th{padding:.875rem 1rem;text-align:left;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#334155;border-bottom:1px solid #1e3a6e}
.adm-table tbody tr{border-bottom:1px solid #0d1f3c;transition:background .15s}
.adm-table tbody tr:hover{background:#0d1f3c}
.adm-table tbody td{padding:.875rem 1rem;color:#cbd5e1}
</style>
}
<div class="adm-header">
    <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#3b82f6;display:block;margin-bottom:.5rem;">Administration</span>
    <h1 style="font-size:2rem;font-weight:800;margin:0 0 .4rem;color:#f1f5f9;">Supplier Management</h1>
    <p style="margin:0;font-size:.9rem;color:#475569;">Manage supplier accounts, contacts, and status</p>
</div>
@if (TempData["Success"] != null) { <div style="padding:1rem 1.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:8px;color:#34d399;margin-bottom:1.5rem;font-weight:600;">✓ @TempData["Success"]</div> }

<div class="blue-card">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <form method="get" style="display:flex;gap:.75rem;align-items:center;">
            <input name="search" value="@ViewBag.Search" class="dark-input" placeholder="Search suppliers…" style="width:260px;"/>
            <button type="submit" class="btn-blue"><i class="bi bi-search"></i></button>
        </form>
        <a href="/Admin/CreateSupplier" class="btn-blue"><i class="bi bi-plus-lg"></i> New Supplier</a>
    </div>
</div>

<div class="blue-card">
    <div style="overflow-x:auto;border-radius:10px;border:1px solid #1e3a6e;">
        <table class="adm-table">
            <thead><tr><th>Supplier</th><th>Contact</th><th>Phone</th><th>City</th><th>Balance</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="7" style="text-align:center;color:#334155;padding:3rem;">No suppliers found.</td></tr> }
                @foreach (var s in Model) {
                    <tr>
                        <td>
                            <div style="font-weight:600;color:#f1f5f9;">@s.Name</div>
                            @if (!string.IsNullOrEmpty(s.Email)) { <div style="font-size:.75rem;color:#475569;">@s.Email</div> }
                        </td>
                        <td style="color:#94a3b8;">@(s.ContactPerson ?? "—")</td>
                        <td style="color:#94a3b8;">@(s.Phone ?? "—")</td>
                        <td style="color:#94a3b8;">@(s.City ?? "—")</td>
                        <td style="color:@(s.Balance>0?"#fca5a5":"#34d399");font-weight:700;">₱@s.Balance.ToString("N2")</td>
                        <td><span style="font-size:.78rem;font-weight:600;color:@(s.IsActive?"#34d399":"#475569");">@(s.IsActive?"Active":"Inactive")</span></td>
                        <td>
                            <div style="display:flex;gap:.5rem;">
                                <a href="/Admin/EditSupplier/@s.Id" class="btn-ghost"><i class="bi bi-pencil"></i> Edit</a>
                                <form method="post" action="/Admin/ToggleSupplier" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@s.Id"/>
                                    <button type="submit" class="btn-ghost">@(s.IsActive?"Disable":"Enable")</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
