@model CRLFruitstandESS.Models.SupplierDelivery
@{
    ViewData["Title"] = "Record Delivery";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="delivery-form-page">
    <div class="form-card">
        <div class="form-header">
            <div class="header-icon">
                <i class="bi bi-truck"></i>
            </div>
            <div>
                <h2 class="form-title">Record Supplier Delivery</h2>
                <p class="form-subtitle">Log incoming goods from your supplier</p>
            </div>
        </div>

        <form asp-action="CreateDelivery" method="post" class="delivery-form">
            @Html.AntiForgeryToken()

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Supplier <span class="required">*</span></label>
                    <select asp-for="SupplierId" class="form-select" id="supplierSelect" required>
                        <option value="">-- Select Supplier --</option>
                        @foreach (var supplier in ViewBag.Suppliers)
                        {
                            <option value="@supplier.Id">@supplier.Name</option>
                        }
                    </select>
                </div>

                <div class="form-group">
                    <label class="form-label">Product <span class="required">*</span></label>
                    <select asp-for="ProductId" class="form-select" id="productSelect" required>
                        <option value="">-- Select Product --</option>
                        @foreach (var product in ViewBag.Products)
                        {
                            <option value="@product.Id">
                                @product.Emoji @product.Name
                            </option>
                        }
                    </select>
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Quantity <span class="required">*</span></label>
                    <input asp-for="Quantity" type="number" class="form-control" min="1" required placeholder="Enter quantity received" />
                </div>

                <div class="form-group">
                    <label class="form-label">Unit Cost (₱) <span class="required">*</span></label>
                    <input asp-for="UnitCost" type="number" step="0.01" class="form-control" min="0" required placeholder="Cost per unit" />
                </div>
            </div>

            <div class="form-group">
                <label class="form-label">Reference Number <span class="required">*</span></label>
                <input asp-for="ReferenceNumber" class="form-control" required placeholder="Invoice number, delivery receipt, etc." />
            </div>

            <div class="form-group">
                <label class="form-label">Notes (Optional)</label>
                <textarea asp-for="Notes" class="form-control" rows="3" placeholder="Condition of goods, special instructions, etc."></textarea>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-check-circle"></i> Save Delivery
                </button>
                <a href="/Inventory/Stocks" class="btn btn-outline-secondary btn-lg">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Styles {
<style>
    .delivery-form-page {
        max-width: 700px;
        margin: 2rem auto;
        padding: 0 1rem;
    }

    .form-card {
        background: rgba(255, 255, 255, 0.05);
        border-radius: 20px;
        padding: 2rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .form-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 2rem;
    }

    .header-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: white;
    }

    .form-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: #f8fafc;
        margin: 0;
    }

    .form-subtitle {
        color: #94a3b8;
        margin: 0.25rem 0 0;
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-weight: 500;
        color: #e2e8f0;
    }

    .required {
        color: #ef4444;
    }

    .form-control, .form-select {
        width: 100%;
        padding: 0.75rem 1rem;
        background: rgba(15, 23, 42, 0.5);
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        color: #e2e8f0;
        font-size: 0.9375rem;
    }

    .form-control:focus, .form-select:focus {
        outline: none;
        border-color: #3b82f6;
    }

    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
    }

    .form-actions .btn {
        flex: 1;
        padding: 0.875rem;
        border-radius: 10px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
        text-decoration: none;
        transition: all 0.2s;
    }

    .btn-primary {
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        border: none;
    }

    .btn-outline-secondary {
        background: transparent;
        border: 2px solid rgba(255, 255, 255, 0.2);
        color: #94a3b8;
    }

    @@media (max-width: 768px) {
        .form-row { grid-template-columns: 1fr; }
    }
</style>
}