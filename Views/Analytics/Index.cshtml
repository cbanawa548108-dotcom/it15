// DRILL-DOWN SIDE PANEL
// ════════════════════════════════════════════
let drillInst = null;

async function openDrill(url) {
    document.getElementById('drillPanel').classList.add('open');
    document.getElementById('drillBackdrop').classList.add('open');
    document.getElementById('drillTitle').textContent = 'Loading…';
    document.getElementById('drillTableWrap').style.display = 'none';
    if (drillInst) { drillInst.destroy(); drillInst = null; }

    const data = await fetch(url).then(r => r.json());
    document.getElementById('drillTitle').textContent = data.title;

    const ctx = document.getElementById('drillChart').getContext('2d');
    drillInst = new Chart(ctx, {
        type: data.type,
        data: {
            labels: data.labels,
            datasets: data.datasets.map((ds, i) => ({
                label: ds.label, data: ds.data,
                backgroundColor: ds.backgroundColor || PALETTE[i] + '88',
                borderColor:     ds.borderColor     || PALETTE[i],
                borderWidth: data.type === 'line' ? 2 : 1,
                borderRadius: 4, tension: .4,
                fill: data.type === 'line',
                pointRadius: data.type === 'line' ? 3 : undefined
            }))
        },
        options: {
            responsive: true,
            interaction: { mode: 'index', intersect: false },
            plugins: {
                legend: { labels: { color: '#475569', usePointStyle: true } },
                tooltip: tip({ callbacks: { label: c => ' ₱' + Number(c.parsed.y ?? c.parsed).toLocaleString() } })
            },
            scales: data.type !== 'doughnut' && data.type !== 'pie' ? {
                x: { ticks: { color: '#334155' }, grid: { color: 'rgba(255,255,255,.03)' } },
                y: { ticks: { color: '#334155', callback: v => '₱' + (v >= 1000 ? (v/1000).toFixed(0)+'k' : v) }, grid: { color: 'rgba(255,255,255,.03)' } }
            } : {}
        }
    });

    if (data.rows?.length) {
        document.getElementById('drillTableBody').innerHTML = data.rows.slice(0,40).map(r =>
            `<tr>
                <td style="color:#475569;white-space:nowrap;">${r.date}</td>
                <td style="color:#94a3b8;">${r.label}</td>
                <td><span style="padding:.15rem .5rem;border-radius:999px;background:rgba(99,102,241,.12);color:#818cf8;font-size:.65rem;font-weight:700;">${r.category}</span></td>
                <td style="color:#34d399;font-weight:700;">₱${Number(r.amount).toLocaleString()}</td>
            </tr>`
        ).join('');
        document.getElementById('drillTableWrap').style.display = 'block';
    }
}

function closeDrill() {
    document.getElementById('drillPanel').classList.remove('open');
    document.getElementById('drillBackdrop').classList.remove('open');
    if (drillInst) { drillInst.destroy(); drillInst = null; }
}

function drillTrend()      { openDrill(`/Analytics/DrillRevenue?category=all&period=${PERIOD}`); }
function drillExpensePie() { openDrill(`/Analytics/DrillExpense?category=all&period=${PERIOD}`); }
function drillRevenuePie() { openDrill(`/Analytics/DrillRevenue?category=all&period=${PERIOD}`); }

document.addEventListener('keydown', e => { if (e.key === 'Escape') closeDrill(); });

// ── HEAT MAP
fetch(`/Analytics/HeatMapData?period=${PERIOD}`).then(r=>r.json()).then(rows=>{
    const days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    const maxVal=Math.max(...rows.map(r=>Number(r.value)),1);
    const datasets=days.map((d,di)=>({
        label:d,
        data:rows.filter(r=>r.day===d).map(r=>({x:r.hour,y:di,r:Math.max(4,Math.sqrt(Number(r.value)/maxVal)*18)})),
        backgroundColor:`hsla(${di*50},70%,60%,.6)`
    }));
    new Chart(document.getElementById('heatChart'),{
        type:'bubble', data:{datasets},
        options:{responsive:true,
            plugins:{legend:{display:false},
                tooltip:{backgroundColor:'#0d1526',borderColor:'rgba(99,102,241,.3)',borderWidth:1,titleColor:'#e2e8f0',bodyColor:'#64748b',
                    callbacks:{label:c=>`${days[c.parsed.y]} ${c.parsed.x}:00 — ₱${(rows.find(r=>r.day===days[c.parsed.y]&&r.hour===c.parsed.x)?.value||0).toLocaleString()}`}}},
            scales:{
                x:{min:0,max:23,ticks:{color:'#334155',callback:v=>v+':00',stepSize:3},grid:{color:'rgba(255,255,255,.03)'}},
                y:{min:-0.5,max:6.5,ticks:{color:'#475569',callback:v=>days[v]||''},grid:{color:'rgba(255,255,255,.03)'}}
            }}
    });
});

