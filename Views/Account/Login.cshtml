@model CRLFruitstandESS.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-page">
    <div class="login-card">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <img src="/images/logo_cropped.png" style="width:140px;height:140px;object-fit:contain;border-radius:50%;mix-blend-mode:screen;filter:brightness(1.1) drop-shadow(0 0 20px rgba(59,130,246,0.6));margin:0 auto 0.75rem;display:block;" />
            <h1>Welcome Back</h1>
            <p class="sub">Sign in to the Executive Decision Support System</p>
        </div>

        @{
            var errorMessages = ViewData.ModelState
                .Where(x => x.Value?.Errors.Count > 0)
                .SelectMany(x => x.Value!.Errors)
                .Select(e => e.ErrorMessage)
                .Where(m => !string.IsNullOrEmpty(m))
                .ToList();
        }
        @if (errorMessages.Any())
        {
            <div style="display:flex;align-items:flex-start;gap:0.6rem;background:rgba(239,68,68,0.1);
                        border:1px solid rgba(239,68,68,0.3);border-radius:10px;padding:0.875rem 1rem;
                        color:#fca5a5;font-size:0.875rem;margin-bottom:1.25rem;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" style="flex-shrink:0;margin-top:2px;">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
                <div>
                    @foreach (var msg in errorMessages)
                    {
                        <div>@msg</div>
                    }
                </div>
            </div>
        }
        @if (TempData["Info"] != null)
        {
            <div style="padding:0.875rem 1rem;background:rgba(59,130,246,0.1);border:1px solid rgba(59,130,246,0.3);border-radius:8px;color:#93c5fd;margin-bottom:1.25rem;font-size:0.875rem;">
                ℹ️ @TempData["Info"]
            </div>
        }
        @if (TempData["Success"] != null)
        {
            <div style="padding:0.875rem 1rem;background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:8px;color:#34d399;margin-bottom:1.25rem;font-size:0.875rem;">
                ✅ @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div style="padding:0.875rem 1rem;background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:8px;color:#fca5a5;margin-bottom:1.25rem;font-size:0.875rem;">
                ❌ @TempData["Error"]
            </div>
        }

        <form asp-action="Login" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="form-group">
                <label asp-for="UserName">Username</label>
                <input asp-for="UserName" class="form-input" placeholder="Enter your username"
                       autocomplete="username" autofocus />
                <span asp-validation-for="UserName" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Password</label>
                <div class="input-wrap">
                    <input asp-for="Password" class="form-input" type="password"
                           placeholder="Enter your password" autocomplete="current-password" id="passwordField" />
                    <button type="button" class="toggle-pw" onclick="togglePassword()" aria-label="Show password">
                        <svg id="eyeIcon" xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                             viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="form-check">
                <input asp-for="RememberMe" type="checkbox" id="rememberMe" />
                <label for="rememberMe">Keep me signed in</label>
            </div>

            <button type="submit" class="login-btn">
                Sign In to ESS
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="5" y1="12" x2="19" y2="12"/>
                    <polyline points="12 5 19 12 12 19"/>
                </svg>
            </button>
        </form>

        <div style="margin-top:2rem;padding-top:1.5rem;border-top:1px solid rgba(255,255,255,0.06);text-align:center;">
            <a href="/Account/ForgotPassword" style="font-size:.8rem;color:#8fadd8;display:block;margin-bottom:.75rem;">Forgot your password?</a>
            <p style="font-size:.75rem;color:#8fadd8;letter-spacing:.04em;">
                CRL Fruitstand ESS &nbsp;·&nbsp; Authorized Personnel Only
            </p>
        </div>
    </div>
</div>

@section Scripts {
<script>
function togglePassword() {
    const field = document.getElementById('passwordField');
    const icon = document.getElementById('eyeIcon');
    if (field.type === 'password') {
        field.type = 'text';
        icon.innerHTML = `<path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/>`;
    } else {
        field.type = 'password';
        icon.innerHTML = `<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>`;
    }
}
</script>
}





