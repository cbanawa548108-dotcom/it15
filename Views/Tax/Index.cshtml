@{
    ViewData["Title"] = "Tax Projections";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    decimal totalRevenue  = (decimal)ViewBag.TotalRevenue;
    decimal totalExpenses = (decimal)ViewBag.TotalExpenses;
    decimal grossIncome   = (decimal)ViewBag.GrossIncome;
    decimal taxRate       = (decimal)ViewBag.TaxRate;
    decimal estimatedTax  = (decimal)ViewBag.EstimatedTax;
    int     year          = (int)ViewBag.Year;
}
@section Styles {
<style>
.page-content{background:#0f172a!important;min-height:100vh}
.tax-header{background:linear-gradient(135deg,#1e293b,#0f172a);border:1px solid #334155;padding:2.5rem 2rem;border-radius:14px;margin-bottom:2rem;position:relative;overflow:hidden}
.tax-header::before{content:'';position:absolute;top:-60px;right:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(245,158,11,.08) 0%,transparent 70%);border-radius:50%;pointer-events:none}
.tax-header>div{position:relative;z-index:1}
.dark-card{background:#1e293b;border:1px solid #334155;border-radius:14px;padding:1.75rem;margin-bottom:1.5rem}
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:1.25rem;margin-bottom:1.5rem}
.stat-tile{background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;transition:border-color .2s}
.stat-tile:hover{border-color:#475569}
.st-label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:.5rem}
.st-value{font-size:1.6rem;font-weight:800;line-height:1;margin-bottom:.3rem}
.st-sub{font-size:.75rem;color:#475569}
.dark-table{width:100%;border-collapse:collapse;font-size:.9rem}
.dark-table thead tr{background:#0f172a}
.dark-table thead th{padding:1rem;text-align:left;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748b;border-bottom:1px solid #334155}
.dark-table tbody tr{border-bottom:1px solid #1e293b;transition:background .15s}
.dark-table tbody tr:hover{background:#0f172a}
.dark-table tbody td{padding:.875rem 1rem;color:#cbd5e1}
.year-btn{padding:.45rem 1rem;border-radius:8px;font-size:.82rem;font-weight:700;border:1px solid #334155;background:#0f172a;color:#64748b;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.year-btn:hover,.year-btn.active{border-color:#f59e0b;color:#fbbf24;background:#1e293b;box-shadow:0 0 0 1px #f59e0b}
.info-box{background:#0f172a;border:1px solid #334155;border-left:3px solid #f59e0b;border-radius:8px;padding:1rem 1.25rem;margin-bottom:1.5rem}
</style>
}

<div class="tax-header">
    <div>
        <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#f59e0b;display:block;margin-bottom:.5rem;">CFO · TRAIN Law / CREATE Act</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 .5rem;color:#f1f5f9;">Budget Forecasting &amp; Tax Module</h1>
        <p style="margin:0;font-size:.95rem;color:#94a3b8;">Estimated corporate income tax projections based on actual financial data</p>
    </div>
</div>

<!-- Year selector -->
<div style="display:flex;gap:.5rem;margin-bottom:1.5rem;flex-wrap:wrap;">
    @foreach (var y in (List<int>)ViewBag.AvailableYears) {
        <a href="/Tax/Index?year=@y" class="year-btn @(year == y ? "active" : "")">@y</a>
    }
</div>

<div class="info-box">
    <p style="margin:0;color:#94a3b8;font-size:.875rem;">
        <i class="bi bi-info-circle" style="color:#f59e0b;margin-right:.5rem;"></i>
        Tax rates based on Philippine CREATE Act: <strong style="color:#fbbf24;">20%</strong> for net income ≤ ₱5M, <strong style="color:#fbbf24;">25%</strong> above ₱5M. These are estimates only — consult a licensed tax professional for filing.
    </p>
</div>

<div class="stat-row">
    <div class="stat-tile" style="border-top:3px solid #3b82f6">
        <div class="st-label">Gross Revenue</div>
        <div class="st-value" style="color:#60a5fa">₱@totalRevenue.ToString("N0")</div>
        <div class="st-sub">FY @year</div>
    </div>
    <div class="stat-tile" style="border-top:3px solid #ef4444">
        <div class="st-label">Total Expenses</div>
        <div class="st-value" style="color:#fca5a5">₱@totalExpenses.ToString("N0")</div>
        <div class="st-sub">Deductible</div>
    </div>
    <div class="stat-tile" style="border-top:3px solid #10b981">
        <div class="st-label">Taxable Income</div>
        <div class="st-value" style="color:@(grossIncome >= 0 ? "#34d399" : "#fca5a5")">₱@grossIncome.ToString("N0")</div>
        <div class="st-sub">Net of expenses</div>
    </div>
    <div class="stat-tile" style="border-top:3px solid #f59e0b">
        <div class="st-label">Tax Rate</div>
        <div class="st-value" style="color:#fbbf24">@taxRate.ToString("F0")%</div>
        <div class="st-sub">CREATE Act rate</div>
    </div>
    <div class="stat-tile" style="border-top:3px solid #8b5cf6">
        <div class="st-label">Estimated Tax</div>
        <div class="st-value" style="color:#c4b5fd">₱@estimatedTax.ToString("N0")</div>
        <div class="st-sub">Annual projection</div>
    </div>
</div>

<div class="dark-card">
    <p style="font-size:1rem;font-weight:700;color:#f1f5f9;margin:0 0 1.25rem;display:flex;align-items:center;gap:.6rem;">
        <i class="bi bi-calendar3" style="color:#f59e0b;font-size:1.2rem;"></i> Quarterly Tax Breakdown — FY @year
    </p>
    <div style="overflow-x:auto;border-radius:10px;border:1px solid #334155;">
        <table class="dark-table">
            <thead>
                <tr>
                    <th>Quarter</th>
                    <th>Revenue</th>
                    <th>Expenses</th>
                    <th>Gross Income</th>
                    <th>Est. Tax (@taxRate.ToString("F0")%)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (dynamic q in ViewBag.Quarters) {
                    decimal qRev    = (decimal)q.Revenue;
                    decimal qExp    = (decimal)q.Expenses;
                    decimal qIncome = (decimal)q.GrossIncome;
                    decimal qTax    = (decimal)q.EstTax;
                    <tr>
                        <td style="color:#f1f5f9;font-weight:600;">@q.Quarter</td>
                        <td style="color:#60a5fa;">₱@qRev.ToString("N0")</td>
                        <td style="color:#fca5a5;">₱@qExp.ToString("N0")</td>
                        <td style="color:@(qIncome >= 0 ? "#34d399" : "#fca5a5");">₱@qIncome.ToString("N0")</td>
                        <td style="color:#fbbf24;font-weight:700;">₱@qTax.ToString("N0")</td>
                    </tr>
                }
                <tr style="border-top:2px solid #334155;background:#0f172a;">
                    <td style="color:#f1f5f9;font-weight:800;">ANNUAL TOTAL</td>
                    <td style="color:#60a5fa;font-weight:700;">₱@totalRevenue.ToString("N0")</td>
                    <td style="color:#fca5a5;font-weight:700;">₱@totalExpenses.ToString("N0")</td>
                    <td style="color:@(grossIncome >= 0 ? "#34d399" : "#fca5a5");font-weight:700;">₱@grossIncome.ToString("N0")</td>
                    <td style="color:#fbbf24;font-weight:800;font-size:1.05rem;">₱@estimatedTax.ToString("N0")</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
