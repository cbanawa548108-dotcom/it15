@model CRLFruitstandESS.Models.ViewModels.InventoryDashboardViewModel
@using CRLFruitstandESS.Models.ViewModels
@{
    ViewData["Title"] = "Inventory Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="inv-dash">

    <!-- ── Header ──────────────────────────────────── -->
    <div class="inv-header">
        <div class="inv-header-text">
            <span class="inv-eyebrow">
                <span class="inv-eyebrow-dot"></span>
                Inventory Management
            </span>
            <h1 class="inv-title">Stock Overview</h1>
        </div>
        <div class="inv-header-actions">
            <a href="/Inventory/StockIn" class="inv-btn inv-btn-in">
                <span class="inv-btn-icon">
                    <i class="bi bi-box-arrow-in-down"></i>
                </span>
                <span class="inv-btn-label">Stock In</span>
            </a>
            <a href="/Inventory/StockOut" class="inv-btn inv-btn-out">
                <span class="inv-btn-icon">
                    <i class="bi bi-box-arrow-up"></i>
                </span>
                <span class="inv-btn-label">Stock Out</span>
            </a>
        </div>
    </div>

    <!-- ── Alert Banner ─────────────────────────────── -->
    @*
    @{
        var itemsBelowTwenty = (Model.InventoryItems ?? new List<InventoryViewModel>())
            .Where(i => i.CurrentStock <= 20).ToList();
    }
    @if (Model.CriticalStockCount > 0 || Model.OutOfStockCount > 0 || itemsBelowTwenty.Any())
    {
        <div class="inv-alerts">
            @if (Model.OutOfStockCount > 0)
            {
                <div class="inv-alert inv-alert-danger">
                    <div class="inv-alert-icon">
                        <i class="bi bi-exclamation-octagon-fill"></i>
                    </div>
                    <div class="inv-alert-body">
                        <strong>@Model.OutOfStockCount items</strong> are currently out of stock
                    </div>
                    <a href="/Inventory/Index?status=out" class="inv-alert-link">
                        View now <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            }
            @if (itemsBelowTwenty.Any())
            {
                <div class="inv-alert inv-alert-critical">
                    <div class="inv-alert-icon">
                        <i class="bi bi-exclamation-circle-fill"></i>
                    </div>
                    <div class="inv-alert-body">
                        <strong>@itemsBelowTwenty.Count items</strong> have stock ≤ 20 units - CRITICAL LEVEL!
                    </div>
                    <a href="/Inventory/Index" class="inv-alert-link">
                        View now <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            }
            @if (Model.CriticalStockCount > 0 && !itemsBelowTwenty.Any())
            {
                <div class="inv-alert inv-alert-warn">
                    <div class="inv-alert-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <div class="inv-alert-body">
                        <strong>@Model.CriticalStockCount items</strong> are at critical level
                    </div>
                    <a href="/Inventory/Index?status=critical" class="inv-alert-link">
                        View now <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            }
        </div>
    }
    *@

    <!-- ── Stats Grid ───────────────────────────────── -->
    <div class="inv-stats">
        <div class="inv-stat inv-stat-blue">
            <div class="inv-stat-glow"></div>
            <div class="inv-stat-icon-wrap">📦</div>
            <div class="inv-stat-content">
                <div class="inv-stat-val">@Model.TotalProducts</div>
                <div class="inv-stat-lbl">Active Products</div>
            </div>
            <div class="inv-stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="inv-stat inv-stat-green">
            <div class="inv-stat-glow"></div>
            <div class="inv-stat-icon-wrap">📊</div>
            <div class="inv-stat-content">
                <div class="inv-stat-val">@Model.TotalStockItems</div>
                <div class="inv-stat-lbl">Total Units</div>
            </div>
            <div class="inv-stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="inv-stat inv-stat-purple">
            <div class="inv-stat-glow"></div>
            <div class="inv-stat-icon-wrap">💰</div>
            <div class="inv-stat-content">
                <div class="inv-stat-val">₱@Model.TotalInventoryValue.ToString("N0")</div>
                <div class="inv-stat-lbl">Inventory Value</div>
            </div>
            <div class="inv-stat-trend up"><i class="bi bi-arrow-up-right"></i></div>
        </div>
        <div class="inv-stat inv-stat-amber">
            <div class="inv-stat-glow"></div>
            <div class="inv-stat-icon-wrap">⚠️</div>
            <div class="inv-stat-content">
                <div class="inv-stat-val">@Model.LowStockCount</div>
                <div class="inv-stat-lbl">Low Stock Items</div>
            </div>
            <div class="inv-stat-trend down"><i class="bi bi-arrow-down-right"></i></div>
        </div>
    </div>

    <!-- ── Quick Links ──────────────────────────────── -->
    <div class="inv-quicklinks">
        <a href="/Inventory/Index" class="inv-qlink">
            <div class="inv-qlink-ico"><i class="bi bi-list-check"></i></div>
            <span>All Inventory</span>
            <i class="bi bi-chevron-right inv-qlink-arrow"></i>
        </a>
        <a href="/Inventory/Movements" class="inv-qlink">
            <div class="inv-qlink-ico"><i class="bi bi-arrow-left-right"></i></div>
            <span>Stock Movements</span>
            <i class="bi bi-chevron-right inv-qlink-arrow"></i>
        </a>
        <a href="/Inventory/Stocks" class="inv-qlink">
            <div class="inv-qlink-ico"><i class="bi bi-truck"></i></div>
            <span>Stocks</span>
            <i class="bi bi-chevron-right inv-qlink-arrow"></i>
        </a>
        <a href="/Inventory/Suppliers" class="inv-qlink">
            <div class="inv-qlink-ico"><i class="bi bi-people"></i></div>
            <span>Suppliers</span>
            <i class="bi bi-chevron-right inv-qlink-arrow"></i>
        </a>
        <a href="/Inventory/Valuation" class="inv-qlink">
            <div class="inv-qlink-ico"><i class="bi bi-pie-chart-fill"></i></div>
            <span>Valuation Report</span>
            <i class="bi bi-chevron-right inv-qlink-arrow"></i>
        </a>
    </div>

    <!-- ── Low Stock Table ──────────────────────────── -->
    <div class="inv-section">
        <div class="inv-section-head">
            <div class="inv-section-title">
                <span class="inv-pulse-dot"></span>
                <h3>Low Stock Alerts</h3>
            </div>
            <a href="/Inventory/Index?status=low" class="inv-btn-ghost">
                View all <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        @if (Model.LowStockAlerts?.Any() == true)
        {
            <div class="inv-table-wrap">
                <table class="inv-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Category</th>
                            <th class="tc">Current Stock</th>
                            <th class="tc">Min Level</th>
                            <th class="tc">Status</th>
                            <th class="tc">Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.LowStockAlerts.Take(5))
                        {
                            <tr class="inv-row @(item.CurrentStock == 0 ? "out-of-stock-row" : "")">
                                <td>
                                    <div class="inv-product-name">
                                        <span class="inv-emoji">@item.Emoji</span>
                                        <span>@item.ProductName</span>
                                    </div>
                                </td>
                                <td><span class="inv-category-pill">@item.Category</span></td>
                                <td class="tc">
                                    <span class="inv-stock-val @(item.CurrentStock == 0 ? "out-of-stock" : item.CurrentStock <= 20 ? "critical" : "warn")">
                                        @item.CurrentStock
                                    </span>
                                </td>
                                <td class="tc"><span class="inv-min-val">@item.MinStockLevel</span></td>
                                <td class="tc">
                                    @if (item.CurrentStock == 0)
                                    {
                                        <span class="inv-badge inv-badge-out-of-stock">
                                            <i class="bi bi-exclamation-diamond-fill"></i> OUT OF STOCK
                                        </span>
                                    }
                                    else if (item.StockStatus == "Critical Stock")
                                    {
                                        <span class="inv-badge inv-badge-danger">
                                            <i class="bi bi-exclamation-circle-fill"></i> @item.StockStatus
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inv-badge inv-badge-warn">
                                            <i class="bi bi-exclamation-triangle-fill"></i> @item.StockStatus
                                        </span>
                                    }
                                <td class="tc">
                                    @{
                                        var productsWithPending = ViewBag.ProductsWithPendingDeliveries as System.Collections.Generic.List<int> ?? new System.Collections.Generic.List<int>();
                                        bool hasPendingDelivery = productsWithPending.Contains(item.ProductId);
                                    }
                                    @if (hasPendingDelivery)
                                    {
                                        <a href="/Inventory/StockIn?productId=@item.ProductId" class="inv-restock-btn @(item.CurrentStock == 0 ? "urgent" : "")">
                                            <i class="bi bi-plus-lg"></i> @(item.CurrentStock == 0 ? "URGENT: Restock Now" : "Restock")
                                        </a>
                                    }
                                    else
                                    {
                                        <button type="button" 
                                                class="inv-restock-btn" 
                                                disabled 
                                                title="No pending deliveries from suppliers"
                                                style="opacity: 0.5; cursor: not-allowed; background: rgba(100, 116, 139, 0.15); border-color: rgba(100, 116, 139, 0.3);">
                                            <i class="bi bi-plus-lg"></i> Restock
                                        </button>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="inv-empty-state">
                <div class="inv-empty-icon">
                    <i class="bi bi-check-circle-fill"></i>
                </div>
                <h3 class="inv-empty-title">Everything is in stock!</h3>
                <p class="inv-empty-sub">All your products are at healthy stock levels. Great job maintaining inventory!</p>
                <a href="/Inventory/Index" class="inv-empty-btn">
                    <i class="bi bi-list-check"></i> View Inventory
                </a>
            </div>
        }
    </div>

    <!-- ── Top Products by Value ──────────────────────── -->
    <div class="inv-section">
        <div class="inv-section-head">
            <div class="inv-section-title">
                <span class="inv-section-dot"></span>
                <h3>Top Products by Inventory Value</h3>
            </div>
            <a href="/Inventory/Index" class="inv-btn-ghost">
                View all <i class="bi bi-arrow-right"></i>
            </a>
        </div>

        <div class="inv-grid-products">
            @foreach (var item in (Model.InventoryItems ?? new List<InventoryViewModel>()).OrderByDescending(x => x.InventoryValue).Take(4))
            {
                <div class="inv-product-card">
                    <div class="inv-card-top">
                        <div class="inv-card-emoji-wrap">
                            <span class="inv-card-emoji">@item.Emoji</span>
                        </div>
                        <div class="inv-card-info">
                            <div class="inv-card-name">@item.ProductName</div>
                            <span class="inv-card-cat-pill">@item.Category</span>
                        </div>
                    </div>
                    <div class="inv-card-sep"></div>
                    <div class="inv-card-metrics">
                        <div class="inv-metric-row">
                            <span class="inv-metric-lbl"><i class="bi bi-currency-exchange"></i> Total Value</span>
                            <span class="inv-metric-val inv-metric-highlight">₱@item.InventoryValue.ToString("N0")</span>
                        </div>
                        <div class="inv-metric-row">
                            <span class="inv-metric-lbl"><i class="bi bi-layers"></i> Units in Stock</span>
                            <span class="inv-metric-val">@item.CurrentStock</span>
                        </div>
                        <div class="inv-metric-row">
                            <span class="inv-metric-lbl"><i class="bi bi-tag"></i> Unit Price</span>
                            <span class="inv-metric-val">₱@item.UnitPrice.ToString("N2")</span>
                        </div>
                    </div>
                    @{
                        var productsWithPendingCard = ViewBag.ProductsWithPendingDeliveries as System.Collections.Generic.List<int> ?? new System.Collections.Generic.List<int>();
                        bool hasPendingDeliveryCard = productsWithPendingCard.Contains(item.ProductId);
                    }
                    @if (hasPendingDeliveryCard)
                    {
                        <a href="/Inventory/StockIn?productId=@item.ProductId" class="inv-card-action-btn">
                            <i class="bi bi-plus-lg"></i> Add Stock
                        </a>
                    }
                    else
                    {
                        <button type="button" 
                                class="inv-card-action-btn" 
                                disabled 
                                title="No pending deliveries from suppliers"
                                style="opacity: 0.5; cursor: not-allowed; background: rgba(100, 116, 139, 0.08); border-color: rgba(100, 116, 139, 0.2);">
                            <i class="bi bi-plus-lg"></i> Add Stock
                        </button>
                    }
                </div>
            }
        </div>
    </div>

</div>

@section Styles {
<style>
@@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

/* ─── Base ─────────────────────────────────────── */
.inv-dash {
    padding: 2rem 2.25rem;
    font-family: 'DM Sans', sans-serif;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
}

/* ─── Header ───────────────────────────────────── */
.inv-header {
    display: flex; align-items: flex-end;
    justify-content: space-between; flex-wrap: wrap; gap: 1rem;
}
.inv-eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.12em;
    text-transform: uppercase; color: #64b5f6; margin-bottom: 0.35rem;
}
.inv-eyebrow-dot {
    width: 6px; height: 6px; border-radius: 50%;
    background: #42a5f5; box-shadow: 0 0 8px #42a5f5;
    animation: eyebrow-pulse 2s ease-in-out infinite;
}
@@keyframes eyebrow-pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
.inv-title {
    font-family: 'Syne', sans-serif; font-size: 1.9rem;
    font-weight: 800; color: #f0f4ff; margin: 0; line-height: 1;
}
.inv-header-actions { display: flex; gap: 10px; }

/* ─── Action Buttons ────────────────────────────── */
.inv-btn {
    display: inline-flex; align-items: center; gap: 0;
    border: none; border-radius: 12px;
    font-family: 'DM Sans', sans-serif; font-size: 0.875rem; font-weight: 600;
    text-decoration: none; cursor: pointer; overflow: hidden;
    transition: transform .2s ease, box-shadow .2s ease;
}
.inv-btn:hover { transform: translateY(-2px); }
.inv-btn-icon {
    display: flex; align-items: center; justify-content: center;
    width: 42px; height: 42px; font-size: 1rem; flex-shrink: 0;
    transition: background .2s;
}
.inv-btn-label { padding: 0 16px 0 12px; white-space: nowrap; letter-spacing: .01em; }

.inv-btn-in  { background:#1b5e20; color:#a5d6a7; box-shadow:0 4px 16px rgba(27,94,32,.45); }
.inv-btn-in  .inv-btn-icon { background:#2e7d32; color:#c8e6c9; }
.inv-btn-in:hover  { background:#2e7d32; color:#c8e6c9; box-shadow:0 6px 22px rgba(46,125,50,.55); }
.inv-btn-in:hover  .inv-btn-icon { background:#388e3c; }
.inv-btn-out { background:#e65100; color:#ffccbc; box-shadow:0 4px 16px rgba(230,81,0,.4); }
.inv-btn-out .inv-btn-icon { background:#bf360c; color:#ffab91; }
.inv-btn-out:hover { background:#bf360c; color:#ffccbc; box-shadow:0 6px 22px rgba(191,54,12,.55); }
.inv-btn-out:hover .inv-btn-icon { background:#d84315; }

/* ─── Alerts ─────────────────────────────────────*/
.inv-alerts { display: flex; flex-direction: column; gap: 10px; }
.inv-alert {
    display: flex; align-items: center; gap: 14px;
    padding: 14px 18px; border-radius: 14px;
    font-size: 0.875rem; font-weight: 500;
    backdrop-filter: blur(6px); transition: transform .2s;
}
.inv-alert:hover { transform: translateX(4px); }
.inv-alert-danger { background:rgba(183,28,28,.18); border:1px solid rgba(229,57,53,.4); color:#ef9a9a; }
.inv-alert-danger .inv-alert-icon { color:#ef5350; font-size:1.2rem; }
.inv-alert-critical { background:rgba(191,54,12,.22); border:1px solid rgba(229,57,53,.5); color:#ff7043; animation: alert-pulse 1.5s ease-in-out infinite; }
.inv-alert-critical .inv-alert-icon { color:#ff5722; font-size:1.3rem; animation: icon-pulse 1.5s ease-in-out infinite; }
@@keyframes alert-pulse { 0%,100%{opacity:1} 50%{opacity:.85} }
@@keyframes icon-pulse { 0%,100%{transform:scale(1)} 50%{transform:scale(1.08)} }
.inv-alert-warn   { background:rgba(230,81,0,.14);  border:1px solid rgba(255,152,0,.4);  color:#ffcc80; }
.inv-alert-warn   .inv-alert-icon { color:#ffa726; font-size:1.2rem; }
.inv-alert-body { flex:1; }
.inv-alert-body strong { font-weight:700; }
.inv-alert-link {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 6px 14px; border-radius: 8px;
    font-weight: 600; font-size: 0.8rem; text-decoration: none;
    white-space: nowrap; background: rgba(255,255,255,.08);
    color: inherit; border: 1px solid rgba(255,255,255,.15);
    transition: background .15s, transform .15s;
}
.inv-alert-link:hover { background:rgba(255,255,255,.14); transform:translateX(2px); color:inherit; }

/* ─── Stats ──────────────────────────────────────*/
.inv-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 14px;
}
.inv-stat {
    position: relative; display: flex; align-items: center; gap: 14px;
    padding: 20px 18px; border-radius: 16px; overflow: visible;
    transition: transform .22s ease, box-shadow .22s ease;
}
.inv-stat:hover { transform: translateY(-3px); }
.inv-stat-glow {
    position: absolute; top: -20px; right: -20px;
    width: 100px; height: 100px; border-radius: 50%;
    opacity: .18; filter: blur(28px); pointer-events: none;
    overflow: hidden;
}
.inv-stat-blue   { background:linear-gradient(135deg,#0d2137,#0a3256); border:1px solid rgba(66,165,245,.3); box-shadow:0 4px 24px rgba(13,71,161,.35), inset 0 1px 0 rgba(66,165,245,.15); }
.inv-stat-blue   .inv-stat-glow        { background:#42a5f5; }
.inv-stat-blue   .inv-stat-icon-wrap   { background:linear-gradient(135deg,rgba(66,165,245,.3),rgba(66,165,245,.15)); color:#64b5f6; border:1px solid rgba(66,165,245,.25); }
.inv-stat-blue   .inv-stat-val         { color:#90caf9; text-shadow:0 0 20px rgba(66,165,245,.4); }
.inv-stat-blue   .inv-stat-lbl         { color:#4fc3f7; }
.inv-stat-green  { background:linear-gradient(135deg,#0a2119,#0d3326); border:1px solid rgba(102,187,106,.3); box-shadow:0 4px 24px rgba(27,94,32,.35), inset 0 1px 0 rgba(102,187,106,.15); }
.inv-stat-green  .inv-stat-glow        { background:#66bb6a; }
.inv-stat-green  .inv-stat-icon-wrap   { background:linear-gradient(135deg,rgba(102,187,106,.3),rgba(102,187,106,.15)); color:#81c784; border:1px solid rgba(102,187,106,.25); }
.inv-stat-green  .inv-stat-val         { color:#a5d6a7; text-shadow:0 0 20px rgba(102,187,106,.4); }
.inv-stat-green  .inv-stat-lbl         { color:#80cbc4; }
.inv-stat-purple { background:linear-gradient(135deg,#1a0a2e,#2a1052); border:1px solid rgba(171,71,188,.3); box-shadow:0 4px 24px rgba(74,20,140,.35), inset 0 1px 0 rgba(171,71,188,.15); }
.inv-stat-purple .inv-stat-glow        { background:#ab47bc; }
.inv-stat-purple .inv-stat-icon-wrap   { background:linear-gradient(135deg,rgba(171,71,188,.3),rgba(171,71,188,.15)); color:#ce93d8; border:1px solid rgba(171,71,188,.25); }
.inv-stat-purple .inv-stat-val         { color:#e1bee7; text-shadow:0 0 20px rgba(171,71,188,.4); }
.inv-stat-purple .inv-stat-lbl         { color:#b39ddb; }
.inv-stat-amber  { background:linear-gradient(135deg,#2c1a00,#3e2400); border:1px solid rgba(255,167,38,.3); box-shadow:0 4px 24px rgba(230,81,0,.35), inset 0 1px 0 rgba(255,167,38,.15); }
.inv-stat-amber  .inv-stat-glow        { background:#ffa726; }
.inv-stat-amber  .inv-stat-icon-wrap   { background:linear-gradient(135deg,rgba(255,167,38,.3),rgba(255,167,38,.15)); color:#ffb74d; border:1px solid rgba(255,167,38,.25); }
.inv-stat-amber  .inv-stat-val         { color:#ffcc80; text-shadow:0 0 20px rgba(255,167,38,.4); }
.inv-stat-amber  .inv-stat-lbl         { color:#ffab40; }
.inv-stat-icon-wrap {
    width:56px; height:56px; border-radius:16px;
    display:flex; align-items:center; justify-content:center;
    font-size:1.9rem; flex-shrink:0;
    position:relative; z-index:1;
    backdrop-filter:blur(8px);
}
.inv-stat-content { flex:1; }
.inv-stat-val { font-family:'Syne',sans-serif; font-size:1.75rem; font-weight:900; line-height:1.1; letter-spacing:-.02em; }
.inv-stat-lbl { font-size:.72rem; font-weight:700; letter-spacing:.08em; text-transform:uppercase; margin-top:4px; opacity:.75; }
.inv-stat-trend { font-size:.8rem; font-weight:700; padding:4px 8px; border-radius:8px; align-self:flex-start; }
.inv-stat-trend.up   { background:rgba(102,187,106,.15); color:#81c784; }
.inv-stat-trend.down { background:rgba(239,83,80,.15);   color:#ef9a9a; }

/* ─── Stickers ─────────────────────────────────*/
.inv-stat-sticker {
    position: absolute;
    top: 8px;
    right: 10px;
    width: 44px;
    height: 44px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    background: rgba(255,255,255,.12);
    box-shadow: 0 4px 12px rgba(0,0,0,.2);
    border: 1px solid rgba(255,255,255,.15);
    animation: sticker-float 3s ease-in-out infinite;
    z-index: 2;
    backdrop-filter: blur(4px);
}
@@keyframes sticker-float {
    0%, 100% { transform: translateY(0px) rotate(-8deg); }
    50% { transform: translateY(-6px) rotate(-8deg); }
}

.inv-stat:hover .inv-stat-sticker {
    animation: sticker-bounce .6s ease-out;
}
@@keyframes sticker-bounce {
    0% { transform: translateY(0) rotate(-8deg) scale(.9); }
    50% { transform: translateY(-12px) rotate(-8deg) scale(1.05); }
    100% { transform: translateY(-6px) rotate(-8deg) scale(1); }
}

/* ─── Quick Links ────────────────────────────────*/
.inv-quicklinks {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 12px;
}
.inv-qlink {
    display: flex; align-items: center; gap: 12px;
    padding: 16px 18px;
