// ── STOCK DEMAND PREDICTOR
fetch('/Analytics/StockDemand').then(r=>r.json()).then(rows=>{
    const sc={critical:'#fca5a5',warning:'#fcd34d',ok:'#34d399'};
    const sb={critical:'rgba(239,68,68,.15)',warning:'rgba(245,158,11,.15)',ok:'rgba(16,185,129,.15)'};
    const sd={critical:'rgba(239,68,68,.3)',warning:'rgba(245,158,11,.3)',ok:'rgba(16,185,129,.3)'};
    document.getElementById('demandBody').innerHTML=rows.map(r=>`
        <tr style="border-bottom:1px solid rgba(255,255,255,.03);">
