@model IEnumerable<CRLFruitstandESS.Models.ViewModels.SupplierPaymentViewModel>
@{
    ViewData["Title"] = "Supplier Payments";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="payments-page">
    <div class="page-header">
        <div class="header-left">
            <span class="breadcrumb">Finance</span>
            <h1>Payment History</h1>
        </div>
        <a href="/Inventory/PaySupplier" class="btn-add">
            <i class="bi bi-cash-stack"></i> New Payment
        </a>
    </div>

    <div class="table-card">
        <div class="table-header">
            <h3>Recent Payments</h3>
        </div>
        
        <div class="table-container">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Supplier</th>
                        <th>Amount</th>
                        <th>Method</th>
                        <th>Reference</th>
                        <th>Paid By</th>
                        <th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payment in Model)
                    {
                        <tr>
                            <td>@payment.PaymentDate.ToString("MMM dd, yyyy HH:mm")</td>
                            <td><strong>@payment.SupplierName</strong></td>
                            <td class="amount">₱@payment.Amount.ToString("N2")</td>
                            <td>@payment.PaymentMethod</td>
                            <td>@payment.ReferenceNumber</td>
                            <td>@payment.PaidBy</td>
                            <td>@payment.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Styles {
<style>
    .payments-page { padding: 2rem; max-width: 1400px; margin: 0 auto; }
    .page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem; }
    .header-left .breadcrumb { color: #64b5f6; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.5rem; }
    .header-left h1 { color: #fff; font-size: 1.75rem; font-weight: 700; margin: 0; }
    .btn-add { display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1.5rem; background: linear-gradient(135deg, #22c55e, #16a34a); color: #fff; border-radius: 10px; text-decoration: none; font-weight: 600; }
    .table-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 16px; overflow: hidden; }
    .table-header { padding: 1.25rem 1.5rem; border-bottom: 1px solid rgba(255,255,255,0.08); }
    .table-header h3 { color: #fff; font-size: 1.1rem; font-weight: 600; margin: 0; }
    .table-container { overflow-x: auto; }
    .data-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .data-table th { text-align: left; padding: 1rem 1.5rem; color: #94a3b8; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; background: rgba(255,255,255,0.02); border-bottom: 1px solid rgba(255,255,255,0.08); }
    .data-table td { padding: 1rem 1.5rem; color: #cbd5e1; border-bottom: 1px solid rgba(255,255,255,0.04); }
    .data-table tr:hover td { background: rgba(255,255,255,0.02); }
    .amount { color: #22c55e; font-weight: 700; }
</style>
}