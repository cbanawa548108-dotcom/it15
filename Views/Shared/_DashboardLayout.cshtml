<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRL Fruitstand ESS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <!-- ADD THIS LINE -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body">

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">CRL</div>
            <div class="brand-text">
                <span class="brand-name">Fruitstand</span>
                <span class="brand-sub">ESS Platform</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <a href="/Account/RedirectToDashboard" class="sidebar-link active">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                </svg>
                Dashboard
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Administration</div>
                <a href="/Admin/Users" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                    </svg>
                    User Management
                </a>
                <a href="/Admin/Roles" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    Roles &amp; Permissions
                </a>
                <a href="/Admin/Products" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10"/>
                    </svg>
                    Products
                </a>
                <a href="/Admin/Suppliers" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                    </svg>
                    Suppliers
                </a>
                <a href="/Admin/InventoryManagement" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <rect x="2" y="7" width="20" height="14" rx="2"/>
                        <path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/>
                    </svg>
                    Inventory
                </a>
            }

            @if (User.IsInRole("CFO") || User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Finance</div>
                <a href="/CfoDashboard/Index" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <line x1="12" y1="1" x2="12" y2="23"/>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                    Dashboard
                </a>
                <a href="/CfoDashboard/Revenue" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                    Revenue
                </a>
                <a href="/CfoDashboard/Expenses" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8zm3.5-9c.83 0 1.5-.67 1.5-1.5S16.33 8 15.5 8 14 8.67 14 9.5s.67 1.5 1.5 1.5zm-7 0c.83 0 1.5-.67 1.5-1.5S9.33 8 8.5 8 7 8.67 7 9.5 7.67 11 8.5 11zm3.5 6.5c2.33 0 4.31-1.46 5.11-3.5H6.89c.8 2.04 2.78 3.5 5.11 3.5z"/>
                    </svg>
                    Expenses
                </a>
                <a href="/CfoDashboard/Budget" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
                    </svg>
                    Budget
                </a>
                <a href="/CfoDashboard/Reports" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z"/>
                    </svg>
                    Reports
                </a>
            }

            @if (User.IsInRole("CFO") || User.IsInRole("CEO") || User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Executive</div>
                <a href="/ExecutiveDashboard/Index" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 12h18M3 6h18M3 18h18M5 12v6m4-6v6m4-6v6m4-6v6"/>
                    </svg>
                    Executive Dashboard
                </a>
                <a href="/ExecutiveDashboard/KPIDashboard" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 17"/>
                        <polyline points="17 6 23 6 23 12"/>
                    </svg>
                    KPI Dashboard
                </a>
                <a href="/ExecutiveDashboard/Forecasting" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M21 21H3V3h7V1H3a2 2 0 0 0-2 2v18a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2v-7h-2v7z"/>
                        <path d="M16 4l4 4m0-4v4h-4"/>
                    </svg>
                    Sales Forecasting
                </a>
                <a href="/ExecutiveDashboard/ScenarioSimulation" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <circle cx="12" cy="12" r="1"/>
                        <path d="M12 1v6m0 6v6M4.22 4.22l4.24 4.24m5.08 5.08l4.24 4.24M1 12h6m6 0h6M4.22 19.78l4.24-4.24m5.08-5.08l4.24-4.24"/>
                    </svg>
                    Scenarios
                </a>
                <a href="/Reporting/Index" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                        <polyline points="14 2 14 8 20 8"/>
                        <line x1="16" y1="13" x2="8" y2="13"/>
                        <line x1="16" y1="17" x2="8" y2="17"/>
                        <polyline points="10 9 9 9 8 9"/>
                    </svg>
                    Reports
                </a>
                <a href="/Analytics/Index" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                    Analytics
                </a>
                <a href="/AuditLog/Index" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 8v4l3 3m6-3a9 9 0 1 1-18 0 9 9 0 0 1 18 0z"/>
                    </svg>
                    Audit Log
                </a>
                <a href="/Compliance/Index" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    Compliance
                </a>
                <a href="/TrendReport/Index" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 17"/>
                        <polyline points="17 6 23 6 23 12"/>
                    </svg>
                    Trend Reports
                </a>
                @if (User.IsInRole("CFO") || User.IsInRole("Admin"))
                {
                    <a href="/PettyCash/Review" class="sidebar-link">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <rect x="2" y="5" width="20" height="14" rx="2"/>
                            <line x1="2" y1="10" x2="22" y2="10"/>
                        </svg>
                        Petty Cash
                    </a>
                    <a href="/Tax/Index" class="sidebar-link">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                        </svg>
                        Tax Projections
                    </a>
                    <a href="/ExecutiveDashboard/CompareScenarios" class="sidebar-link">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <line x1="8" y1="6" x2="21" y2="6"/><line x1="8" y1="12" x2="21" y2="12"/>
                            <line x1="8" y1="18" x2="21" y2="18"/><line x1="3" y1="6" x2="3.01" y2="6"/>
                            <line x1="3" y1="12" x2="3.01" y2="12"/><line x1="3" y1="18" x2="3.01" y2="18"/>
                        </svg>
                        Compare Scenarios
                    </a>
                }
                @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
                {
                    <a href="/Warehouse/Index" class="sidebar-link">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                             viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                            <polyline points="9 22 9 12 15 12 15 22"/>
                        </svg>
                        Warehouse
                    </a>
                }
                <a href="/ExecutiveDashboard/RiskAnalysis" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z"/>
                        <path d="M12 12.5l-2 3 2 3 2-3-2-3z"/>
                    </svg>
                    Risk Analysis
                </a>
            }

            @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Operations</div>
                <a href="/Inventory/Dashboard" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                    Inventory
                </a>
                <a href="/Inventory/Suppliers" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>
                    </svg>
                    Suppliers
                </a>
                <a href="/Inventory/SupplierBalances" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M21 21H3V3h7V1H3a2 2 0 0 0-2 2v18a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2v-7h-2v7z"/><rect x="14" y="4" width="8" height="8"/>
                    </svg>
                    Supplier Balances
                </a>
                <a href="/Inventory/SupplierPayments" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M19 14c1.49-1.46 2.5-3.5 2.5-5.5 0-4.41-3.59-8-8-8s-8 3.59-8 8 3.59 8 8 8c2 0 4.04-1.01 5.5-2.5"/><path d="M12 14v6m3-3H9"/>
                    </svg>
                    Payment History
                </a>
                <a href="/Inventory/PaySupplier" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
                    </svg>
                    Pay Supplier
                </a>
                <a href="/ManagerDashboard/SalesReport" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <polyline points="23 6 13.5 15.5 8.5 10.5 1 17"/>
                        <polyline points="17 6 23 6 23 12"/>
                    </svg>
                    Sales Report
                </a>
            }

            @if (User.IsInRole("Cashier") || User.IsInRole("Admin"))
            {
                <div class="nav-section-label">POS</div>
                <a href="/Cashier/POS" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                        <path d="M8 21h8M12 17v4"/>
                    </svg>
                    POS Terminal
                </a>
                <a href="/PettyCash/Submit" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                    Expense Claim
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                <div class="user-details">
                    <div class="user-name">@User.Identity?.Name</div>
                    <div class="user-role">
                        @(User.IsInRole("Admin") ? "Administrator" :
                          User.IsInRole("CFO") ? "CFO" :
                          User.IsInRole("Manager") ? "Manager" : "Cashier")
                    </div>
                </div>
            </div>
            <form asp-action="Logout" asp-controller="Account" method="post" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn" title="Sign Out">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </button>
            </form>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <div class="topbar-right">
                <div class="topbar-date">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
            </div>
        </header>

        <div class="page-content">
            @if (TempData["Error"] != null)
            {
                <div style="position:fixed;top:1rem;right:1rem;z-index:9999;max-width:400px;padding:1rem 1.5rem;background:#1e293b;border:1px solid #ef4444;border-left:4px solid #ef4444;border-radius:10px;box-shadow:0 8px 32px rgba(0,0,0,.5);animation:slideIn .3s ease;">
                    <div style="display:flex;align-items:start;gap:1rem;">
                        <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;font-size:1.25rem;flex-shrink:0;"></i>
                        <div style="flex:1;">
                            <strong style="color:#fca5a5;display:block;margin-bottom:.25rem;font-size:.9rem;">Error</strong>
                            <p style="margin:0;color:#94a3b8;font-size:.85rem;line-height:1.5;">@TempData["Error"]</p>
                        </div>
                    </div>
                </div>
                <style>@@keyframes slideIn { from { opacity:0; transform:translateX(100px); } to { opacity:1; transform:translateX(0); } }</style>
            }
            @RenderBody()
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>