@{
    ViewData["Title"] = "Valuation Report";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="valuation-container">
    <!-- Header -->
    <div class="valuation-header">
        <div class="header-content">
            <span class="header-eyebrow">
                <span class="eyebrow-pulse"></span>
                Financial Analysis
            </span>
            <h1 class="header-title">Inventory Valuation</h1>
            <p class="header-subtitle">Real-time financial overview of your stock portfolio</p>
        </div>
        <div class="header-actions">
            <button class="btn-export" onclick="window.print()">
                <i class="bi bi-printer"></i>
                <span>Print Report</span>
            </button>
            <a href="/Inventory/Index" class="btn-back">
                <i class="bi bi-arrow-left"></i>
                <span>Back</span>
            </a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="metrics-grid">
        <div class="metric-card metric-primary">
            <div class="metric-glow"></div>
            <div class="metric-sticker sticker-primary">💰</div>
            <div class="metric-icon">
                <i class="bi bi-currency-exchange"></i>
            </div>
            <div class="metric-content">
                <span class="metric-label">Total Inventory Value</span>
                <span class="metric-value">₱@ViewBag.TotalValue.ToString("N2")</span>
                <span class="metric-trend">
                    <i class="bi bi-graph-up-arrow"></i> Current valuation
                </span>
            </div>
        </div>

        <div class="metric-card metric-secondary">
            <div class="metric-glow"></div>
            <div class="metric-sticker sticker-secondary">📦</div>
            <div class="metric-icon">
                <i class="bi bi-boxes"></i>
            </div>
            <div class="metric-content">
                <span class="metric-label">Total Units</span>
                <span class="metric-value">@ViewBag.TotalItems.ToString("N0")</span>
                <span class="metric-trend">
                    <i class="bi bi-layers"></i> Across all categories
                </span>
            </div>
        </div>

        <div class="metric-card metric-tertiary">
            <div class="metric-glow"></div>
            <div class="metric-sticker sticker-tertiary">🏷️</div>
            <div class="metric-icon">
                <i class="bi bi-grid-3x3"></i>
            </div>
            <div class="metric-content">
                <span class="metric-label">Categories</span>
                <span class="metric-value">@ViewBag.ByCategory.Count</span>
                <span class="metric-trend">
                    <i class="bi bi-tags"></i> Product segments
                </span>
            </div>
        </div>

        <div class="metric-card metric-quaternary">
            <div class="metric-glow"></div>
            <div class="metric-sticker sticker-quaternary">📊</div>
            <div class="metric-icon">
                <i class="bi bi-calculator"></i>
            </div>
            <div class="metric-content">
                <span class="metric-label">Average Cost</span>
                <span class="metric-value">₱@(ViewBag.TotalItems > 0 ? (ViewBag.TotalValue / ViewBag.TotalItems).ToString("N2") : "0.00")</span>
                <span class="metric-trend">
                    <i class="bi bi-clipboard-data"></i> Per unit average
                </span>
            </div>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="content-grid">
        <!-- Category Breakdown -->
        <div class="content-panel panel-large">
            <div class="panel-header">
                <div class="panel-icon">
                    <i class="bi bi-pie-chart-fill"></i>
                </div>
                <div class="panel-title">
                    <h3>Category Breakdown</h3>
                    <p>Valuation distribution by product category</p>
                </div>
            </div>
            
            <div class="panel-body">
                <div class="category-list">
                    @foreach (var category in ViewBag.ByCategory)
                    {
                        var percentage = ViewBag.TotalValue > 0 ? (category.TotalValue / ViewBag.TotalValue) * 100 : 0;
                        <div class="category-item">
                            <div class="category-info">
                                <span class="category-badge">@category.Category</span>
                                <span class="category-items">@category.TotalItems.ToString("N0") items</span>
                            </div>
                            <div class="category-bar">
                                <div class="category-progress">
                                    <div class="category-fill" style="width: @percentage%"></div>
                                </div>
                                <span class="category-percent">@percentage.ToString("F1")%</span>
                            </div>
                            <div class="category-values">
                                <span class="category-total">₱@category.TotalValue.ToString("N2")</span>
                                <span class="category-avg">avg ₱@category.AvgCost.ToString("N2")</span>
                            </div>
                        </div>
                    }
                </div>

                <!-- Total Summary -->
                <div class="category-total-row">
                    <div class="total-info">
                        <span class="total-label">Total Inventory Value</span>
                    </div>
                    <div class="total-value">
                        <span>₱@ViewBag.TotalValue.ToString("N2")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Insights Panel -->
        <div class="content-panel panel-small">
            <div class="panel-header">
                <div class="panel-icon icon-insight">
                    <i class="bi bi-lightbulb-fill"></i>
                </div>
                <div class="panel-title">
                    <h3>Key Insights</h3>
                    <p>Quick analysis</p>
                </div>
            </div>
            
            <div class="panel-body">
                <div class="insight-list">
                    @{
                        var topCategory = ViewBag.ByCategory.Count > 0 ? ViewBag.ByCategory[0] : null;
                        var totalItems = ViewBag.TotalItems;
                        var avgValue = totalItems > 0 ? ViewBag.TotalValue / totalItems : 0;
                    }
                    
                    @if (topCategory != null)
                    {
                        <div class="insight-item">
                            <div class="insight-sticker">🏆</div>
                            <div class="insight-icon insight-primary">
                                <i class="bi bi-trophy-fill"></i>
                            </div>
                            <div class="insight-content">
                                <span class="insight-label">Top Category</span>
                                <span class="insight-value">@topCategory.Category</span>
                                <span class="insight-detail">₱@topCategory.TotalValue.ToString("N2")</span>
                            </div>
                        </div>
                    }

                    <div class="insight-item">
                        <div class="insight-sticker">📈</div>
                        <div class="insight-icon insight-secondary">
                            <i class="bi bi-graph-up"></i>
                        </div>
                        <div class="insight-content">
                            <span class="insight-label">Average Unit Value</span>
                            <span class="insight-value">₱@avgValue.ToString("N2")</span>
                            <span class="insight-detail">Per item average</span>
                        </div>
                    </div>

                    <div class="insight-item">
                        <div class="insight-sticker">🗂️</div>
                        <div class="insight-icon insight-tertiary">
                            <i class="bi bi-collection-fill"></i>
                        </div>
                        <div class="insight-content">
                            <span class="insight-label">Total Categories</span>
                            <span class="insight-value">@ViewBag.ByCategory.Count</span>
                            <span class="insight-detail">Product segments</span>
                        </div>
                    </div>

                    <div class="insight-item">
                        <div class="insight-sticker">💎</div>
                        <div class="insight-icon insight-quaternary">
                            <i class="bi bi-cash-stack"></i>
                        </div>
                        <div class="insight-content">
                            <span class="insight-label">Inventory Investment</span>
                            <span class="insight-value">₱@ViewBag.TotalValue.ToString("N0")</span>
                            <span class="insight-detail">Current stock value</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Visual Chart Representation -->
    <div class="chart-section">
        <div class="chart-header">
            <h3>Value Distribution</h3>
            <p>Visual breakdown of inventory value by category</p>
        </div>
        <div class="chart-visual">
            @foreach (var category in ViewBag.ByCategory)
            {
                var percentage = ViewBag.TotalValue > 0 ? (category.TotalValue / ViewBag.TotalValue) * 100 : 0;
                <div class="chart-segment" style="width: @percentage%" title="@category.Category: ₱@category.TotalValue.ToString("N2") (@percentage.ToString("F1")%)">
                    <span class="segment-label">@category.Category</span>
                </div>
            }
        </div>
        <div class="chart-legend">
            @foreach (var category in ViewBag.ByCategory)
            {
                var percentage = ViewBag.TotalValue > 0 ? (category.TotalValue / ViewBag.TotalValue) * 100 : 0;
                <div class="legend-item">
                    <span class="legend-dot"></span>
                    <span class="legend-name">@category.Category</span>
                    <span class="legend-value">@percentage.ToString("F1")%</span>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
<style>
@@import url('https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap');

/* ─── Container ───────────────────────────────── */
.valuation-container {
    padding: 2rem 2.5rem;
    font-family: 'DM Sans', sans-serif;
    max-width: 1400px;
    margin: 0 auto;
}

/* ─── Header ──────────────────────────────────── */
.valuation-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1.5rem;
}

.header-content {
    flex: 1;
}

.header-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #64b5f6;
    margin-bottom: 0.5rem;
}

.eyebrow-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #42a5f5;
    box-shadow: 0 0 0 0 rgba(66, 165, 245, 0.7);
    animation: pulse-ring 2s infinite;
}

@@keyframes pulse-ring {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(66, 165, 245, 0.7); }
    70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(66, 165, 245, 0); }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(66, 165, 245, 0); }
}

.header-title {
    font-family: 'Syne', sans-serif;
    font-size: 2rem;
    font-weight: 800;
    color: #f0f4ff;
    margin: 0 0 0.5rem 0;
}

.header-subtitle {
    color: #8fadd8;
    font-size: 0.95rem;
    margin: 0;
}

.header-actions {
    display: flex;
    gap: 0.75rem;
}

.btn-export, .btn-back {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0.75rem 1.25rem;
    border-radius: 12px;
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.3s ease;
    cursor: pointer;
}

.btn-export {
    background: rgba(46, 125, 50, 0.15);
    border: 1px solid rgba(102, 187, 106, 0.3);
    color: #81c784;
}

.btn-export:hover {
    background: rgba(46, 125, 50, 0.25);
    border-color: rgba(102, 187, 106, 0.5);
    color: #c8e6c9;
    transform: translateY(-2px);
}

.btn-back {
    background: rgba(66, 165, 245, 0.1);
    border: 1px solid rgba(66, 165, 245, 0.25);
    color: #64b5f6;
}

.btn-back:hover {
    background: rgba(66, 165, 245, 0.2);
    border-color: rgba(66, 165, 245, 0.4);
    color: #90caf9;
    transform: translateY(-2px);
}

/* ─── Metrics Grid ────────────────────────────── */
.metrics-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
    margin-bottom: 2rem;
}

.metric-card {
    position: relative;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 1.5rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    overflow: hidden;
    transition: all 0.3s ease;
}

.metric-card:hover {
    transform: translateY(-3px);
    border-color: rgba(255, 255, 255, 0.15);
}

.metric-glow {
    position: absolute;
    top: -50%;
    right: -50%;
    width: 200px;
    height: 200px;
    border-radius: 50%;
    opacity: 0.15;
    filter: blur(40px);
    pointer-events: none;
}

.metric-primary .metric-glow { background: #42a5f5; }
.metric-secondary .metric-glow { background: #66bb6a; }
.metric-tertiary .metric-glow { background: #ffa726; }
.metric-quaternary .metric-glow { background: #ab47bc; }

.metric-icon {
    width: 52px;
    height: 52px;
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    flex-shrink: 0;
}

.metric-primary .metric-icon {
    background: rgba(66, 165, 245, 0.15);
    color: #64b5f6;
}

.metric-secondary .metric-icon {
    background: rgba(102, 187, 106, 0.15);
    color: #81c784;
}

.metric-tertiary .metric-icon {
    background: rgba(255, 167, 38, 0.15);
    color: #ffb74d;
}

.metric-quaternary .metric-icon {
    background: rgba(171, 71, 188, 0.15);
    color: #ce93d8;
}

.metric-content {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.metric-label {
    font-size: 0.75rem;
    color: #8fadd8;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

.metric-value {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #f0f4ff;
}

.metric-trend {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.75rem;
    color: #6ba3d1;
}

/* ─── Metric Stickers ──────────────────────────── */
.metric-sticker {
    position: absolute;
    top: -8px;
    right: -8px;
    font-size: 3rem;
    opacity: 0.15;
    transform: rotate(15deg);
    animation: float-sticker 3s ease-in-out infinite;
    pointer-events: none;
}

.metric-sticker.sticker-primary { animation-delay: 0s; }
.metric-sticker.sticker-secondary { animation-delay: 0.2s; }
.metric-sticker.sticker-tertiary { animation-delay: 0.4s; }
.metric-sticker.sticker-quaternary { animation-delay: 0.6s; }

@@keyframes float-sticker {
    0%, 100% { transform: rotate(15deg) translateY(0px); }
    50% { transform: rotate(15deg) translateY(-10px); }
}

.metric-trend {
    font-size: 0.8rem;
    color: #546e7a;
    display: flex;
    align-items: center;
    gap: 4px;
}

/* ─── Content Grid ────────────────────────────── */
.content-grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: 1.5rem;
    margin-bottom: 2rem;
}

.content-panel {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    overflow: hidden;
}

.panel-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.panel-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    background: rgba(66, 165, 245, 0.15);
    color: #64b5f6;
}

.icon-insight {
    background: rgba(255, 167, 38, 0.15);
    color: #ffb74d;
}

.panel-title h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #e0eeff;
    margin: 0 0 0.25rem 0;
}

.panel-title p {
    color: #546e7a;
    font-size: 0.85rem;
    margin: 0;
}

.panel-body {
    padding: 1.5rem;
}

/* ─── Category List ───────────────────────────── */
.category-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.category-item {
    display: grid;
    grid-template-columns: 1fr 1.5fr 1fr;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
}

.category-item:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(66, 165, 245, 0.2);
    transform: translateX(4px);
}

.category-info {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
}

.category-badge {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: rgba(66, 165, 245, 0.15);
    border: 1px solid rgba(66, 165, 245, 0.25);
    border-radius: 20px;
    color: #64b5f6;
    font-size: 0.8rem;
    font-weight: 600;
    width: fit-content;
}

.category-items {
    font-size: 0.8rem;
    color: #8fadd8;
}

.category-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.category-progress {
    flex: 1;
    height: 8px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    overflow: hidden;
}

.category-fill {
    height: 100%;
    background: linear-gradient(90deg, #42a5f5, #66bb6a);
    border-radius: 4px;
    transition: width 1s ease;
}

.category-percent {
    font-size: 0.85rem;
    color: #8fadd8;
    font-weight: 500;
    min-width: 45px;
    text-align: right;
}

.category-values {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.25rem;
}

.category-total {
    font-family: 'Syne', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: #f0f4ff;
}

.category-avg {
    font-size: 0.75rem;
    color: #8fadd8;
}

/* ─── Total Row ───────────────────────────────── */
.category-total-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 2px solid rgba(255, 255, 255, 0.1);
}

.total-label {
    font-size: 1rem;
    font-weight: 600;
    color: #8fadd8;
}

.total-value span {
    font-family: 'Syne', sans-serif;
    font-size: 1.5rem;
    font-weight: 800;
    color: #81c784;
}

/* ─── Insights ────────────────────────────────── */
.insight-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
}

.insight-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.05);
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;
}

.insight-item:hover {
    background: rgba(255, 255, 255, 0.06);
    transform: translateX(4px);
}

.insight-sticker {
    position: absolute;
    top: -5px;
    right: -5px;
    font-size: 2.5rem;
    opacity: 0.1;
    transform: rotate(-20deg);
    animation: bounce-sticker 2.5s ease-in-out infinite;
    pointer-events: none;
}

@@keyframes bounce-sticker {
    0%, 100% { transform: rotate(-20deg) scale(1); }
    50% { transform: rotate(-20deg) scale(1.05); }
}

.insight-icon {
    width: 44px;
    height: 44px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    flex-shrink: 0;
}

.insight-primary { background: rgba(255, 167, 38, 0.15); color: #ffb74d; }
.insight-secondary { background: rgba(66, 165, 245, 0.15); color: #64b5f6; }
.insight-tertiary { background: rgba(171, 71, 188, 0.15); color: #ce93d8; }
.insight-quaternary { background: rgba(102, 187, 106, 0.15); color: #81c784; }

.insight-content {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    flex: 1;
}

.insight-label {
    font-size: 0.75rem;
    color: #8fadd8;
    text-transform: uppercase;
    letter-spacing: 0.03em;
}

.insight-value {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #f0f4ff;
}

.insight-detail {
    font-size: 0.8rem;
    color: #546e7a;
}

/* ─── Chart Section ───────────────────────────── */
.chart-section {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 1.5rem;
}

.chart-header {
    margin-bottom: 1.5rem;
}

.chart-header h3 {
    font-family: 'Syne', sans-serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: #e0eeff;
    margin: 0 0 0.25rem 0;
}

.chart-header p {
    color: #546e7a;
    font-size: 0.85rem;
    margin: 0;
}

.chart-visual {
    display: flex;
    height: 50px;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 1.5rem;
}

.chart-segment {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    position: relative;
    transition: all 0.3s ease;
    cursor: pointer;
}

.chart-segment:hover {
    flex-grow: 1.1;
}

.chart-segment:nth-child(1) { background: #42a5f5; }
.chart-segment:nth-child(2) { background: #66bb6a; }
.chart-segment:nth-child(3) { background: #ffa726; }
.chart-segment:nth-child(4) { background: #ab47bc; }
.chart-segment:nth-child(5) { background: #ef5350; }
.chart-segment:nth-child(6) { background: #26c6da; }

.segment-label {
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.75rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    padding: 0 0.5rem;
}

.chart-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
}

.legend-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
}

.legend-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
}

.legend-item:nth-child(1) .legend-dot { background: #42a5f5; }
.legend-item:nth-child(2) .legend-dot { background: #66bb6a; }
