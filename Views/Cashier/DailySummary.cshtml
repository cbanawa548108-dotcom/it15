@model CRLFruitstandESS.Models.ViewModels.DailySummaryViewModel
@{
    ViewData["Title"] = "Daily Sales Summary";
    Layout = "~/Views/Shared/_CashierLayout.cshtml";
}

<div class="summary-page">
    <div class="summary-container">
        <!-- Header -->
        <div class="page-header">
            <div class="header-content">
                <div class="header-icon">
                    <i class="bi bi-bar-chart-line-fill"></i>
                </div>
                <div class="header-text">
                    <h1 class="page-title">Daily Sales Summary</h1>
                    <p class="page-subtitle">Track your daily performance and transactions</p>
                </div>
            </div>
            <form method="get" class="date-selector">
                <div class="date-input-wrapper">
                    <i class="bi bi-calendar3"></i>
                    <input type="date" name="date" class="date-input"
                           value="@Model.Date.ToString("yyyy-MM-dd")"
                           max="@DateTime.Today.ToString("yyyy-MM-dd")" />
                </div>
                <button type="submit" class="btn-view">
                    <i class="bi bi-arrow-right-circle"></i>
                    View
                </button>
            </form>
        </div>

        <!-- Stats Cards -->
        <div class="stats-grid">
            <div class="stat-card transactions">
                <div class="stat-bg-icon"><i class="bi bi-receipt"></i></div>
                <div class="stat-content">
                    <div class="stat-header">
                        <span class="stat-label">Total Transactions</span>
                        <div class="stat-badge">
                            <i class="bi bi-arrow-up-short"></i>
                            <span>Daily</span>
                        </div>
                    </div>
                    <div class="stat-value">@Model.TotalTransactions</div>
                    <div class="stat-footer">
                        <span class="stat-trend positive">
                            <i class="bi bi-graph-up"></i>
                            Active sales
                        </span>
                    </div>
                </div>
                <div class="stat-progress">
                    <div class="progress-bar" style="width: 75%"></div>
                </div>
            </div>

            <div class="stat-card sales">
                <div class="stat-bg-icon"><i class="bi bi-cash-stack"></i></div>
                <div class="stat-content">
                    <div class="stat-header">
                        <span class="stat-label">Total Sales</span>
                        <div class="stat-badge success">
                            <i class="bi bi-currency-dollar"></i>
                            Revenue
                        </div>
                    </div>
                    <div class="stat-value">₱@Model.TotalSales.ToString("N2")</div>
                    <div class="stat-footer">
                        <span class="stat-trend">
                            <i class="bi bi-wallet2"></i>
                            Gross income
                        </span>
                    </div>
                </div>
                <div class="stat-progress">
                    <div class="progress-bar success" style="width: 60%"></div>
                </div>
            </div>

            <div class="stat-card average">
                <div class="stat-bg-icon"><i class="bi bi-graph-up-arrow"></i></div>
                <div class="stat-content">
                    <div class="stat-header">
                        <span class="stat-label">Average Transaction</span>
                        <div class="stat-badge info">
                            <i class="bi bi-calculator"></i>
                            Avg
                        </div>
                    </div>
                    <div class="stat-value">
                        ₱@(Model.TotalTransactions > 0
                            ? (Model.TotalSales / Model.TotalTransactions).ToString("N2")
                            : "0.00")
                    </div>
                    <div class="stat-footer">
                        <span class="stat-trend info">
                            <i class="bi bi-cart-check"></i>
                            Per customer
                        </span>
                    </div>
                </div>
                <div class="stat-progress">
                    <div class="progress-bar info" style="width: 45%"></div>
                </div>
            </div>
        </div>

        <!-- Transactions Table -->
        <div class="transactions-card">
            <div class="card-header-custom">
                <div class="header-left">
                    <div class="header-icon-small">
                        <i class="bi bi-list-ul"></i>
                    </div>
                    <div>
                        <h3 class="card-title">Transactions</h3>
                        <p class="card-date">@Model.Date.ToString("MMMM dd, yyyy")</p>
                    </div>
                </div>
                <a href="/Cashier/POS" class="btn-new-sale">
                    <i class="bi bi-plus-lg"></i>
                    New Sale
                </a>
            </div>

            <div class="table-container">
                @if (!Model.Sales.Any())
                {
                    <div class="empty-state">
                        <div class="empty-icon">
                            <i class="bi bi-inbox"></i>
                        </div>
                        <h4>No transactions found</h4>
                        <p>No sales recorded for @Model.Date.ToString("MMMM dd, yyyy")</p>
                        <a href="/Cashier/POS" class="btn-create">
                            <i class="bi bi-plus-circle"></i>
                            Create First Sale
                        </a>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="custom-table">
                            <thead>
                                <tr>
                                    <th class="col-receipt">
                                        <i class="bi bi-receipt"></i>
                                        Receipt
                                    </th>
                                    <th class="col-time">
                                        <i class="bi bi-clock"></i>
                                        Time
                                    </th>
                                    <th class="col-cashier">
                                        <i class="bi bi-person"></i>
                                        Cashier
                                    </th>
                                    <th class="col-amount">
                                        <i class="bi bi-cash"></i>
                                        Amount
                                    </th>
                                    <th class="col-status">
                                        <i class="bi bi-check-circle"></i>
                                        Status
                                    </th>
                                    <th class="col-action">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sale in Model.Sales)
                                {
                                    <tr class="table-row">
                                        <td class="col-receipt">
                                            <div class="receipt-badge">
                                                <span class="receipt-hash">#</span>
                                                <span class="receipt-number">@sale.Id.ToString("D6")</span>
                                            </div>
                                        </td>
                                        <td class="col-time">
                                            <div class="time-display">
                                                <span class="time-main">@sale.SaleDate.ToString("hh:mm tt")</span>
                                                <span class="time-sub">@sale.SaleDate.ToString("ss")s</span>
                                            </div>
                                        </td>
                                        <td class="col-cashier">
                                            <div class="cashier-info">
                                                <div class="cashier-avatar">
                                                    @(sale.Cashier?.FullName?.Substring(0, 1) ?? "U")
                                                </div>
                                                <span class="cashier-name">@(sale.Cashier?.FullName ?? "Unknown")</span>
                                            </div>
                                        </td>
                                        <td class="col-amount">
                                            <span class="amount-value">₱@sale.TotalAmount.ToString("N2")</span>
                                        </td>
                                        <td class="col-status">
                                            <span class="status-badge @(sale.Status.ToLower())">
                                                <i class="bi bi-check-circle-fill"></i>
                                                @sale.Status
                                            </span>
                                        </td>
                                        <td class="col-action">
                                            <a href="/Cashier/Receipt/@sale.Id" class="btn-view-receipt">
                                                <i class="bi bi-eye"></i>
                                                View
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Summary Footer -->
                    <div class="table-footer">
                        <div class="footer-stats">
                            <div class="footer-stat">
                                <span class="label">Total Records:</span>
                                <span class="value">@Model.Sales.Count()</span>
                            </div>
                            <div class="footer-stat">
                                <span class="label">Date Range:</span>
                                <span class="value">@Model.Date.ToString("MMM dd, yyyy")</span>
                            </div>
                        </div>
                        <div class="footer-total">
                            <span class="label">Total Revenue:</span>
                            <span class="value">₱@Model.TotalSales.ToString("N2")</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
<style>
    /* Page Layout */
    .summary-page {
        min-height: 100vh;
        background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
        padding: 2rem;
    }

    .summary-container {
        max-width: 1400px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        gap: 2rem;
    }

    /* Header */
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        padding: 1.5rem 2rem;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .header-content {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        border-radius: 16px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        color: white;
        box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
    }

    .page-title {
        font-size: 1.75rem;
        font-weight: 800;
        color: #f8fafc;
        margin: 0;
        letter-spacing: -0.5px;
    }

    .page-subtitle {
        font-size: 0.9rem;
        color: #94a3b8;
        margin: 0.25rem 0 0;
    }

    /* Date Selector */
    .date-selector {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .date-input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
    }

    .date-input-wrapper i {
        position: absolute;
        left: 1rem;
        color: #64748b;
        font-size: 1rem;
    }

    .date-input {
        padding: 0.875rem 1rem 0.875rem 2.75rem;
        border: 2px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        background: rgba(15, 23, 42, 0.5);
        color: #f1f5f9;
        font-size: 0.95rem;
        font-weight: 500;
        outline: none;
        transition: all 0.2s;
    }

    .date-input:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.2);
    }

    .btn-view {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.5rem;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-view:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
    }

    /* Stats Grid */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 1.5rem;
    }

    .stat-card {
        position: relative;
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        padding: 1.5rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        overflow: hidden;
        transition: transform 0.3s, box-shadow 0.3s;
    }

    .stat-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px -5px rgba(0, 0, 0, 0.3);
    }

    .stat-bg-icon {
        position: absolute;
        top: -20px;
        right: -20px;
        font-size: 8rem;
        opacity: 0.03;
        color: white;
    }

    .stat-content {
        position: relative;
        z-index: 1;
    }

    .stat-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1rem;
    }

    .stat-label {
        font-size: 0.875rem;
        color: #94a3b8;
        font-weight: 500;
    }

    .stat-badge {
        display: flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.35rem 0.75rem;
        background: rgba(59, 130, 246, 0.2);
        color: #60a5fa;
        border-radius: 20px;
        font-size: 0.75rem;
        font-weight: 600;
    }

    .stat-badge.success {
        background: rgba(16, 185, 129, 0.2);
        color: #34d399;
    }

    .stat-badge.info {
        background: rgba(139, 92, 246, 0.2);
        color: #a78bfa;
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 800;
        color: #f8fafc;
        margin-bottom: 0.5rem;
        letter-spacing: -1px;
    }

    .stat-footer {
        margin-top: 0.5rem;
    }

    .stat-trend {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.875rem;
        color: #64748b;
    }

    .stat-trend.positive {
        color: #34d399;
    }

    .stat-trend.info {
        color: #a78bfa;
    }

    .stat-progress {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        height: 4px;
        background: rgba(255, 255, 255, 0.05);
    }

    .progress-bar {
        height: 100%;
        background: linear-gradient(90deg, #3b82f6, #60a5fa);
        border-radius: 0 2px 0 0;
        transition: width 0.5s ease;
    }

    .progress-bar.success {
        background: linear-gradient(90deg, #10b981, #34d399);
    }

    .progress-bar.info {
        background: linear-gradient(90deg, #8b5cf6, #a78bfa);
    }

    /* Transactions Card */
    .transactions-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(10px);
        border-radius: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        overflow: hidden;
    }

    .card-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.5rem 2rem;
        background: rgba(255, 255, 255, 0.05);
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .header-left {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .header-icon-small {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #f59e0b, #ef4444);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 1.25rem;
    }

    .card-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #f8fafc;
        margin: 0;
    }

    .card-date {
        font-size: 0.875rem;
        color: #94a3b8;
        margin: 0.25rem 0 0;
    }

    .btn-new-sale {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.875rem 1.5rem;
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        font-size: 0.9rem;
        transition: all 0.2s;
    }

    .btn-new-sale:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(16, 185, 129, 0.4);
        color: white;
    }

    /* Table */
    .table-container {
        padding: 0;
    }

    .custom-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
    }

    .custom-table thead th {
        padding: 1.25rem 1.5rem;
        text-align: left;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #64748b;
        font-weight: 600;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        white-space: nowrap;
    }

    .custom-table thead th i {
        margin-right: 0.5rem;
    }

    .custom-table tbody tr {
        transition: background 0.2s;
    }

    .custom-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.03);
    }

    .custom-table tbody td {
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        vertical-align: middle;
    }

    .receipt-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.5rem 1rem;
        background: rgba(59, 130, 246, 0.15);
        border-radius: 8px;
        font-family: monospace;
        font-weight: 700;
    }

    .receipt-hash {
        color: #3b82f6;
        margin-right: 2px;
    }

    .receipt-number {
        color: #60a5fa;
    }

    .time-display {
        display: flex;
        flex-direction: column;
    }

    .time-main {
        font-weight: 600;
        color: #e2e8f0;
    }

    .time-sub {
        font-size: 0.75rem;
        color: #64748b;
    }

    .cashier-info {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .cashier-avatar {
        width: 36px;
        height: 36px;
        background: linear-gradient(135deg, #8b5cf6, #a78bfa);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 0.875rem;
    }

    .cashier-name {
        color: #e2e8f0;
        font-weight: 500;
    }

    .amount-value {
        font-family: monospace;
        font-size: 1.1rem;
        font-weight: 700;
        color: #34d399;
    }

    .status-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .status-badge.completed {
        background: rgba(16, 185, 129, 0.15);
        color: #34d399;
    }

    .btn-view-receipt {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        background: rgba(59, 130, 246, 0.15);
        color: #60a5fa;
        text-decoration: none;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-view-receipt:hover {
        background: rgba(59, 130, 246, 0.25);
        color: #93c5fd;
    }

    /* Table Footer */
    .table-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 2rem;
        background: rgba(255, 255, 255, 0.03);
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        flex-wrap: wrap;
        gap: 1rem;
    }

    .footer-stats {
        display: flex;
        gap: 2rem;
    }

    .footer-stat {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .footer-stat .label {
        color: #64748b;
        font-size: 0.875rem;
    }

    .footer-stat .value {
        color: #94a3b8;
        font-weight: 600;
    }

    .footer-total {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .footer-total .label {
        color: #94a3b8;
        font-size: 0.9rem;
    }

    .footer-total .value {
        font-size: 1.5rem;
        font-weight: 800;
        color: #34d399;
    }

    /* Empty State */
    .empty-state {
        text-align: center;
        padding: 4rem 2rem;
    }

    .empty-icon {
        width: 100px;
        height: 100px;
        background: rgba(255, 255, 255, 0.05);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 3rem;
        color: #64748b;
    }

    .empty-state h4 {
        color: #e2e8f0;
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: #64748b;
        margin-bottom: 1.5rem;
    }

    .btn-create {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: white;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 600;
        transition: all 0.2s;
    }

    .btn-create:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 25px -5px rgba(59, 130, 246, 0.4);
        color: white;
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .summary-page {
            padding: 1rem;
        }

        .page-header {
            flex-direction: column;
            text-align: center;
        }

        .stats-grid {
            grid-template-columns: 1fr;
        }

        .card-header-custom {
            flex-direction: column;
            gap: 1rem;
            text-align: center;
        }

        .custom-table thead {
            display: none;
        }

        .custom-table tbody td {
            display: block;
            padding: 0.75rem 1rem;
            text-align: right;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .custom-table tbody td::before {
            content: attr(data-label);
            float: left;
            font-weight: 600;
            text-transform: uppercase;
            font-size: 0.75rem;
            color: #64748b;
        }

        .table-footer {
            flex-direction: column;
            text-align: center;
        }

        .footer-stats {
            flex-direction: column;
            gap: 0.5rem;
        }
    }
</style>
}