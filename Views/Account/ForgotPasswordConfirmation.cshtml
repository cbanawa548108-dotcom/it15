@{
    ViewData["Title"] = "Reset Link Ready";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var resetLink  = TempData["ResetLink"]  as string ?? "";
    var resetEmail = TempData["ResetEmail"] as string ?? "";
}

<div class="login-page">
    <div class="login-card" style="max-width:520px;">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <img src="/images/logo_cropped.png" style="width:140px;height:140px;object-fit:contain;border-radius:50%;mix-blend-mode:screen;filter:brightness(1.1) drop-shadow(0 0 20px rgba(59,130,246,0.6));margin:0 auto 0.75rem;display:block;" />
            <h1 style="font-size:1.4rem;">Password Reset</h1>
        </div>

        <div style="background:rgba(245,158,11,0.1);border:1px solid rgba(245,158,11,0.3);
                    border-radius:10px;padding:1rem 1.25rem;margin-bottom:1.5rem;">
            <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
                <span style="font-size:1.1rem;">⚠️</span>
                <strong style="color:#f59e0b;font-size:0.85rem;">SMTP NOT CONFIGURED — DEMO MODE</strong>
            </div>
            <p style="color:#94a3b8;font-size:0.82rem;margin:0;">
                Email sending is disabled because no SMTP credentials are set in <code>appsettings.json</code>.
                The reset link is shown below instead.
            </p>
        </div>

        <p style="color:#94a3b8;font-size:0.875rem;margin-bottom:0.75rem;">
            Reset link for <strong style="color:#f1f5f9;">@resetEmail</strong>:
        </p>

        <div style="background:#0d1526;border:1px solid #334155;border-radius:8px;
                    padding:0.875rem 1rem;margin-bottom:1.25rem;word-break:break-all;">
            <a href="@resetLink" style="color:#60a5fa;font-size:0.78rem;text-decoration:none;">@resetLink</a>
        </div>

        <a href="@resetLink"
           style="display:block;text-align:center;padding:0.875rem;background:#3b82f6;
                  color:white;border-radius:8px;font-weight:700;text-decoration:none;
                  margin-bottom:1rem;transition:background 0.2s;">
            → Click Here to Reset Password
        </a>

        <div style="text-align:center;">
            <a href="/Account/Login" style="color:#64748b;font-size:0.82rem;">← Back to Login</a>
        </div>
    </div>
</div>






