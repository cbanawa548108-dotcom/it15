@model CRLFruitstandESS.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Cashier Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-header">
    <div>
        <span class="dash-label">POS Terminal</span>
        <h1 class="dash-title">Cashier Dashboard</h1>
        <p class="dash-sub">@Model.WelcomeMessage</p>
    </div>
    <div class="dash-badge cashier-badge">Cashier</div>
</div>

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon si-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">₱0.00</div>
            <div class="stat-label">My Sales Today</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon si-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <rect x="2" y="3" width="20" height="14" rx="2"/>
                <path d="M8 21h8M12 17v4"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">0</div>
            <div class="stat-label">Transactions</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon si-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">@DateTime.Now.ToString("hh:mm tt")</div>
            <div class="stat-label">Current Time</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon si-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <polyline points="20 6 9 17 4 12"/>
            </svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">Active</div>
            <div class="stat-label">Shift Status</div>
        </div>
    </div>
</div>

<div class="quick-actions">
    <h3 class="section-heading">POS Actions</h3>
    <div class="action-grid">
        <a href="/Cashier/POS" class="action-card">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none"
                 viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <line x1="9" y1="9" x2="15" y2="9"/>
                <line x1="9" y1="15" x2="15" y2="15"/>
            </svg>
            Open POS Terminal
        </a>
    </div>
</div>