<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CRL Fruitstand ESS</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
    <!-- ADD THIS LINE -->
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="dashboard-body">

    <!-- SIDEBAR -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">CRL</div>
            <div class="brand-text">
                <span class="brand-name">Fruitstand</span>
                <span class="brand-sub">ESS Platform</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <div class="nav-section-label">Main</div>
            <a href="/Account/RedirectToDashboard" class="sidebar-link active">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                    <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/>
                </svg>
                Dashboard
            </a>

            @if (User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Administration</div>
                <a href="/Users" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                        <circle cx="9" cy="7" r="4"/>
                    </svg>
                    User Management
                </a>
                <a href="/Roles" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                    </svg>
                    Roles & Permissions
                </a>
            }

            @if (User.IsInRole("CFO") || User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Finance</div>
                <a href="/FinancialMonitor" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <line x1="12" y1="1" x2="12" y2="23"/>
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
                    </svg>
                    Financial Monitor
                </a>
                <a href="/Analytics" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/>
                    </svg>
                    Analytics
                </a>
            }

            @if (User.IsInRole("Manager") || User.IsInRole("Admin"))
            {
                <div class="nav-section-label">Operations</div>
                <a href="/Inventory/Dashboard" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
                    </svg>
                    Inventory
                </a>
            }

            @if (User.IsInRole("Cashier") || User.IsInRole("Admin"))
            {
                <div class="nav-section-label">POS</div>
                <a href="/Cashier/POS" class="sidebar-link">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                        <path d="M8 21h8M12 17v4"/>
                    </svg>
                    POS Terminal
                </a>
            }
        </nav>

        <div class="sidebar-footer">
            <div class="user-info">
                <div class="user-avatar">@User.Identity?.Name?.Substring(0, 1).ToUpper()</div>
                <div class="user-details">
                    <div class="user-name">@User.Identity?.Name</div>
                    <div class="user-role">
                        @(User.IsInRole("Admin") ? "Administrator" :
                          User.IsInRole("CFO") ? "CFO" :
                          User.IsInRole("Manager") ? "Manager" : "Cashier")
                    </div>
                </div>
            </div>
            <form asp-action="Logout" asp-controller="Account" method="post" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" class="logout-btn" title="Sign Out">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
                        <polyline points="16 17 21 12 16 7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </button>
            </form>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <header class="topbar">
            <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <line x1="3" y1="12" x2="21" y2="12"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                    <line x1="3" y1="18" x2="21" y2="18"/>
                </svg>
            </button>
            <div class="topbar-right">
                <div class="topbar-date">@DateTime.Now.ToString("dddd, MMMM dd, yyyy")</div>
            </div>
        </header>

        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>