@using CRLFruitstandESS.Models.ViewModels
@model List<UserListViewModel>
@{ ViewData["Title"] = "User Management"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }
@section Styles {
<style>
.page-content{background:#060d1a!important;min-height:100vh}
.adm-header{background:linear-gradient(135deg,#0f2044 0%,#0a1628 100%);border:1px solid #1e3a6e;padding:2.5rem 2rem;border-radius:14px;margin-bottom:2rem;position:relative;overflow:hidden}
.adm-header::before{content:'';position:absolute;top:-60px;right:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(59,130,246,.15) 0%,transparent 70%);border-radius:50%;pointer-events:none}
.adm-header>div{position:relative;z-index:1}
.blue-card{background:#0d1f3c;border:1px solid #1e3a6e;border-radius:14px;padding:1.75rem;margin-bottom:1.5rem}
.dark-input{padding:.75rem 1rem;background:#060d1a;border:1px solid #1e3a6e;border-radius:8px;color:#e2e8f0;font-size:.9rem;outline:none;transition:border-color .2s,box-shadow .2s}
.dark-input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.2)}
.btn-blue{display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.5rem;background:#2563eb;color:white;border:none;border-radius:8px;font-size:.875rem;font-weight:700;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.btn-blue:hover{background:#1d4ed8;transform:translateY(-1px);box-shadow:0 4px 16px rgba(37,99,235,.4)}
.btn-blue:active{transform:scale(.97)}
.btn-ghost{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1rem;background:transparent;color:#64748b;border:1px solid #1e3a6e;border-radius:6px;font-size:.8rem;font-weight:600;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.btn-ghost:hover{border-color:#3b82f6;color:#93c5fd}
.btn-danger{display:inline-flex;align-items:center;gap:.4rem;padding:.5rem 1rem;background:rgba(239,68,68,.1);color:#fca5a5;border:1px solid rgba(239,68,68,.3);border-radius:6px;font-size:.8rem;font-weight:600;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.btn-danger:hover{background:rgba(239,68,68,.2)}
.adm-table{width:100%;border-collapse:collapse;font-size:.875rem}
.adm-table thead tr{background:#060d1a}
.adm-table thead th{padding:.875rem 1rem;text-align:left;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#334155;border-bottom:1px solid #1e3a6e}
.adm-table tbody tr{border-bottom:1px solid #0d1f3c;transition:background .15s}
.adm-table tbody tr:hover{background:#0d1f3c}
.adm-table tbody td{padding:.875rem 1rem;color:#cbd5e1}
.badge-role{display:inline-block;padding:.2rem .65rem;border-radius:999px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.role-admin  {background:rgba(239,68,68,.15);color:#fca5a5;border:1px solid rgba(239,68,68,.3)}
.role-cfo    {background:rgba(59,130,246,.15);color:#93c5fd;border:1px solid rgba(59,130,246,.3)}
.role-manager{background:rgba(16,185,129,.15);color:#34d399;border:1px solid rgba(16,185,129,.3)}
.role-cashier{background:rgba(245,158,11,.15);color:#fcd34d;border:1px solid rgba(245,158,11,.3)}
.role-other  {background:rgba(139,92,246,.15);color:#a78bfa;border:1px solid rgba(139,92,246,.3)}
.status-dot{width:8px;height:8px;border-radius:50%;display:inline-block;margin-right:.4rem}
.dot-active{background:#10b981;box-shadow:0 0 6px #10b981}
.dot-inactive{background:#475569}
</style>
}
<div class="adm-header">
    <div>
        <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#3b82f6;display:block;margin-bottom:.5rem;">Administration</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 .4rem;color:#f1f5f9;">User Management</h1>
        <p style="margin:0;font-size:.9rem;color:#475569;">Create, edit, and manage system user accounts and role assignments</p>
    </div>
</div>
@if (TempData["Success"] != null) { <div style="padding:1rem 1.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:8px;color:#34d399;margin-bottom:1.5rem;font-weight:600;">✓ @TempData["Success"]</div> }
@if (TempData["Error"]   != null) { <div style="padding:1rem 1.5rem;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:8px;color:#fca5a5;margin-bottom:1.5rem;font-weight:600;">✕ @TempData["Error"]</div> }

<div class="blue-card">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <form method="get" style="display:flex;gap:.75rem;align-items:center;">
            <input name="search" value="@ViewBag.Search" class="dark-input" placeholder="Search users…" style="width:260px;"/>
            <button type="submit" class="btn-blue"><i class="bi bi-search"></i> Search</button>
        </form>
        <a href="/Admin/CreateUser" class="btn-blue"><i class="bi bi-person-plus-fill"></i> New User</a>
    </div>
</div>

<div class="blue-card">
    <div style="overflow-x:auto;border-radius:10px;border:1px solid #1e3a6e;">
        <table class="adm-table">
            <thead><tr><th>User</th><th>Email</th><th>Department</th><th>Role</th><th>Status</th><th>Last Login</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="7" style="text-align:center;color:#334155;padding:3rem;">No users found.</td></tr> }
                @foreach (var u in Model) {
                    var roleClass = u.Roles.FirstOrDefault()?.ToLower() switch {
                        "admin"   => "role-admin",
                        "cfo"     => "role-cfo",
                        "manager" => "role-manager",
                        "cashier" => "role-cashier",
                        _         => "role-other"
                    };
                    <tr>
                        <td>
                            <div style="font-weight:600;color:#f1f5f9;">@u.FullName</div>
                            <div style="font-size:.78rem;color:#475569;">@@@u.UserName</div>
                        </td>
                        <td style="color:#94a3b8;">@u.Email</td>
                        <td style="color:#94a3b8;">@(string.IsNullOrEmpty(u.Department) ? "—" : u.Department)</td>
                        <td>
                            @foreach (var r in u.Roles) { <span class="badge-role @roleClass">@r</span> }
                            @if (!u.Roles.Any()) { <span style="color:#334155;font-size:.8rem;">No role</span> }
                        </td>
                        <td><span class="status-dot @(u.IsActive?"dot-active":"dot-inactive")"></span><span style="color:@(u.IsActive?"#34d399":"#475569");font-size:.82rem;font-weight:600;">@(u.IsActive?"Active":"Inactive")</span></td>
                        <td style="color:#475569;font-size:.8rem;">@(u.LastLoginAt?.ToString("MMM dd, yyyy") ?? "Never")</td>
                        <td>
                            <div style="display:flex;gap:.5rem;flex-wrap:wrap;">
                                <a href="/Admin/EditUser/@u.Id" class="btn-ghost"><i class="bi bi-pencil"></i> Edit</a>
                                <form method="post" action="/Admin/ToggleUser" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@u.Id"/>
                                    <button type="submit" class="btn-ghost">@(u.IsActive?"Deactivate":"Activate")</button>
                                </form>
                                <button type="button" class="btn-ghost"
                                        style="color:#f59e0b;border-color:rgba(245,158,11,0.3);"
                                        onclick="openResetModal('@u.Id', '@u.FullName')">
                                    <i class="bi bi-key"></i> Reset PW
                                </button>
                                @if (u.UserName != User.Identity?.Name) {
                                    <form method="post" action="/Admin/DeleteUser" style="display:inline;" onsubmit="return confirm('Delete @u.FullName?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@u.Id"/>
                                        <button type="submit" class="btn-danger"><i class="bi bi-trash"></i></button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>


<div id="resetModal" style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:9999;align-items:center;justify-content:center;">
    <div style="background:#1e293b;border:1px solid #334155;border-radius:14px;padding:2rem;width:100%;max-width:420px;margin:1rem;">
        <h3 style="color:#f1f5f9;margin:0 0 0.25rem;font-size:1.1rem;">🔑 Reset Password</h3>
        <p id="resetModalName" style="color:#64748b;font-size:0.85rem;margin:0 0 1.5rem;"></p>

        <form method="post" action="/Admin/AdminResetPassword" id="resetForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="resetUserId" />

            <div style="margin-bottom:1rem;">
                <label style="display:block;font-size:0.72rem;font-weight:700;text-transform:uppercase;letter-spacing:0.07em;color:#475569;margin-bottom:0.4rem;">New Password</label>
                <input type="password" name="newPassword" id="resetNewPassword" required minlength="8"
                       placeholder="Min. 8 characters — include uppercase, number, symbol"
                       style="width:100%;padding:0.75rem 1rem;background:#0d1526;border:1px solid #334155;
                              border-radius:8px;color:#f1f5f9;font-size:0.9rem;box-sizing:border-box;outline:none;" />
                <p style="color:#475569;font-size:0.72rem;margin:0.4rem 0 0;">
                    Must be 8+ chars with uppercase, lowercase, number, and symbol (e.g. <code>Pass@1234</code>)
                </p>
            </div>

            <div style="display:flex;gap:0.75rem;margin-top:1.5rem;">
                <button type="submit"
                        style="flex:1;padding:0.75rem;background:#f59e0b;color:#0d1526;border:none;
                               border-radius:8px;font-weight:700;cursor:pointer;font-size:0.9rem;">
                    Reset Password
                </button>
                <button type="button" onclick="closeResetModal()"
                        style="flex:1;padding:0.75rem;background:rgba(255,255,255,0.08);color:#94a3b8;
                               border:1px solid #334155;border-radius:8px;font-weight:600;cursor:pointer;font-size:0.9rem;">
                    Cancel
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function openResetModal(userId, fullName) {
    document.getElementById('resetUserId').value = userId;
    document.getElementById('resetModalName').textContent = 'User: ' + fullName;
    document.getElementById('resetNewPassword').value = '';
    const modal = document.getElementById('resetModal');
    modal.style.display = 'flex';
}
function closeResetModal() {
    document.getElementById('resetModal').style.display = 'none';
}
document.getElementById('resetModal').addEventListener('click', function(e) {
    if (e.target === this) closeResetModal();
});
</script>
}

