@model CRLFruitstandESS.Models.ViewModels.RevenueFormViewModel
@{ ViewData["Title"] = "Add Revenue"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }

<div class="dash-header">
    <div>
        <span class="dash-label">Finance</span>
        <h1 class="dash-title">@(Model.Id > 0 ? "Edit" : "Add") Revenue</h1>
    </div>
    <a href="/CfoDashboard/Revenue" class="btn-secondary">← Back</a>
</div>

<div class="cfo-card" style="max-width:600px;">
    <div class="cfo-card-body">
        <form asp-action="@(Model.Id > 0 ? "EditRevenue" : "AddRevenue")" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="form-group">
                <label asp-for="Source">Source / Description</label>
                <input asp-for="Source" class="form-input" placeholder="e.g. Fruit Sales - Mango" />
                <span asp-validation-for="Source" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category">Category</label>
                <select asp-for="Category" class="form-input">
                    <option value="Sales">Sales</option>
                    <option value="Other">Other Income</option>
                </select>
                <span asp-validation-for="Category" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Amount">Amount (₱)</label>
                <input asp-for="Amount" class="form-input" type="number" step="0.01" min="0.01" placeholder="0.00" />
                <span asp-validation-for="Amount" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="TransactionDate">Transaction Date</label>
                <input asp-for="TransactionDate" class="form-input" type="date" />
                <span asp-validation-for="TransactionDate" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Notes">Notes (optional)</label>
                <textarea asp-for="Notes" class="form-input" rows="3" placeholder="Additional notes..."></textarea>
            </div>

            <div style="display:flex;gap:1rem;margin-top:1.5rem;">
                <button type="submit" class="btn-primary">@(Model.Id > 0 ? "Update" : "Save") Revenue</button>
                <a href="/CfoDashboard/Revenue" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>