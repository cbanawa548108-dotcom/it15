@using CRLFruitstandESS.Models
@model List<ComplianceFlag>
@{ ViewData["Title"] = "Compliance Monitor"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }
@section Styles {
<style>
.page-content{background:#0f172a!important;min-height:100vh}
.comp-header{background:linear-gradient(135deg,#1e293b,#0f172a);border:1px solid #334155;padding:2.5rem 2rem;border-radius:14px;margin-bottom:2rem;position:relative;overflow:hidden}
.comp-header::before{content:'';position:absolute;top:-60px;right:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(239,68,68,.1) 0%,transparent 70%);border-radius:50%;pointer-events:none}
.comp-header>div{position:relative;z-index:1}
.dark-card{background:#1e293b;border:1px solid #334155;border-radius:14px;padding:1.75rem;margin-bottom:1.5rem}
.stat-row{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:1.25rem;margin-bottom:1.5rem}
.stat-tile{background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;transition:border-color .2s}
.stat-tile:hover{border-color:#475569}
.st-label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#64748b;margin-bottom:.5rem}
.st-value{font-size:1.8rem;font-weight:800;line-height:1}
.flag-row{display:flex;align-items:start;gap:1rem;padding:1.25rem;background:#0f172a;border:1px solid #334155;border-radius:10px;margin-bottom:.75rem;transition:border-color .2s}
.flag-row:hover{border-color:#475569}
.flag-row.resolved{opacity:.45}
.sev-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:4px}
.sev-critical{background:#ef4444;box-shadow:0 0 8px #ef4444}
.sev-warning{background:#f59e0b;box-shadow:0 0 8px #f59e0b}
.sev-info{background:#3b82f6;box-shadow:0 0 8px #3b82f6}
.badge-pill{display:inline-block;padding:.2rem .65rem;border-radius:999px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.btn-resolve{padding:.4rem 1rem;background:#10b981;color:white;border:none;border-radius:6px;font-size:.8rem;font-weight:700;cursor:pointer;transition:all .2s;outline:none}
.btn-resolve:hover{background:#059669;transform:translateY(-1px)}
.btn-resolve:active{transform:scale(.97)}
</style>
}
<div class="comp-header">
    <div>
        <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#ef4444;display:block;margin-bottom:.5rem;">RA 10173 · Internal Policy</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 .5rem;color:#f1f5f9;">Financial Compliance Monitor</h1>
        <p style="margin:0;font-size:.95rem;color:#94a3b8;">Auto-detected policy violations and non-compliant transactions</p>
    </div>
</div>
<div class="stat-row">
    <div class="stat-tile" style="border-top:3px solid #ef4444"><div class="st-label">Open Flags</div><div class="st-value" style="color:#fca5a5">@ViewBag.OpenCount</div></div>
    <div class="stat-tile" style="border-top:3px solid #f59e0b"><div class="st-label">Critical</div><div class="st-value" style="color:#fcd34d">@ViewBag.CriticalCount</div></div>
    <div class="stat-tile" style="border-top:3px solid #10b981"><div class="st-label">Resolved</div><div class="st-value" style="color:#34d399">@Model.Count(f=>f.IsResolved)</div></div>
    <div class="stat-tile" style="border-top:3px solid #3b82f6"><div class="st-label">Total Flags</div><div class="st-value" style="color:#60a5fa">@Model.Count</div></div>
</div>
@if (TempData["Success"] != null) {
    <div style="padding:1rem 1.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:8px;color:#34d399;margin-bottom:1.5rem;font-weight:600;">✓ @TempData["Success"]</div>
}
<div class="dark-card">
    <p style="font-size:1rem;font-weight:700;color:#f1f5f9;margin:0 0 1.25rem;display:flex;align-items:center;gap:.6rem;">
        <i class="bi bi-shield-exclamation" style="color:#ef4444;font-size:1.2rem;"></i> Compliance Flags
    </p>
    @if (!Model.Any()) {
        <p style="color:#475569;text-align:center;padding:2rem;">No compliance flags detected.</p>
    }
    @foreach (var f in Model) {
        <div class="flag-row @(f.IsResolved?"resolved":"")">
            <div class="sev-dot sev-@f.Severity"></div>
            <div style="flex:1">
                <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.4rem;flex-wrap:wrap;">
                    <span style="color:#f1f5f9;font-weight:600;font-size:.9rem;">@f.Description</span>
                    <span class="badge-pill" style="background:rgba(139,92,246,.15);color:#a78bfa;border:1px solid rgba(139,92,246,.3);">@f.Module</span>
                    @if (!string.IsNullOrEmpty(f.PolicyReference)) {
                        <span class="badge-pill" style="background:rgba(239,68,68,.1);color:#fca5a5;border:1px solid rgba(239,68,68,.2);">@f.PolicyReference</span>
                    }
                    @if (f.IsResolved) {
                        <span class="badge-pill" style="background:rgba(16,185,129,.1);color:#34d399;border:1px solid rgba(16,185,129,.2);">RESOLVED</span>
                    }
                </div>
                <small style="color:#475569;">@f.FlaggedAt.ToString("MMM dd, yyyy HH:mm") · Flagged by @f.FlaggedBy
                    @if (f.IsResolved) { <text> · Resolved by @f.ResolvedBy on @f.ResolvedAt?.ToString("MMM dd")</text> }
                </small>
            </div>
            @if (!f.IsResolved) {
                <form method="post" action="/Compliance/Resolve" style="flex-shrink:0;">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@f.Id"/>
                    <button type="submit" class="btn-resolve">Resolve</button>
                </form>
            }
        </div>
    }
</div>
