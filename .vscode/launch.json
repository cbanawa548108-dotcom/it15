{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "C#: CRLFruitstandESS Debug",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/bin/Debug/net8.0/CRLFruitstandESS.dll",
            "args": [],
            "cwd": "${workspaceFolder}",
            "stopAtEntry": false,
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:7080;http://localhost:5080"
            },
            "sourceFileMap": {
                "/Views": "${workspaceFolder}"
            }
        }
    ]
}
