@model CRLFruitstandESS.Models.ViewModels.ExpenseFormViewModel
@{ ViewData["Title"] = "Add Expense"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }

<div class="dash-header">
    <div>
        <span class="dash-label">Finance</span>
        <h1 class="dash-title">@(Model.Id > 0 ? "Edit" : "Add") Expense</h1>
    </div>
    <a href="/CfoDashboard/Expenses" class="btn-secondary">← Back</a>
</div>

<div class="cfo-card" style="max-width:600px;">
    <div class="cfo-card-body">
        <form asp-action="@(Model.Id > 0 ? "EditExpense" : "AddExpense")" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="Id" type="hidden" />

            <div class="form-group">
                <label asp-for="Description">Description</label>
                <input asp-for="Description" class="form-input" placeholder="e.g. Purchased Mango from Supplier A" />
                <span asp-validation-for="Description" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Category">Category</label>
                <select asp-for="Category" class="form-input">
                    <option value="">-- Select Category --</option>
                    <option value="Purchasing">Purchasing (Fruits)</option>
                    <option value="Labor">Labor / Wages</option>
                    <option value="Utilities">Utilities</option>
                    <option value="Transport">Transport / Delivery</option>
                    <option value="Spoilage">Spoilage Loss</option>
                    <option value="Other">Other</option>
                </select>
                <span asp-validation-for="Category" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Amount">Amount (₱)</label>
                <input asp-for="Amount" class="form-input" type="number" step="0.01" min="0.01" placeholder="0.00" />
                <span asp-validation-for="Amount" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ExpenseDate">Expense Date</label>
                <input asp-for="ExpenseDate" class="form-input" type="date" />
                <span asp-validation-for="ExpenseDate" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="Supplier">Supplier (optional)</label>
                <input asp-for="Supplier" class="form-input" placeholder="e.g. Davao Durian Farm" />
            </div>

            <div class="form-group">
                <label asp-for="Notes">Notes (optional)</label>
                <textarea asp-for="Notes" class="form-input" rows="3" placeholder="Additional details..."></textarea>
            </div>

            <div style="display:flex;gap:1rem;margin-top:1.5rem;">
                <button type="submit" class="btn-primary">@(Model.Id > 0 ? "Update" : "Save") Expense</button>
                <a href="/CfoDashboard/Expenses" class="btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>