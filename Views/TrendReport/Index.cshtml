@using CRLFruitstandESS.Models
@model List<TrendReport>
@{ ViewData["Title"] = "Trend Reports"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }
@section Styles {
<style>
.page-content{background:#0f172a!important;min-height:100vh}
.tr-header{background:linear-gradient(135deg,#1e293b,#0f172a);border:1px solid #334155;padding:2.5rem 2rem;border-radius:14px;margin-bottom:2rem;position:relative;overflow:hidden}
.tr-header::before{content:'';position:absolute;top:-60px;right:-60px;width:300px;height:300px;background:radial-gradient(circle,rgba(99,102,241,.1) 0%,transparent 70%);border-radius:50%;pointer-events:none}
.tr-header>div{position:relative;z-index:1}
.dark-card{background:#1e293b;border:1px solid #334155;border-radius:14px;padding:1.75rem;margin-bottom:1.5rem}
.dark-input{width:100%;padding:.75rem 1rem;background:#0f172a;border:1px solid #334155;border-radius:8px;color:#f1f5f9;font-size:.9rem;box-sizing:border-box;outline:none;transition:border-color .2s,box-shadow .2s}
.dark-input:focus{border-color:#6366f1;box-shadow:0 0 0 3px rgba(99,102,241,.15)}
.form-label{display:block;margin-bottom:.4rem;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#64748b}
.btn-create{display:inline-flex;align-items:center;gap:.5rem;padding:.75rem 1.75rem;background:#6366f1;color:white;border:none;border-radius:8px;font-size:.9rem;font-weight:700;cursor:pointer;transition:all .2s;outline:none;text-decoration:none}
.btn-create:hover{background:#4f46e5;transform:translateY(-2px);box-shadow:0 6px 20px rgba(99,102,241,.4)}
.btn-create:active{transform:scale(.97)}
.report-card{background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;margin-bottom:.75rem;display:flex;align-items:center;justify-content:space-between;gap:1rem;transition:border-color .2s}
.report-card:hover{border-color:#475569}
.badge-pill{display:inline-block;padding:.25rem .65rem;border-radius:999px;font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.btn-view{padding:.4rem 1rem;background:rgba(99,102,241,.15);color:#a5b4fc;border:1px solid rgba(99,102,241,.3);border-radius:6px;font-size:.8rem;font-weight:700;cursor:pointer;text-decoration:none;transition:all .2s}
.btn-view:hover{background:rgba(99,102,241,.25);color:#c7d2fe}
</style>
}
<div class="tr-header">
    <div>
        <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#6366f1;display:block;margin-bottom:.5rem;">Analytics · Read-Only Archive</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 .5rem;color:#f1f5f9;">Trend Report Builder</h1>
        <p style="margin:0;font-size:.95rem;color:#94a3b8;">Analyst-generated trend reports for executive review — no delete permissions</p>
    </div>
</div>
@if (TempData["Success"] != null) {
    <div style="padding:1rem 1.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:8px;color:#34d399;margin-bottom:1.5rem;font-weight:600;">✓ @TempData["Success"]</div>
}
<div class="dark-card">
    <p style="font-size:1rem;font-weight:700;color:#f1f5f9;margin:0 0 1.5rem;display:flex;align-items:center;gap:.6rem;"><i class="bi bi-plus-circle" style="color:#6366f1;font-size:1.2rem;"></i> Create New Trend Report</p>
    <form method="post" action="/TrendReport/Create">
        @Html.AntiForgeryToken()
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.25rem;margin-bottom:1.25rem;">
            <div><label class="form-label">Report Title</label><input name="title" class="dark-input" placeholder="e.g. Q2 Revenue Trend" required/></div>
            <div><label class="form-label">Type</label>
                <select name="reportType" class="dark-input">
                    <option>Revenue</option><option>Expense</option><option>Sales</option><option>Inventory</option><option>Custom</option>
                </select>
            </div>
            <div><label class="form-label">Period From</label><input type="date" name="periodFrom" class="dark-input" value="@DateTime.Today.AddDays(-30).ToString("yyyy-MM-dd")" required/></div>
            <div><label class="form-label">Period To</label><input type="date" name="periodTo" class="dark-input" value="@DateTime.Today.ToString("yyyy-MM-dd")" required/></div>
            <div style="grid-column:1/-1"><label class="form-label">Summary / Notes</label><textarea name="summary" class="dark-input" rows="3" placeholder="Key observations and insights..."></textarea></div>
        </div>
        <button type="submit" class="btn-create"><i class="bi bi-file-earmark-bar-graph"></i> Generate Report</button>
    </form>
</div>
<div class="dark-card">
    <p style="font-size:1rem;font-weight:700;color:#f1f5f9;margin:0 0 1.25rem;display:flex;align-items:center;gap:.6rem;"><i class="bi bi-archive" style="color:#94a3b8;font-size:1.2rem;"></i> Report Archive (@Model.Count)</p>
    @if (!Model.Any()) { <p style="color:#475569;text-align:center;padding:2rem;">No reports yet.</p> }
    @foreach (var r in Model) {
        <div class="report-card">
            <div>
                <div style="display:flex;align-items:center;gap:.75rem;margin-bottom:.35rem;">
                    <span style="color:#f1f5f9;font-weight:600;">@r.Title</span>
                    <span class="badge-pill" style="background:rgba(99,102,241,.15);color:#a5b4fc;border:1px solid rgba(99,102,241,.3);">@r.ReportType</span>
                </div>
                <small style="color:#475569;">@r.PeriodFrom.ToString("MMM dd") – @r.PeriodTo.ToString("MMM dd, yyyy") · By @r.CreatedBy · @r.CreatedAt.ToString("MMM dd, yyyy")</small>
            </div>
            <a href="/TrendReport/View/@r.Id" class="btn-view"><i class="bi bi-eye"></i> View</a>
        </div>
    }
</div>
