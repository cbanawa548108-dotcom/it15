            <td style="padding:.65rem 1rem;text-align:right;color:#94a3b8;">${r.dailyAvg}/day</td>
            <td style="padding:.65rem 1rem;text-align:right;color:#94a3b8;">${r.currentStock}</td>
            <td style="padding:.65rem 1rem;text-align:right;color:${sc[r.status]};font-weight:700;">${r.daysLeft}d</td>
            <td style="padding:.65rem 1rem;"><span style="padding:.2rem .6rem;border-radius:999px;font-size:.68rem;font-weight:700;text-transform:uppercase;background:${sb[r.status]};color:${sc[r.status]};border:1px solid ${sd[r.status]};">${r.status}</span></td>
        </tr>`).join('');
});

// ── Entrance animation
document.querySelectorAll('.chart-panel, .stat-cell').forEach((el, i) => {
    el.style.opacity = '0';
    el.style.transform = 'translateY(16px)';
    el.style.transition = `opacity .5s ease ${i * 0.04}s, transform .5s ease ${i * 0.04}s`;
    requestAnimationFrame(() => requestAnimationFrame(() => {
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
    }));
});
