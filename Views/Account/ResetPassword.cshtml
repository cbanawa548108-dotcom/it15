@model CRLFruitstandESS.Models.ViewModels.ResetPasswordViewModel
@{
    ViewData["Title"] = "Reset Password";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="login-page">
    <div class="login-card">
        <div style="text-align:center;margin-bottom:1.5rem;">
            <img src="/images/logo_cropped.png" style="width:140px;height:140px;object-fit:contain;border-radius:50%;mix-blend-mode:screen;filter:brightness(1.1) drop-shadow(0 0 20px rgba(59,130,246,0.6));margin:0 auto 0.75rem;display:block;" />
            <h1>Reset Password</h1>
            <p class="sub">Enter your new password below</p>
        </div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-error">
                <asp-validation-summary asp-validation-summary="All" class="text-danger"></asp-validation-summary>
            </div>
        }

        <form asp-action="ResetPassword" asp-controller="Account" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Token" />

            <div class="form-group">
                <label asp-for="NewPassword">New Password</label>
                <input asp-for="NewPassword" class="form-input" type="password" placeholder="Min. 8 characters" autofocus />
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword">Confirm Password</label>
                <input asp-for="ConfirmPassword" class="form-input" type="password" placeholder="Repeat new password" />
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="login-btn">Reset Password</button>
        </form>

        <div style="margin-top:1.5rem;text-align:center;">
            <a href="/Account/Login" style="color:#8fadd8;font-size:.85rem;">← Back to Login</a>
        </div>
    </div>
</div>






