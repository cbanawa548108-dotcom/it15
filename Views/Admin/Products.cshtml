@using CRLFruitstandESS.Models
@model List<Product>
@{ ViewData["Title"] = "Product Management"; Layout = "~/Views/Shared/_DashboardLayout.cshtml"; }
@section Styles {
<style>
.page-content{background:#060d1a!important;min-height:100vh}
.adm-header{background:linear-gradient(135deg,#0f2044,#0a1628);border:1px solid #1e3a6e;padding:2.5rem 2rem;border-radius:14px;margin-bottom:2rem}
.blue-card{background:#0d1f3c;border:1px solid #1e3a6e;border-radius:14px;padding:1.75rem;margin-bottom:1.5rem}
.dark-input{padding:.65rem 1rem;background:#060d1a;border:1px solid #1e3a6e;border-radius:8px;color:#e2e8f0;font-size:.875rem;outline:none;transition:border-color .2s,box-shadow .2s}
.dark-input:focus{border-color:#3b82f6;box-shadow:0 0 0 3px rgba(59,130,246,.2)}
.btn-blue{display:inline-flex;align-items:center;gap:.5rem;padding:.65rem 1.5rem;background:#2563eb;color:white;border:none;border-radius:8px;font-size:.875rem;font-weight:700;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.btn-blue:hover{background:#1d4ed8;transform:translateY(-1px);box-shadow:0 4px 16px rgba(37,99,235,.4)}
.btn-ghost{display:inline-flex;align-items:center;gap:.4rem;padding:.45rem .875rem;background:transparent;color:#64748b;border:1px solid #1e3a6e;border-radius:6px;font-size:.78rem;font-weight:600;cursor:pointer;text-decoration:none;transition:all .2s;outline:none}
.btn-ghost:hover{border-color:#3b82f6;color:#93c5fd}
.adm-table{width:100%;border-collapse:collapse;font-size:.875rem}
.adm-table thead tr{background:#060d1a}
.adm-table thead th{padding:.875rem 1rem;text-align:left;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#334155;border-bottom:1px solid #1e3a6e}
.adm-table tbody tr{border-bottom:1px solid #0d1f3c;transition:background .15s}
.adm-table tbody tr:hover{background:#0d1f3c}
.adm-table tbody td{padding:.875rem 1rem;color:#cbd5e1}
.badge-cat{display:inline-block;padding:.2rem .65rem;border-radius:999px;font-size:.68rem;font-weight:700;background:rgba(59,130,246,.15);color:#93c5fd;border:1px solid rgba(59,130,246,.3)}
.filter-btn{padding:.45rem 1rem;border-radius:8px;font-size:.78rem;font-weight:700;border:1px solid #1e3a6e;background:#060d1a;color:#475569;cursor:pointer;text-decoration:none;transition:all .2s}
.filter-btn.active,.filter-btn:hover{border-color:#3b82f6;color:#93c5fd;background:#0d1f3c}
</style>
}
<div class="adm-header">
    <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#3b82f6;display:block;margin-bottom:.5rem;">Administration</span>
    <h1 style="font-size:2rem;font-weight:800;margin:0 0 .4rem;color:#f1f5f9;">Product Management</h1>
    <p style="margin:0;font-size:.9rem;color:#475569;">Manage products, categories, pricing, and stock settings</p>
</div>
@if (TempData["Success"] != null) { <div style="padding:1rem 1.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:8px;color:#34d399;margin-bottom:1.5rem;font-weight:600;">✓ @TempData["Success"]</div> }

<div class="blue-card">
    <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
        <form method="get" style="display:flex;gap:.75rem;align-items:center;flex-wrap:wrap;">
            <input name="search" value="@ViewBag.Search" class="dark-input" placeholder="Search products…" style="width:220px;"/>
            <div style="display:flex;gap:.4rem;flex-wrap:wrap;">
                <a href="/Admin/Products" class="filter-btn @(string.IsNullOrEmpty(ViewBag.Category as string)?"active":"")">All</a>
                @foreach (var c in (List<string>)ViewBag.Categories) {
                    <a href="/Admin/Products?category=@c" class="filter-btn @(ViewBag.Category==c?"active":"")">@c</a>
                }
            </div>
            <button type="submit" class="btn-blue"><i class="bi bi-search"></i></button>
        </form>
        <a href="/Admin/CreateProduct" class="btn-blue"><i class="bi bi-plus-lg"></i> New Product</a>
    </div>
</div>

<div class="blue-card">
    <div style="overflow-x:auto;border-radius:10px;border:1px solid #1e3a6e;">
        <table class="adm-table">
            <thead><tr><th>Product</th><th>Category</th><th>Price</th><th>Cost</th><th>Stock</th><th>Status</th><th>Actions</th></tr></thead>
            <tbody>
                @if (!Model.Any()) { <tr><td colspan="7" style="text-align:center;color:#334155;padding:3rem;">No products found.</td></tr> }
                @foreach (var p in Model) {
                    var stock = p.Inventory?.Quantity ?? 0;
                    var stockColor = stock == 0 ? "#fca5a5" : stock <= (p.Inventory?.ReorderPoint ?? 20) ? "#fcd34d" : "#34d399";
                    <tr>
                        <td>
                            <div style="display:flex;align-items:center;gap:.75rem;">
                                <span style="font-size:1.5rem;">@p.Emoji</span>
                                <div>
                                    <div style="font-weight:600;color:#f1f5f9;">@p.Name</div>
                                    @if (!string.IsNullOrEmpty(p.Description)) { <div style="font-size:.75rem;color:#475569;">@p.Description.Substring(0,Math.Min(40,p.Description.Length))…</div> }
                                </div>
                            </div>
                        </td>
                        <td><span class="badge-cat">@p.Category</span></td>
                        <td style="color:#34d399;font-weight:700;">₱@p.Price.ToString("N2")</td>
                        <td style="color:#94a3b8;">₱@p.CostPrice.ToString("N2")</td>
                        <td style="color:@stockColor;font-weight:700;">@stock</td>
                        <td>
                            <span style="font-size:.78rem;font-weight:600;color:@(p.IsActive?"#34d399":"#475569");">@(p.IsActive?"Active":"Inactive")</span>
                        </td>
                        <td>
                            <div style="display:flex;gap:.5rem;">
                                <a href="/Admin/EditProduct/@p.Id" class="btn-ghost"><i class="bi bi-pencil"></i> Edit</a>
                                <a href="/Admin/AdjustStock/@p.Id" class="btn-ghost"><i class="bi bi-boxes"></i> Stock</a>
                                <form method="post" action="/Admin/ToggleProduct" style="display:inline;">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@p.Id"/>
                                    <button type="submit" class="btn-ghost">@(p.IsActive?"Disable":"Enable")</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
