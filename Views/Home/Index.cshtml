@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- ════════════════════════════════════════════
     HERO SECTION
═══════════════════════════════════════════ -->
<section id="home" class="hero">
    <div class="hero-grid"></div>
    <div class="orb orb-1"></div>
    <div class="orb orb-2"></div>
    <div class="orb orb-3"></div>

    <div class="hero-content">
        <div class="hero-badge">Executive Decision Support System</div>

        <h1 class="hero-title">
            <span class="line-1">CRL Fruitstand</span>
            <span class="line-2">ESS Platform</span>
        </h1>

        <p class="hero-subtitle">
            A comprehensive management solution that unifies sales, inventory, analytics,
            and financial oversight — empowering smarter decisions at every level of your business.
        </p>

        <div class="hero-actions">
            <a href="/Account/Login" class="btn-primary">
                Login to ESS
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                </svg>
            </a>
            <a href="#about" class="btn-secondary">
                Learn More
            </a>
        </div>
    </div>

    <div class="scroll-hint">
        <span>Scroll</span>
        <div class="scroll-hint-line"></div>
    </div>
</section>

<!-- ════════════════════════════════════════════
     ABOUT SECTION
═══════════════════════════════════════════ -->
<section id="about">
    <div class="section-inner">
        <div class="about-grid">

            <!-- Visual / Stats Card -->
            <div class="about-visual reveal">
                <div class="about-card-main">
                    <div style="display:flex; align-items:center; gap:10px; margin-bottom:1.5rem;">
                        <div style="width:40px;height:40px;background:linear-gradient(135deg,#1e4fa8,#2d7ef7);border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:'Playfair Display',serif;font-weight:800;font-size:0.9rem;color:white;">CRL</div>
                        <div>
                            <div style="font-weight:700;font-size:0.95rem;color:white;">CRL Fruitstand</div>
                            <div style="font-size:0.72rem;color:#8fadd8;letter-spacing:.08em;text-transform:uppercase;">ESS Dashboard</div>
                        </div>
                        <div style="margin-left:auto;background:rgba(69,200,150,.12);border:1px solid rgba(69,200,150,.2);color:#45c896;font-size:.7rem;font-weight:600;padding:.25rem .7rem;border-radius:50px;">● Live</div>
                    </div>

                    <!-- Mini chart bar illustration -->
                    <div style="display:flex; align-items:flex-end; gap:8px; height:80px; padding:0 0.5rem; margin-bottom:1rem;">
                        @{
                            var bars = new[] { 55, 70, 45, 88, 62, 95, 73, 80, 58, 92, 67, 85 };
                            var months = new[] { "J","F","M","A","M","J","J","A","S","O","N","D" };
                        }
                        @for (int i = 0; i < bars.Length; i++)
                        {
                            <div style="flex:1; display:flex; flex-direction:column; align-items:center; gap:4px;">
                                <div style="width:100%; height:@(bars[i])%; background:linear-gradient(to top,#1e4fa8,@(i == 9 ? "#2d7ef7" : "#5ba4f5")); border-radius:4px 4px 0 0; opacity:@(i == 9 ? "1" : "0.5"); transition:all 0.3s;"></div>
                                <span style="font-size:.5rem;color:#8fadd8;">@months[i]</span>
                            </div>
                        }
                    </div>

                    <div class="stat-row">
                        <div class="stat-item">
                            <div class="stat-num" data-target="98" data-suffix="%">0%</div>
                            <div class="stat-label">Uptime</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-num" data-target="4" data-suffix=" mods">0</div>
                            <div class="stat-label">Modules</div>
                        </div>
                        <div class="stat-item">
                            <div class="stat-num" data-target="24" data-suffix="/7">0</div>
                            <div class="stat-label">Support</div>
                        </div>
                    </div>
                </div>

                <div class="about-badge-float">
                    <div style="font-size:0.65rem;letter-spacing:.1em;text-transform:uppercase;opacity:.7;">Powered by</div>
                    <div>ASP.NET Core 8</div>
                </div>
            </div>

            <!-- Text Content -->
            <div class="about-content">
                <span class="section-label reveal">About the System</span>
                <h2 class="section-title reveal">Built for Smart<br>Fruit Business Operations</h2>

                <p class="reveal">
                    <strong style="color:var(--light-sky);">CRL Fruitstand</strong> is a local retail business
                    dedicated to delivering fresh, quality produce to customers. As the business grows,
                    managing sales, inventory, and finances manually becomes increasingly challenging.
                </p>
                <p class="reveal">
                    The <strong style="color:var(--light-sky);">Executive Decision Support System (ESS)</strong>
                    is a purpose-built web application developed to address these challenges. It provides
                    owners and managers with a centralized platform that brings together all critical
                    business data in one place — enabling faster, more informed decisions.
                </p>

                <ul class="about-list reveal">
                    <li>Real-time sales and transaction tracking</li>
                    <li>Automated inventory alerts and stock management</li>
                    <li>Data-driven analytics and business insights</li>
                    <li>Comprehensive financial monitoring and reporting</li>
                </ul>
            </div>

        </div>
    </div>
</section>

<!-- ════════════════════════════════════════════
     FEATURES SECTION
═══════════════════════════════════════════ -->
<section id="features">
    <div class="section-inner">
        <div class="features-header">
            <span class="section-label reveal">System Modules</span>
            <h2 class="section-title reveal">Powerful Features<br>for Every Operation</h2>
            <p class="section-desc reveal">
                Four integrated modules work seamlessly together to give CRL Fruitstand
                complete visibility and control over its entire business operation.
            </p>
        </div>

        <div class="features-grid">

            <!-- Feature 1: POS -->
            <div class="feature-card reveal">
                <div class="feature-icon-wrap fi-1">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="1.8">
                        <rect x="2" y="3" width="20" height="14" rx="2" />
                        <path d="M8 21h8M12 17v4" />
                        <path d="M6 8h4M6 11h2" />
                        <rect x="14" y="7" width="4" height="5" rx="1" />
                    </svg>
                </div>
                <h3 class="feature-title">Point of Sale (POS)</h3>
                <p class="feature-desc">
                    A streamlined transaction processing system that speeds up checkout, handles
                    multiple payment methods, and automatically logs every sale with complete
                    itemization and receipt generation.
                </p>
                <div class="feature-tags">
                    <span class="tag tag-blue">Fast Checkout</span>
                    <span class="tag tag-blue">Receipts</span>
                    <span class="tag tag-blue">Multi-Payment</span>
                </div>
            </div>

            <!-- Feature 2: Inventory -->
            <div class="feature-card reveal">
                <div class="feature-icon-wrap fi-2">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="1.8">
                        <path d="M3 3h2l.4 2M7 13h10l4-8H5.4" />
                        <circle cx="9" cy="21" r="1" />
                        <circle cx="20" cy="21" r="1" />
                        <path d="M9 16H5l-2-10" />
                    </svg>
                </div>
                <h3 class="feature-title">Inventory Management</h3>
                <p class="feature-desc">
                    Keep precise control over stock levels with real-time quantity tracking, automated
                    low-stock alerts, expiration date monitoring, and supplier management — ensuring
                    shelves are always stocked with fresh produce.
                </p>
                <div class="feature-tags">
                    <span class="tag tag-blue">Stock Alerts</span>
                    <span class="tag tag-blue">Expiry Tracking</span>
                    <span class="tag tag-blue">Suppliers</span>
                </div>
            </div>

            <!-- Feature 3: Analytics -->
            <div class="feature-card reveal">
                <div class="feature-icon-wrap fi-3">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="1.8">
                        <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
                    </svg>
                </div>
                <h3 class="feature-title">Sales Analytics</h3>
                <p class="feature-desc">
                    Transform raw sales data into actionable insights with interactive charts, trend
                    analysis, bestseller rankings, and peak-hour reports. Understand what's driving
                    revenue and where growth opportunities lie.
                </p>
                <div class="feature-tags">
                    <span class="tag tag-gold">Trend Reports</span>
                    <span class="tag tag-gold">Best Sellers</span>
                    <span class="tag tag-gold">Peak Hours</span>
                </div>
            </div>

            <!-- Feature 4: Financial -->
            <div class="feature-card reveal">
                <div class="feature-icon-wrap fi-4">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor" stroke-width="1.8">
                        <line x1="12" y1="1" x2="12" y2="23" />
                        <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6" />
                    </svg>
                </div>
                <h3 class="feature-title">Financial Monitoring</h3>
                <p class="feature-desc">
                    Maintain a clear picture of your financial health with daily revenue summaries,
                    expense tracking, profit & loss statements, and automated financial reports — all
                    designed for non-accountant business owners.
                </p>
                <div class="feature-tags">
                    <span class="tag tag-green">P&amp;L Reports</span>
                    <span class="tag tag-green">Revenue Tracking</span>
                    <span class="tag tag-green">Expenses</span>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ════════════════════════════════════════════
     CTA STRIP
═══════════════════════════════════════════ -->
<div class="cta-strip">
    <div class="cta-inner">
        <div class="cta-text">
            <h2>Ready to Take Control of Your Business?</h2>
            <p>Access your personalized ESS dashboard and start making data-driven decisions today.</p>
        </div>
        <a href="/Account/Login" class="btn-primary">
            Access the ESS
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12" />
                <polyline points="12 5 19 12 12 19" />
            </svg>
        </a>
    </div>
</div>
