@model IEnumerable<CRLFruitstandESS.Models.ViewModels.SupplierViewModel>
@{
    ViewData["Title"] = "Suppliers";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h6 class="text-uppercase text-muted mb-1">Supply Chain</h6>
            <h2 class="fw-bold mb-0">Supplier Management</h2>
        </div>
        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
        {
            <a href="/Supplier/Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>Add Supplier
            </a>
        }
    </div>

    <!-- Stats Cards -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card bg-primary bg-opacity-10 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-primary bg-opacity-20 rounded-circle p-3">
                                <i class="bi bi-building text-primary fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="fw-bold mb-0">@Model.Count()</h3>
                            <small class="text-muted">Total Suppliers</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-success bg-opacity-10 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-success bg-opacity-20 rounded-circle p-3">
                                <i class="bi bi-check-circle text-success fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="fw-bold mb-0">@Model.Count(s => s.IsActive)</h3>
                            <small class="text-muted">Active Suppliers</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-info bg-opacity-10 border-0">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-shrink-0">
                            <div class="bg-info bg-opacity-20 rounded-circle p-3">
                                <i class="bi bi-box-seam text-info fs-4"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 ms-3">
                            <h3 class="fw-bold mb-0">@Model.Sum(s => s.ProductCount)</h3>
                            <small class="text-muted">Supplier Products</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Suppliers Table -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="mb-0">All Suppliers</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Supplier Name</th>
                            <th>Contact Person</th>
                            <th>Phone</th>
                            <th>Email</th>
                            <th>City</th>
                            <th>Products</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var supplier in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-info bg-opacity-10 rounded p-2 me-3">
                                            <i class="bi bi-building text-info"></i>
                                        </div>
                                        <div>
                                            <h6 class="mb-0">@supplier.Name</h6>
                                        </div>
                                    </div>
                                </td>
                                <td>@supplier.ContactPerson</td>
                                <td>@supplier.Phone</td>
                                <td>@supplier.Email</td>
                                <td>@supplier.City</td>
                                <td>
                                    <span class="badge bg-secondary">@supplier.ProductCount products</span>
                                </td>
                                <td>
                                    @if (supplier.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group">
                                        <a href="/Supplier/Details/@supplier.Id" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i>
                                        </a>
                                        @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                        {
                                            <a href="/Supplier/Edit/@supplier.Id" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>