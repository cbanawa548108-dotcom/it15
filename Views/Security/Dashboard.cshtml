@{
    ViewData["Title"] = "Security Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";

    var totalToday    = (int)ViewBag.TotalToday;
    var failedToday   = (int)ViewBag.FailedToday;
    var successToday  = (int)ViewBag.SuccessToday;
    var lockedUsers   = (List<CRLFruitstandESS.Models.ApplicationUser>)ViewBag.LockedUsers;
    var inactiveUsers = (List<CRLFruitstandESS.Models.ApplicationUser>)ViewBag.InactiveUsers;
    var recentAttempts= (List<CRLFruitstandESS.Models.LoginAttempt>)ViewBag.RecentAttempts;
    var secHeaders    = (List<(string Name, string Value, string Description)>)ViewBag.SecurityHeaders;
    var dailyStats    = ViewBag.DailyStats as IEnumerable<dynamic>;
    var suspiciousIps = ViewBag.SuspiciousIps as IEnumerable<dynamic>;
}

@section Styles {
<style>
.page-content { background:#0f172a !important; min-height:100vh; }

.sec-header {
    background:linear-gradient(135deg,#1e293b 0%,#0f172a 100%);
    border:1px solid #334155; border-radius:14px;
    padding:2.5rem 2rem; margin-bottom:2rem; position:relative; overflow:hidden;
}
.sec-header::before {
    content:''; position:absolute; top:-60px; right:-60px;
    width:320px; height:320px;
    background:radial-gradient(circle,rgba(239,68,68,.10) 0%,transparent 70%);
    border-radius:50%; pointer-events:none;
}
.sec-header > div { position:relative; z-index:1; }

.dark-card {
    background:#1e293b; border:1px solid #334155; border-radius:14px;
    padding:1.75rem; margin-bottom:1.5rem; transition:border-color .25s;
}
.dark-card:hover { border-color:#475569; }

.section-title {
    font-size:1rem; font-weight:700; color:#f1f5f9;
    display:flex; align-items:center; gap:.6rem; margin:0 0 1.5rem;
}

.stat-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:1.25rem; margin-bottom:1.5rem; }
@@media(max-width:900px){ .stat-grid{ grid-template-columns:repeat(2,1fr); } }

.stat-card {
    background:#0f172a; border:1px solid #334155; border-radius:12px;
    padding:1.25rem 1.5rem;
}
.stat-label { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.09em; color:#475569; margin-bottom:.4rem; }
.stat-value { font-size:2rem; font-weight:800; line-height:1; }
.stat-sub   { font-size:.75rem; color:#64748b; margin-top:.3rem; }

.sec-table { width:100%; border-collapse:collapse; font-size:.875rem; }
.sec-table thead tr { background:#0f172a; }
.sec-table thead th { padding:.875rem 1rem; text-align:left; font-size:.7rem; font-weight:700; text-transform:uppercase; letter-spacing:.08em; color:#475569; border-bottom:1px solid #334155; }
.sec-table tbody tr { border-bottom:1px solid #1e293b; transition:background .15s; }
.sec-table tbody tr:hover { background:#0f172a; }
.sec-table tbody td { padding:.75rem 1rem; color:#cbd5e1; }

.badge {
    display:inline-flex; align-items:center; gap:.3rem;
    padding:.2rem .65rem; border-radius:999px; font-size:.7rem; font-weight:700;
}
.badge-success { background:rgba(16,185,129,.12); color:#34d399; border:1px solid rgba(16,185,129,.3); }
.badge-danger  { background:rgba(239,68,68,.12);  color:#fca5a5; border:1px solid rgba(239,68,68,.3); }
.badge-warning { background:rgba(251,191,36,.12); color:#fbbf24; border:1px solid rgba(251,191,36,.3); }
.badge-info    { background:rgba(99,102,241,.12); color:#a5b4fc; border:1px solid rgba(99,102,241,.3); }

.header-row {
    display:flex; align-items:start; gap:1rem;
    padding:1rem; background:#0f172a; border:1px solid #334155;
    border-radius:8px; margin-bottom:.75rem;
}
.header-name  { font-size:.85rem; font-weight:700; color:#f1f5f9; margin-bottom:.2rem; }
.header-value { font-size:.75rem; color:#6366f1; font-family:monospace; margin-bottom:.3rem; }
.header-desc  { font-size:.78rem; color:#64748b; }
.header-check { color:#34d399; font-size:1.2rem; flex-shrink:0; margin-top:.1rem; }

.two-col { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; }
@@media(max-width:900px){ .two-col{ grid-template-columns:1fr; } }

.unlock-btn {
    padding:.3rem .75rem; border-radius:6px; font-size:.75rem; font-weight:700;
    background:rgba(16,185,129,.15); color:#34d399; border:1px solid rgba(16,185,129,.3);
    cursor:pointer; transition:background .2s;
}
.unlock-btn:hover { background:rgba(16,185,129,.25); }

.deactivate-btn {
    padding:.3rem .75rem; border-radius:6px; font-size:.75rem; font-weight:700;
    background:rgba(239,68,68,.12); color:#fca5a5; border:1px solid rgba(239,68,68,.3);
    cursor:pointer; transition:background .2s;
}
.deactivate-btn:hover { background:rgba(239,68,68,.22); }
</style>
}

<!-- HEADER -->
<div class="sec-header">
    <div>
        <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#ef4444;display:block;margin-bottom:.5rem;">Admin Only</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 .5rem;color:#f1f5f9;">
            <i class="bi bi-shield-lock-fill" style="color:#ef4444;margin-right:.5rem;"></i>Security Dashboard
        </h1>
        <p style="margin:0;font-size:.95rem;color:#94a3b8;">Login activity, account security, and HTTP security headers — @DateTime.Now.ToString("MMM dd, yyyy h:mm tt")</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div style="padding:1rem 1.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:10px;color:#34d399;margin-bottom:1.5rem;display:flex;align-items:center;gap:.75rem;">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}

<!-- STAT CARDS -->
<div class="stat-grid">
    <div class="stat-card" style="border-top:3px solid #6366f1;">
        <div class="stat-label">Total Logins (24h)</div>
        <div class="stat-value" style="color:#a5b4fc;">@totalToday</div>
        <div class="stat-sub">All attempts today</div>
    </div>
    <div class="stat-card" style="border-top:3px solid #34d399;">
        <div class="stat-label">Successful (24h)</div>
        <div class="stat-value" style="color:#34d399;">@successToday</div>
        <div class="stat-sub">Authenticated sessions</div>
    </div>
    <div class="stat-card" style="border-top:3px solid #ef4444;">
        <div class="stat-label">Failed (24h)</div>
        <div class="stat-value" style="color:#fca5a5;">@failedToday</div>
        <div class="stat-sub">Invalid credentials / lockouts</div>
    </div>
    <div class="stat-card" style="border-top:3px solid #fbbf24;">
        <div class="stat-label">Locked Accounts</div>
        <div class="stat-value" style="color:#fbbf24;">@lockedUsers.Count</div>
        <div class="stat-sub">Currently locked out</div>
    </div>
</div>

<div class="two-col">
    <!-- LEFT: Login activity chart + recent attempts -->
    <div>
        <!-- 7-day chart -->
        <div class="dark-card">
            <p class="section-title">
                <i class="bi bi-graph-up" style="color:#6366f1;font-size:1.1rem;"></i>
                Login Activity — Last 7 Days
            </p>
            <canvas id="loginChart" height="120"></canvas>
        </div>

        <!-- Recent login attempts -->
        <div class="dark-card">
            <p class="section-title">
                <i class="bi bi-clock-history" style="color:#f59e0b;font-size:1.1rem;"></i>
                Recent Login Attempts
                <span style="margin-left:auto;font-size:.75rem;color:#475569;">Last 20</span>
            </p>
            @if (recentAttempts.Any())
            {
            <div style="overflow-x:auto;border-radius:10px;border:1px solid #334155;">
                <table class="sec-table">
                    <thead>
                        <tr>
                            <th>Time (UTC)</th>
                            <th>Username</th>
                            <th>IP Address</th>
                            <th>Result</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var a in recentAttempts)
                        {
                            <tr>
                                <td style="color:#64748b;font-size:.8rem;">@a.AttemptedAt.ToString("MMM dd HH:mm:ss")</td>
                                <td style="font-weight:600;color:#f1f5f9;">@a.UserName</td>
                                <td style="font-family:monospace;color:#94a3b8;font-size:.82rem;">@a.IpAddress</td>
                                <td>
                                    @if (a.Succeeded)
                                    {
                                        <span class="badge badge-success"><i class="bi bi-check-circle-fill"></i> Success</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-danger"><i class="bi bi-x-circle-fill"></i> Failed</span>
                                    }
                                </td>
                                <td style="color:#64748b;font-size:.8rem;">
                                    @(string.IsNullOrEmpty(a.FailReason) ? "—" : a.FailReason)
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
            else
            {
                <div style="text-align:center;padding:2rem;color:#475569;">
                    <i class="bi bi-shield-check" style="font-size:2rem;display:block;margin-bottom:.5rem;color:#334155;"></i>
                    No login attempts recorded yet. Attempts will appear here after the first login.
                </div>
            }
        </div>
    </div>

    <!-- RIGHT: Security headers + locked accounts + suspicious IPs -->
    <div>
        <!-- Security Headers -->
        <div class="dark-card">
            <p class="section-title">
                <i class="bi bi-shield-fill-check" style="color:#34d399;font-size:1.1rem;"></i>
                HTTP Security Headers
                <span class="badge badge-success" style="margin-left:auto;">
                    <i class="bi bi-check-circle-fill"></i> All Active
                </span>
            </p>
            @foreach (var (name, value, desc) in secHeaders)
            {
                <div class="header-row">
                    <i class="bi bi-check-circle-fill header-check"></i>
                    <div>
                        <div class="header-name">@name</div>
                        <div class="header-value">@value</div>
                        <div class="header-desc">@desc</div>
                    </div>
                </div>
            }
        </div>

        <!-- Locked Accounts -->
        <div class="dark-card">
            <p class="section-title">
                <i class="bi bi-lock-fill" style="color:#fbbf24;font-size:1.1rem;"></i>
                Locked Accounts
                @if (lockedUsers.Any())
                {
                    <span class="badge badge-warning" style="margin-left:auto;">@lockedUsers.Count locked</span>
                }
                else
                {
                    <span class="badge badge-success" style="margin-left:auto;">None</span>
                }
            </p>
            @if (lockedUsers.Any())
            {
                <div style="overflow-x:auto;border-radius:10px;border:1px solid #334155;">
                    <table class="sec-table">
                        <thead><tr><th>User</th><th>Locked Until</th><th>Action</th></tr></thead>
                        <tbody>
                            @foreach (var u in lockedUsers)
                            {
                                <tr>
                                    <td>
                                        <div style="font-weight:600;color:#f1f5f9;">@u.UserName</div>
                                        <div style="font-size:.75rem;color:#475569;">@u.FullName</div>
                                    </td>
                                    <td style="color:#fbbf24;font-size:.82rem;">
                                        @u.LockoutEnd?.ToString("MMM dd HH:mm UTC")
                                    </td>
                                    <td>
                                        <form asp-action="UnlockUser" asp-controller="Security" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@u.Id" />
                                            <button type="submit" class="unlock-btn">
                                                <i class="bi bi-unlock-fill"></i> Unlock
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <p style="color:#475569;font-size:.875rem;margin:0;">No accounts are currently locked out.</p>
            }
        </div>

        <!-- Suspicious IPs -->
        @if (suspiciousIps != null && ((IEnumerable<dynamic>)suspiciousIps).Any())
        {
        <div class="dark-card">
            <p class="section-title">
                <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;font-size:1.1rem;"></i>
                Suspicious IPs (24h)
                <span style="margin-left:auto;font-size:.75rem;color:#475569;">By failed attempts</span>
            </p>
            <div style="overflow-x:auto;border-radius:10px;border:1px solid #334155;">
                <table class="sec-table">
                    <thead><tr><th>IP Address</th><th>Failed Attempts</th><th>Last Seen</th></tr></thead>
                    <tbody>
                        @foreach (var ip in suspiciousIps)
                        {
                            <tr>
                                <td style="font-family:monospace;color:#fca5a5;">@ip.Ip</td>
                                <td>
                                    <span class="badge badge-danger">@ip.Count attempts</span>
                                </td>
                                <td style="color:#64748b;font-size:.8rem;">@((DateTime)ip.LastSeen).ToString("HH:mm:ss UTC")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        }

        <!-- Inactive Accounts -->
        @if (inactiveUsers.Any())
        {
        <div class="dark-card">
            <p class="section-title">
                <i class="bi bi-person-slash" style="color:#94a3b8;font-size:1.1rem;"></i>
                Deactivated Accounts
                <span class="badge badge-info" style="margin-left:auto;">@inactiveUsers.Count</span>
            </p>
            <div style="overflow-x:auto;border-radius:10px;border:1px solid #334155;">
                <table class="sec-table">
                    <thead><tr><th>User</th><th>Department</th><th>Action</th></tr></thead>
                    <tbody>
                        @foreach (var u in inactiveUsers)
                        {
                            <tr>
                                <td>
                                    <div style="font-weight:600;color:#f1f5f9;">@u.UserName</div>
                                    <div style="font-size:.75rem;color:#475569;">@u.FullName</div>
                                </td>
                                <td style="color:#64748b;">@u.Department</td>
                                <td>
                                    <form asp-action="ToggleActive" asp-controller="Security" method="post" style="display:inline;">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.Id" />
                                        <button type="submit" class="unlock-btn">
                                            <i class="bi bi-person-check-fill"></i> Reactivate
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
        }
    </div>
</div>

<!-- HOW IT WORKS -->
<div class="dark-card">
    <p class="section-title">
        <i class="bi bi-info-circle-fill" style="color:#6366f1;font-size:1.1rem;"></i>
        How the Security Features Work
    </p>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.25rem;">
        <div style="background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;">
            <div style="font-size:1.5rem;margin-bottom:.75rem;">🔐</div>
            <h5 style="color:#f1f5f9;margin:0 0 .5rem;font-size:.9rem;">Account Lockout</h5>
            <p style="color:#64748b;font-size:.82rem;margin:0;line-height:1.6;">After <strong style="color:#f1f5f9;">5 failed login attempts</strong>, the account is locked for <strong style="color:#f1f5f9;">15 minutes</strong>. This is enforced by ASP.NET Identity and applies per username.</p>
        </div>
        <div style="background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;">
            <div style="font-size:1.5rem;margin-bottom:.75rem;">🚦</div>
            <h5 style="color:#f1f5f9;margin:0 0 .5rem;font-size:.9rem;">IP Rate Limiting</h5>
            <p style="color:#64748b;font-size:.82rem;margin:0;line-height:1.6;">After <strong style="color:#f1f5f9;">10 failed attempts</strong> from the same IP within 10 minutes, that IP is blocked for <strong style="color:#f1f5f9;">10 minutes</strong>. Protects against credential-stuffing attacks that rotate usernames.</p>
        </div>
        <div style="background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;">
            <div style="font-size:1.5rem;margin-bottom:.75rem;">🛡️</div>
            <h5 style="color:#f1f5f9;margin:0 0 .5rem;font-size:.9rem;">Security Headers</h5>
            <p style="color:#64748b;font-size:.82rem;margin:0;line-height:1.6;"><strong style="color:#f1f5f9;">6 HTTP headers</strong> are injected on every response: X-Frame-Options prevents clickjacking, CSP blocks XSS, X-Content-Type-Options stops MIME sniffing, and more.</p>
        </div>
        <div style="background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;">
            <div style="font-size:1.5rem;margin-bottom:.75rem;">📋</div>
            <h5 style="color:#f1f5f9;margin:0 0 .5rem;font-size:.9rem;">Login Audit Trail</h5>
            <p style="color:#64748b;font-size:.82rem;margin:0;line-height:1.6;">Every login attempt — success or failure — is recorded with <strong style="color:#f1f5f9;">username, IP address, browser, timestamp, and failure reason</strong>. Stored in the database for compliance review.</p>
        </div>
        <div style="background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;">
            <div style="font-size:1.5rem;margin-bottom:.75rem;">🍪</div>
            <h5 style="color:#f1f5f9;margin:0 0 .5rem;font-size:.9rem;">Secure Session Cookies</h5>
            <p style="color:#64748b;font-size:.82rem;margin:0;line-height:1.6;">Auth cookies are <strong style="color:#f1f5f9;">HttpOnly</strong> (no JS access), <strong style="color:#f1f5f9;">Secure</strong> (HTTPS only), expire after <strong style="color:#f1f5f9;">8 hours</strong> with sliding renewal. Prevents XSS cookie theft.</p>
        </div>
        <div style="background:#0f172a;border:1px solid #334155;border-radius:10px;padding:1.25rem;">
            <div style="font-size:1.5rem;margin-bottom:.75rem;">🔑</div>
            <h5 style="color:#f1f5f9;margin:0 0 .5rem;font-size:.9rem;">Role-Based Access Control</h5>
            <p style="color:#64748b;font-size:.82rem;margin:0;line-height:1.6;">Every controller and API endpoint is protected with <strong style="color:#f1f5f9;">[Authorize(Roles="...")]</strong>. Users are redirected to their role-specific dashboard and cannot access other modules.</p>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
Chart.defaults.color = '#475569';
Chart.defaults.borderColor = 'rgba(255,255,255,.04)';

const stats = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
    ((IEnumerable<dynamic>)ViewBag.DailyStats).Select(d => new {
        label   = (string)d.Label,
        success = (int)d.Success,
        failed  = (int)d.Failed
    }).ToList()
));

new Chart(document.getElementById('loginChart').getContext('2d'), {
    type: 'bar',
    data: {
        labels: stats.map(d => d.label),
        datasets: [
            {
                label: 'Successful',
                data: stats.map(d => d.success),
                backgroundColor: 'rgba(16,185,129,.7)',
                borderColor: '#10b981',
                borderWidth: 1,
                borderRadius: 4
            },
            {
                label: 'Failed',
                data: stats.map(d => d.failed),
                backgroundColor: 'rgba(239,68,68,.6)',
                borderColor: '#ef4444',
                borderWidth: 1,
                borderRadius: 4
            }
        ]
    },
    options: {
        responsive: true,
        plugins: {
            legend: { labels: { color: '#64748b', usePointStyle: true } },
            tooltip: {
                backgroundColor: '#0d1526',
                borderColor: 'rgba(99,102,241,.3)',
                borderWidth: 1,
                titleColor: '#f1f5f9',
                bodyColor: '#94a3b8',
                padding: 10
            }
        },
        scales: {
            x: { ticks: { color: '#334155' }, grid: { color: 'rgba(255,255,255,.03)' }, stacked: false },
            y: { ticks: { color: '#334155', stepSize: 1 }, grid: { color: 'rgba(255,255,255,.03)' }, beginAtZero: true }
        }
    }
});
</script>
}
