@model CRLFruitstandESS.Models.ViewModels.CfoDashboardViewModel
@{
    ViewData["Title"] = "CFO Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="dash-header">
    <div>
        <span class="dash-label">Finance Command</span>
        <h1 class="dash-title">CFO Dashboard</h1>
        <p class="dash-sub">Welcome back, @Model.FullName — @DateTime.Now.ToString("MMMM dd, yyyy")</p>
    </div>
    <div class="dash-badge cfo-badge">CFO</div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert-success">✅ @TempData["Success"]</div>
}

<!-- KPI CARDS -->
<div class="stats-grid four-col">
    <div class="stat-card">
        <div class="stat-icon si-green">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">₱@Model.TodayRevenue.ToString("N2")</div>
            <div class="stat-label">Today's Revenue</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon si-red">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4"/><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">₱@Model.TodayExpenses.ToString("N2")</div>
            <div class="stat-label">Today's Expenses</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon @(Model.TodayNetProfit >= 0 ? "si-green" : "si-red")">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value @(Model.TodayNetProfit >= 0 ? "text-profit" : "text-loss")">₱@Model.TodayNetProfit.ToString("N2")</div>
            <div class="stat-label">Today's Net Profit</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon si-blue">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        </div>
        <div class="stat-info">
            <div class="stat-value">@Model.MonthGrossMargin.ToString("N1")%</div>
            <div class="stat-label">Gross Margin</div>
        </div>
    </div>
</div>

<!-- MONTHLY SUMMARY -->
<div class="cfo-grid-2" style="margin-bottom:1.5rem;">
    <div class="cfo-card">
        <div class="cfo-card-header">
            <h3>Monthly Summary — @DateTime.Now.ToString("MMMM yyyy")</h3>
        </div>
        <div class="cfo-card-body">
            <div class="summary-row">
                <span>Total Revenue</span>
                <span class="text-profit">₱@Model.MonthRevenue.ToString("N2")</span>
            </div>
            <div class="summary-row">
                <span>Total Expenses</span>
                <span class="text-loss">₱@Model.MonthExpenses.ToString("N2")</span>
            </div>
            <div class="summary-divider"></div>
            <div class="summary-row summary-total">
                <span>Net Profit</span>
                <span class="@(Model.MonthNetProfit >= 0 ? "text-profit" : "text-loss")">
                    ₱@Model.MonthNetProfit.ToString("N2")
                </span>
            </div>
            <div class="progress-wrap" style="margin-top:1rem;">
                <div class="progress-label">
                    <span>Budget Utilization</span>
                    <span>@Model.BudgetUtilizationPercent.ToString("N1")%</span>
                </div>
                <div class="progress-bar-bg">
                    <div class="progress-bar-fill @(Model.BudgetUtilizationPercent > 90 ? "fill-red" : Model.BudgetUtilizationPercent > 70 ? "fill-gold" : "fill-green")"
                         style="width:@(Math.Min(Model.BudgetUtilizationPercent, 100))%"></div>
                </div>
                <div style="font-size:.75rem;color:var(--text-muted);margin-top:4px;">
                    ₱@Model.TotalBudgetSpent.ToString("N2") of ₱@Model.TotalBudgetAllocated.ToString("N2") allocated
                </div>
            </div>
        </div>
    </div>

    <!-- Quick actions -->
    <div class="cfo-card">
        <div class="cfo-card-header"><h3>Quick Actions</h3></div>
        <div class="cfo-card-body">
            <div class="quick-action-list">
                <a href="/CfoDashboard/AddRevenue" class="qa-item qa-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Record Revenue
                </a>
                <a href="/CfoDashboard/AddExpense" class="qa-item qa-red">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/></svg>
                    Record Expense
                </a>
                <a href="/CfoDashboard/AddBudget" class="qa-item qa-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/></svg>
                    Create Budget
                </a>
                <a href="/CfoDashboard/Reports" class="qa-item qa-gold">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
                    View Reports
                </a>
                <a href="/CfoDashboard/ExportPdf" class="qa-item qa-purple">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Export PDF
                </a>
                <a href="/CfoDashboard/ExportExcel" class="qa-item qa-green">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    Export Excel
                </a>
            </div>
        </div>
    </div>
</div>

<!-- CHARTS ROW -->
<div class="cfo-grid-2" style="margin-bottom:1.5rem;">
    <div class="cfo-card">
        <div class="cfo-card-header"><h3>7-Day Revenue vs Expenses</h3></div>
        <div class="cfo-card-body"><canvas id="weeklyChart" height="220"></canvas></div>
    </div>
    <div class="cfo-card">
        <div class="cfo-card-header"><h3>6-Month Net Profit Trend</h3></div>
        <div class="cfo-card-body"><canvas id="trendChart" height="220"></canvas></div>
    </div>
</div>

<div class="cfo-grid-2" style="margin-bottom:1.5rem;">
    <div class="cfo-card">
        <div class="cfo-card-header"><h3>Expense Breakdown (This Month)</h3></div>
        <div class="cfo-card-body" style="display:flex;align-items:center;gap:2rem;flex-wrap:wrap;">
            <canvas id="pieChart" width="200" height="200" style="max-width:200px;"></canvas>
            <div class="pie-legend" id="pieLegend"></div>
        </div>
    </div>
    <div class="cfo-card">
        <div class="cfo-card-header">
            <h3>Active Budgets</h3>
            <a href="/CfoDashboard/Budget" class="cfo-card-link">View All</a>
        </div>
        <div class="cfo-card-body">
            @if (!Model.ActiveBudgets.Any())
            {
                <p style="color:var(--text-muted);font-size:.9rem;">No budgets set for this month.</p>
            }
            @foreach (var b in Model.ActiveBudgets)
            {
                <div style="margin-bottom:1rem;">
                    <div class="progress-label">
                        <span style="font-size:.85rem;font-weight:600;color:var(--white);">@b.Category</span>
                        <span style="font-size:.8rem;color:var(--text-muted);">₱@b.SpentAmount.ToString("N2") / ₱@b.AllocatedAmount.ToString("N2")</span>
                    </div>
                    <div class="progress-bar-bg" style="margin-top:4px;">
                        <div class="progress-bar-fill @(b.UtilizationPercent > 90 ? "fill-red" : b.UtilizationPercent > 70 ? "fill-gold" : "fill-green")"
                             style="width:@(Math.Min(b.UtilizationPercent, 100))%"></div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- RECENT TRANSACTIONS -->
<div class="cfo-grid-2">
    <div class="cfo-card">
        <div class="cfo-card-header">
            <h3>Recent Revenue</h3>
            <a href="/CfoDashboard/Revenue" class="cfo-card-link">View All</a>
        </div>
        <div class="cfo-card-body">
            <table class="cfo-table">
                <thead><tr><th>Date</th><th>Source</th><th>Amount</th></tr></thead>
                <tbody>
                    @foreach (var r in Model.RecentRevenues)
                    {
                        <tr>
                            <td>@r.TransactionDate.ToString("MMM dd")</td>
                            <td>@r.Source</td>
                            <td class="text-profit">₱@r.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="cfo-card">
        <div class="cfo-card-header">
            <h3>Recent Expenses</h3>
            <a href="/CfoDashboard/Expenses" class="cfo-card-link">View All</a>
        </div>
        <div class="cfo-card-body">
            <table class="cfo-table">
                <thead><tr><th>Date</th><th>Description</th><th>Amount</th></tr></thead>
                <tbody>
                    @foreach (var e in Model.RecentExpenses)
                    {
                        <tr>
                            <td>@e.ExpenseDate.ToString("MMM dd")</td>
                            <td>@e.Description</td>
                            <td class="text-loss">₱@e.Amount.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
const weeklyRev  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyRevenue.Select(x => x.Value)));
const weeklyExp  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyExpenses.Select(x => x.Value)));
const weeklyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.WeeklyRevenue.Select(x => x.Label)));
const trendData  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(x => x.Value)));
const trendLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MonthlyTrend.Select(x => x.Label)));
const pieData    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExpenseBreakdown.Select(x => x.Value)));
const pieLabels  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExpenseBreakdown.Select(x => x.Label)));
const pieColors  = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ExpenseBreakdown.Select(x => x.Color)));

const chartDefaults = {
    responsive: true,
    plugins: { legend: { labels: { color: '#8fadd8', font: { size: 11 } } } },
    scales: {
        x: { ticks: { color: '#8fadd8' }, grid: { color: 'rgba(93,164,245,0.08)' } },
        y: { ticks: { color: '#8fadd8' }, grid: { color: 'rgba(93,164,245,0.08)' } }
    }
};

// Weekly Bar Chart
new Chart(document.getElementById('weeklyChart'), {
    type: 'bar',
    data: {
        labels: weeklyLabels,
        datasets: [
            { label: 'Revenue', data: weeklyRev, backgroundColor: 'rgba(69,200,150,0.7)', borderRadius: 6 },
            { label: 'Expenses', data: weeklyExp, backgroundColor: 'rgba(248,113,113,0.7)', borderRadius: 6 }
        ]
    },
    options: { ...chartDefaults, plugins: { ...chartDefaults.plugins } }
});

// Monthly Trend Line
new Chart(document.getElementById('trendChart'), {
    type: 'line',
    data: {
        labels: trendLabels,
        datasets: [{
            label: 'Net Profit',
            data: trendData,
            borderColor: '#2d7ef7',
            backgroundColor: 'rgba(45,126,247,0.1)',
            fill: true,
            tension: 0.4,
            pointBackgroundColor: '#2d7ef7',
            pointRadius: 5
        }]
    },
    options: chartDefaults
});

// Pie Chart
if (pieData.length > 0) {
    new Chart(document.getElementById('pieChart'), {
        type: 'doughnut',
        data: {
            labels: pieLabels,
            datasets: [{ data: pieData, backgroundColor: pieColors, borderWidth: 0 }]
        },
        options: {
            responsive: false,
            plugins: { legend: { display: false } },
            cutout: '65%'
        }
    });

    const legend = document.getElementById('pieLegend');
    pieLabels.forEach((label, i) => {
        legend.innerHTML += `<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px;">
            <div style="width:10px;height:10px;border-radius:50%;background:${pieColors[i]};flex-shrink:0;"></div>
            <span style="font-size:.8rem;color:#8fadd8;">${label}</span>
            <span style="font-size:.8rem;color:white;margin-left:auto;">₱${parseFloat(pieData[i]).toLocaleString('en-PH', {minimumFractionDigits:2})}</span>
        </div>`;
    });
}
</script>
}