@model CRLFruitstandESS.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

@section Styles {
<style>
/* ═══════════════════════════════════════════════
   ADMIN DASHBOARD — MAJESTIC DARK DESIGN
═══════════════════════════════════════════════ */
.page-content {
    background: #060b14 !important;
    min-height: 100vh;
}

/* Ambient mesh background */
.page-content::before {
    content: '';
    position: fixed; inset: 0; z-index: 0; pointer-events: none;
    background:
        radial-gradient(ellipse 70% 50% at 15% 10%, rgba(59,130,246,.07) 0%, transparent 60%),
        radial-gradient(ellipse 50% 40% at 85% 80%, rgba(139,92,246,.06) 0%, transparent 60%);
}
.page-content > * { position: relative; z-index: 1; }

/* ── HERO ── */
.admin-hero {
    background: linear-gradient(135deg, #0f1f3d 0%, #060b14 100%);
    border: 1px solid rgba(59,130,246,.2);
    border-radius: 18px;
    padding: 2.5rem 2.5rem;
    margin-bottom: 2rem;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    box-shadow: 0 0 60px rgba(59,130,246,.08), inset 0 1px 0 rgba(255,255,255,.05);
}
.admin-hero::before {
    content: '';
    position: absolute; top: -100px; right: -100px;
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(99,102,241,.15) 0%, transparent 65%);
    border-radius: 50%; pointer-events: none;
}
.admin-hero::after {
    content: '';
    position: absolute; bottom: -60px; left: 30%;
    width: 300px; height: 200px;
    background: radial-gradient(ellipse, rgba(16,185,129,.06) 0%, transparent 70%);
    pointer-events: none;
}
.admin-hero > div { position: relative; z-index: 1; }

.hero-badge {
    display: inline-flex; align-items: center; gap: .5rem;
    padding: .6rem 1.5rem; border-radius: 999px;
    background: linear-gradient(135deg, rgba(99,102,241,.2), rgba(139,92,246,.15));
    border: 1px solid rgba(99,102,241,.4);
    color: #a5b4fc; font-size: .72rem; font-weight: 800;
    text-transform: uppercase; letter-spacing: .14em; flex-shrink: 0;
    box-shadow: 0 0 20px rgba(99,102,241,.2);
}

/* ── KPI STRIP ── */
.kpi-strip {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 1px;
    background: rgba(255,255,255,.04);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,.06);
    margin-bottom: 2rem;
    box-shadow: 0 4px 24px rgba(0,0,0,.3);
}

.kpi-cell {
    background: rgba(8,14,26,.9);
    padding: 1.5rem 1.25rem;
    position: relative;
    overflow: hidden;
    transition: background .25s, transform .2s;
    cursor: default;
}
.kpi-cell:hover { background: rgba(15,25,45,.95); }

/* Glowing top bar */
.kpi-cell::before {
    content: '';
    position: absolute; top: 0; left: 0; right: 0; height: 3px;
    opacity: .7;
    transition: opacity .3s, height .3s;
}
.kpi-cell:hover::before { opacity: 1; height: 3px; }

/* Subtle glow orb */
.kpi-cell::after {
    content: '';
    position: absolute; top: -20px; right: -20px;
    width: 80px; height: 80px;
    border-radius: 50%;
    opacity: 0;
    transition: opacity .3s;
}
.kpi-cell:hover::after { opacity: 1; }

.kpi-cell.c-blue::before   { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
.kpi-cell.c-blue::after    { background: radial-gradient(circle, rgba(59,130,246,.2), transparent); }
.kpi-cell.c-amber::before  { background: linear-gradient(90deg, #f59e0b, #fbbf24); }
.kpi-cell.c-amber::after   { background: radial-gradient(circle, rgba(245,158,11,.2), transparent); }
.kpi-cell.c-green::before  { background: linear-gradient(90deg, #10b981, #34d399); }
.kpi-cell.c-green::after   { background: radial-gradient(circle, rgba(16,185,129,.2), transparent); }
.kpi-cell.c-red::before    { background: linear-gradient(90deg, #ef4444, #f87171); }
.kpi-cell.c-red::after     { background: radial-gradient(circle, rgba(239,68,68,.2), transparent); }
.kpi-cell.c-purple::before { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }
.kpi-cell.c-purple::after  { background: radial-gradient(circle, rgba(139,92,246,.2), transparent); }
.kpi-cell.c-teal::before   { background: linear-gradient(90deg, #06b6d4, #22d3ee); }
.kpi-cell.c-teal::after    { background: radial-gradient(circle, rgba(6,182,212,.2), transparent); }

.kc-label { font-size: .65rem; font-weight: 800; text-transform: uppercase; letter-spacing: .1em; color: #334155; margin-bottom: .6rem; }
.kc-value { font-size: 1.6rem; font-weight: 900; line-height: 1; margin-bottom: .35rem; letter-spacing: -.02em; }
.kc-sub   { font-size: .72rem; color: #1e3a5f; font-weight: 500; }

.kpi-cell.c-blue   .kc-value { color: #60a5fa; text-shadow: 0 0 20px rgba(59,130,246,.4); }
.kpi-cell.c-amber  .kc-value { color: #fbbf24; text-shadow: 0 0 20px rgba(245,158,11,.4); }
.kpi-cell.c-green  .kc-value { color: #34d399; text-shadow: 0 0 20px rgba(16,185,129,.4); }
.kpi-cell.c-red    .kc-value { color: #fca5a5; text-shadow: 0 0 20px rgba(239,68,68,.4); }
.kpi-cell.c-purple .kc-value { color: #a78bfa; text-shadow: 0 0 20px rgba(139,92,246,.4); }
.kpi-cell.c-teal   .kc-value { color: #22d3ee; text-shadow: 0 0 20px rgba(6,182,212,.4); }

/* ── DARK CARD ── */
.dark-card {
    background: linear-gradient(135deg, rgba(15,23,42,.95) 0%, rgba(10,16,28,.9) 100%);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
    box-shadow: 0 4px 24px rgba(0,0,0,.3), inset 0 1px 0 rgba(255,255,255,.04);
    transition: border-color .25s, box-shadow .25s;
}
.dark-card:hover {
    border-color: rgba(99,102,241,.2);
    box-shadow: 0 8px 40px rgba(0,0,0,.4), 0 0 0 1px rgba(99,102,241,.08);
}

.section-title {
    font-size: 1rem; font-weight: 700; color: #f1f5f9;
    display: flex; align-items: center; gap: .6rem; margin: 0 0 1.5rem;
}

/* ── ALERTS ── */
.alert-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.25rem;
    margin-bottom: 1.5rem;
}
.alert-tile {
    padding: 1.25rem 1.5rem; border-radius: 14px;
    display: flex; align-items: start; gap: 1rem;
    transition: transform .2s, box-shadow .2s;
    backdrop-filter: blur(8px);
}
.alert-tile:hover { transform: translateX(4px); box-shadow: 0 8px 24px rgba(0,0,0,.3); }
.alert-tile.danger {
    background: linear-gradient(135deg, rgba(239,68,68,.12), rgba(239,68,68,.06));
    border: 1px solid rgba(239,68,68,.3); border-left: 4px solid #ef4444;
}
.alert-tile.info {
    background: linear-gradient(135deg, rgba(59,130,246,.12), rgba(59,130,246,.06));
    border: 1px solid rgba(59,130,246,.3); border-left: 4px solid #3b82f6;
}
.alert-tile.warn {
    background: linear-gradient(135deg, rgba(245,158,11,.12), rgba(245,158,11,.06));
    border: 1px solid rgba(245,158,11,.3); border-left: 4px solid #f59e0b;
}
.alert-tile .ai { font-size: 1.4rem; flex-shrink: 0; margin-top: 2px; }
.alert-tile.danger .ai { color: #ef4444; filter: drop-shadow(0 0 6px rgba(239,68,68,.5)); }
.alert-tile.info   .ai { color: #3b82f6; filter: drop-shadow(0 0 6px rgba(59,130,246,.5)); }
.alert-tile.warn   .ai { color: #f59e0b; filter: drop-shadow(0 0 6px rgba(245,158,11,.5)); }
.alert-tile h5 { margin: 0 0 .3rem; color: #f1f5f9; font-size: .9rem; font-weight: 700; }
.alert-tile p  { margin: 0 0 .75rem; color: #94a3b8; font-size: .82rem; line-height: 1.5; }
.alert-link { color: #60a5fa; font-size: .8rem; font-weight: 700; text-decoration: none; transition: color .2s; }
.alert-link:hover { color: #93c5fd; }

/* ── ACTION TILES ── */
.actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: .875rem;
}

.action-tile {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    gap: .6rem; padding: 1.4rem 1rem; border-radius: 14px;
    text-decoration: none; font-size: .82rem; font-weight: 700;
    border: 1px solid rgba(255,255,255,.07);
    background: rgba(255,255,255,.03);
    color: #64748b;
    transition: all .25s cubic-bezier(.4,0,.2,1);
    outline: none;
    position: relative;
    overflow: hidden;
}
.action-tile::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.05) 0%, transparent 60%);
    opacity: 0; transition: opacity .25s;
}
.action-tile:hover::before { opacity: 1; }
.action-tile:hover {
    color: #f1f5f9;
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(0,0,0,.4);
}
.action-tile:active { transform: scale(.97) translateY(-2px); }
.action-tile i {
    font-size: 1.6rem;
    transition: transform .25s, filter .25s;
}
.action-tile:hover i { transform: scale(1.2); }

.action-tile.t-blue:hover   { border-color: rgba(59,130,246,.5);  background: rgba(59,130,246,.1);  box-shadow: 0 12px 32px rgba(59,130,246,.2); }
.action-tile.t-blue:hover i { filter: drop-shadow(0 0 8px rgba(59,130,246,.7)); }
.action-tile.t-purple:hover   { border-color: rgba(139,92,246,.5);  background: rgba(139,92,246,.1);  box-shadow: 0 12px 32px rgba(139,92,246,.2); }
.action-tile.t-purple:hover i { filter: drop-shadow(0 0 8px rgba(139,92,246,.7)); }
.action-tile.t-green:hover   { border-color: rgba(16,185,129,.5);  background: rgba(16,185,129,.1);  box-shadow: 0 12px 32px rgba(16,185,129,.2); }
.action-tile.t-green:hover i { filter: drop-shadow(0 0 8px rgba(16,185,129,.7)); }
.action-tile.t-amber:hover   { border-color: rgba(245,158,11,.5);  background: rgba(245,158,11,.1);  box-shadow: 0 12px 32px rgba(245,158,11,.2); }
.action-tile.t-amber:hover i { filter: drop-shadow(0 0 8px rgba(245,158,11,.7)); }
.action-tile.t-gold:hover    { border-color: rgba(251,191,36,.5);  background: rgba(251,191,36,.1);  box-shadow: 0 12px 32px rgba(251,191,36,.2); }
.action-tile.t-gold:hover i  { filter: drop-shadow(0 0 8px rgba(251,191,36,.7)); }
.action-tile.t-red:hover     { border-color: rgba(239,68,68,.5);   background: rgba(239,68,68,.1);   box-shadow: 0 12px 32px rgba(239,68,68,.2); }
.action-tile.t-red:hover i   { filter: drop-shadow(0 0 8px rgba(239,68,68,.7)); }
.action-tile.t-teal:hover    { border-color: rgba(6,182,212,.5);   background: rgba(6,182,212,.1);   box-shadow: 0 12px 32px rgba(6,182,212,.2); }
.action-tile.t-teal:hover i  { filter: drop-shadow(0 0 8px rgba(6,182,212,.7)); }

/* ── PRODUCT ROWS ── */
.product-row {
    display: flex; align-items: center; gap: 1.25rem;
    padding: 1rem 1.25rem;
    background: rgba(255,255,255,.02);
    border: 1px solid rgba(255,255,255,.06);
    border-radius: 12px;
    margin-bottom: .625rem;
    transition: all .2s;
}
.product-row:hover {
    background: rgba(99,102,241,.06);
    border-color: rgba(99,102,241,.2);
    transform: translateX(4px);
    box-shadow: 0 4px 16px rgba(0,0,0,.2);
}

.rank-badge {
    width: 34px; height: 34px; border-radius: 10px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-weight: 900; font-size: .85rem;
    background: rgba(99,102,241,.15); color: #818cf8;
    border: 1px solid rgba(99,102,241,.2);
}
.rank-badge.r1 {
    background: linear-gradient(135deg, rgba(251,191,36,.2), rgba(245,158,11,.1));
    color: #fbbf24; border-color: rgba(251,191,36,.3);
    box-shadow: 0 0 12px rgba(251,191,36,.2);
}
.rank-badge.r2 {
    background: rgba(148,163,184,.12); color: #94a3b8;
    border-color: rgba(148,163,184,.2);
}
.rank-badge.r3 {
    background: rgba(180,83,9,.15); color: #d97706;
    border-color: rgba(180,83,9,.25);
}

/* ── STOCK TILES ── */
.stock-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: .875rem; }
.stock-tile {
    background: rgba(255,255,255,.02);
    border: 1px solid rgba(255,255,255,.07);
    border-radius: 12px;
    padding: 1.25rem;
    text-align: center;
    transition: all .2s;
    position: relative;
    overflow: hidden;
}
.stock-tile::before {
    content: '';
    position: absolute; inset: 0;
    background: linear-gradient(135deg, rgba(255,255,255,.03) 0%, transparent 60%);
}
.stock-tile:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,.3);
}
.stock-tile .sv {
    font-size: 2.25rem; font-weight: 900; line-height: 1;
    margin-bottom: .35rem; letter-spacing: -.03em;
}
.stock-tile .sl {
    font-size: .65rem; font-weight: 800; text-transform: uppercase;
    letter-spacing: .1em; color: #334155;
}

/* ── ENTRANCE ANIMATION ── */
@@keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
}
.admin-hero, .kpi-strip, .alert-row, .dark-card {
    animation: fadeUp .5s ease both;
}
.kpi-strip    { animation-delay: .05s; }
.alert-row    { animation-delay: .1s; }
.dark-card:nth-of-type(1) { animation-delay: .15s; }
.dark-card:nth-of-type(2) { animation-delay: .2s; }
</style>
}

<!-- HERO -->
<div class="admin-hero">
    <div>
        <span style="font-size:.72rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#3b82f6;display:block;margin-bottom:.5rem;">System Administration</span>
        <h1 style="font-size:2.25rem;font-weight:800;margin:0 0 .4rem;color:#f1f5f9;">Admin Dashboard</h1>
        <p style="margin:0;font-size:.95rem;color:#64748b;">Welcome back, <strong style="color:#e2e8f0;">@Model.FullName</strong> &mdash; @DateTime.Now.ToString("MMMM dd, yyyy")</p>
    </div>
    <div class="hero-badge"><i class="bi bi-shield-check"></i> Administrator</div>
</div>

<!-- KPI STRIP -->
<div class="kpi-strip">
    <div class="kpi-cell c-blue">
        <div class="kc-label">Today's Revenue</div>
        <div class="kc-value">₱@Model.TodaysRevenue.ToString("N0")</div>
        <div class="kc-sub">@Model.TodaysTransactions transactions</div>
    </div>
    <div class="kpi-cell c-amber">
        <div class="kc-label">Total Products</div>
        <div class="kc-value">@Model.TotalProducts</div>
        <div class="kc-sub">Active SKUs</div>
    </div>
    <div class="kpi-cell c-green">
        <div class="kc-label">Stock Items</div>
        <div class="kc-value">@Model.TotalStockItems</div>
        <div class="kc-sub">Total units</div>
    </div>
    <div class="kpi-cell c-red">
        <div class="kc-label">Payables</div>
        <div class="kc-value">₱@Model.TotalOutstandingPayables.ToString("N0")</div>
        <div class="kc-sub">@Model.SuppliersWithBalanceDue suppliers</div>
    </div>
    <div class="kpi-cell c-purple">
        <div class="kc-label">Low Stock</div>
        <div class="kc-value">@Model.LowStockCount</div>
        <div class="kc-sub">Need reorder</div>
    </div>
    <div class="kpi-cell c-teal">
        <div class="kc-label">Critical Stock</div>
        <div class="kc-value">@(Model.CriticalStockCount + Model.OutOfStockCount)</div>
        <div class="kc-sub">@Model.OutOfStockCount out of stock</div>
    </div>
</div>

<!-- ALERTS -->
@if (Model.Alerts?.Any() == true)
{
    <div class="alert-row">
        @foreach (var alert in Model.Alerts)
        {
            var cls = alert.Type == "danger" ? "danger" : alert.Type == "info" ? "info" : "warn";
            var icon = alert.Type == "danger" ? "bi-exclamation-octagon-fill" : alert.Type == "info" ? "bi-info-circle-fill" : "bi-exclamation-triangle-fill";
            <div class="alert-tile @cls">
                <i class="bi @icon ai"></i>
                <div>
                    <h5>@alert.Title</h5>
                    <p>@alert.Message</p>
                    @if (!string.IsNullOrEmpty(alert.ActionUrl))
                    {
                        <a href="@alert.ActionUrl" class="alert-link">@alert.ActionText →</a>
                    }
                </div>
            </div>
        }
    </div>
}

<!-- QUICK ACTIONS + STOCK STATUS -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:1.5rem;margin-bottom:1.5rem;">
    <div class="dark-card" style="margin-bottom:0;">
        <p class="section-title"><i class="bi bi-lightning-fill" style="color:#f59e0b;font-size:1.2rem;"></i> Quick Actions</p>
        <div class="actions-grid">
            <a href="/AdminDashboard/Users" class="action-tile t-blue"><i class="bi bi-people-fill" style="color:#60a5fa;"></i>Users</a>
            <a href="/AdminDashboard/Roles" class="action-tile t-purple"><i class="bi bi-shield-fill" style="color:#a78bfa;"></i>Roles</a>
            <a href="/Inventory/Index" class="action-tile t-green"><i class="bi bi-box-seam-fill" style="color:#34d399;"></i>Inventory</a>
            <a href="/Inventory/SupplierBalances" class="action-tile t-amber"><i class="bi bi-cash-stack" style="color:#fbbf24;"></i>Payables</a>
            <a href="/CfoDashboard/Reports" class="action-tile t-gold"><i class="bi bi-file-earmark-bar-graph-fill" style="color:#fbbf24;"></i>Reports</a>
            <a href="/AuditLog/Index" class="action-tile t-teal"><i class="bi bi-clock-history" style="color:#22d3ee;"></i>Audit Log</a>
            <a href="/Compliance/Index" class="action-tile t-red"><i class="bi bi-shield-exclamation" style="color:#fca5a5;"></i>Compliance</a>
            <a href="/Analytics/Index" class="action-tile t-purple"><i class="bi bi-graph-up-arrow" style="color:#a78bfa;"></i>Analytics</a>
            <a href="/Reporting/Index" class="action-tile t-blue"><i class="bi bi-file-earmark-text-fill" style="color:#60a5fa;"></i>Reporting</a>
        </div>
    </div>

    <div class="dark-card" style="margin-bottom:0;">
        <p class="section-title"><i class="bi bi-boxes" style="color:#8b5cf6;font-size:1.2rem;"></i> Stock Status</p>
        <div class="stock-grid">
            <div class="stock-tile" style="border-top:3px solid #10b981;">
                <div class="sv" style="color:#34d399;">@Model.TotalProducts</div>
                <div class="sl">Active</div>
            </div>
            <div class="stock-tile" style="border-top:3px solid #f59e0b;">
                <div class="sv" style="color:#fbbf24;">@Model.LowStockCount</div>
                <div class="sl">Low</div>
            </div>
            <div class="stock-tile" style="border-top:3px solid #ef4444;">
                <div class="sv" style="color:#fca5a5;">@Model.OutOfStockCount</div>
                <div class="sl">Empty</div>
            </div>
        </div>
        <div style="margin-top:1.25rem;padding-top:1.25rem;border-top:1px solid #334155;">
            <p style="font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#475569;margin:0 0 .75rem;">Supplier Payables</p>
            <div style="display:flex;justify-content:space-between;align-items:baseline;">
                <span style="color:#94a3b8;font-size:.85rem;">@Model.SuppliersWithBalanceDue suppliers</span>
                <span style="color:#fca5a5;font-weight:800;font-size:1.1rem;">₱@Model.TotalOutstandingPayables.ToString("N0")</span>
            </div>
            <a href="/Inventory/SupplierBalances" style="display:block;margin-top:.75rem;padding:.5rem 1rem;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.25);border-radius:8px;color:#fca5a5;font-size:.8rem;font-weight:700;text-decoration:none;text-align:center;transition:all .2s;" onmouseover="this.style.background='rgba(239,68,68,.2)'" onmouseout="this.style.background='rgba(239,68,68,.1)'">View Balances →</a>
        </div>
    </div>
</div>

<!-- TOP SELLING PRODUCTS -->
<div class="dark-card">
    <p class="section-title"><i class="bi bi-trophy-fill" style="color:#fbbf24;font-size:1.2rem;"></i> Top Selling Products — Last 30 Days</p>
    @if (!Model.TopSellingProducts.Any())
    {
        <p style="color:#475569;text-align:center;padding:2rem;">No sales data available.</p>
    }
    else
    {
        @for (int i = 0; i < Model.TopSellingProducts.Count; i++)
        {
            var p = Model.TopSellingProducts[i];
            var rankClass = i == 0 ? "r1" : i == 1 ? "r2" : i == 2 ? "r3" : "";
            <div class="product-row">
                <div class="rank-badge @rankClass">#@(i+1)</div>
                <span style="font-size:1.5rem;">@p.Emoji</span>
                <div style="flex:1;">
                    <div style="color:#f1f5f9;font-weight:600;font-size:.9rem;">@p.ProductName</div>
                    <div style="color:#475569;font-size:.78rem;">@p.QuantitySold units sold</div>
                </div>
                <div style="color:#34d399;font-weight:800;font-size:1.05rem;">₱@p.Revenue.ToString("N0")</div>
            </div>
        }
    }
</div>
