@model CRLFruitstandESS.Models.ViewModels.PaySupplierViewModel
@{
    ViewData["Title"] = "Pay Supplier";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
}

<div class="payment-page">
    <div class="form-card">
        <div class="form-header">
            <div class="header-icon payment">
                <i class="bi bi-cash-stack"></i>
            </div>
            <div>
                <h2 class="form-title">Pay Supplier</h2>
                <p class="form-subtitle">Record payment to supplier</p>
            </div>
        </div>

        <!-- Validation Summary - Only shows when ModelState has errors -->
        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
        {
            <div class="validation-summary">
                <div asp-validation-summary="ModelOnly" class="validation-content"></div>
            </div>
        }

        <form asp-action="PaySupplier" method="post" class="payment-form">
            @Html.AntiForgeryToken()

            <!-- Enhanced Supplier Dropdown -->
            <div class="form-group">
                <label asp-for="SupplierId" class="form-label">
                    <i class="bi bi-building"></i> Select Supplier <span class="required">*</span>
                </label>
                <div class="select-wrapper">
                    <select asp-for="SupplierId" class="form-select form-select-lg enhanced-select" required>
                        <option value="">-- Choose a Supplier --</option>
                        @if (ViewBag.Suppliers != null)
                        {
                            @foreach (var supplier in ViewBag.Suppliers)
                            {
                                var balanceDue = ViewBag.SupplierBalances != null && ViewBag.SupplierBalances.ContainsKey(supplier.Id) ? ViewBag.SupplierBalances[supplier.Id] : 0m;
                                var isDisabled = balanceDue <= 0;
                                
                                @if (ViewBag.SelectedSupplier != null && ViewBag.SelectedSupplier.Id == supplier.Id)
                                {
                                    if (isDisabled)
                                    {
                                        <option value="@supplier.Id" disabled selected title="No payment due">🏢 @supplier.Name - Paid ✓</option>
                                    }
                                    else
                                    {
                                        <option value="@supplier.Id" selected>🏢 @supplier.Name - Balance: ₱@(((decimal)balanceDue).ToString("N2"))</option>
                                    }
                                }
                                else
                                {
                                    if (isDisabled)
                                    {
                                        <option value="@supplier.Id" disabled title="No payment due">🏢 @supplier.Name - Paid ✓</option>
                                    }
                                    else
                                    {
                                        <option value="@supplier.Id">🏢 @supplier.Name - Balance: ₱@(((decimal)balanceDue).ToString("N2"))</option>
                                    }
                                }
                            }
                        }
                    </select>
                    <i class="bi bi-chevron-down select-arrow"></i>
                </div>
                <span asp-validation-for="SupplierId" class="field-validation"></span>
            </div>

            <div class="form-row">
                <div class="form-group half">
                    <label asp-for="Amount" class="form-label">
                        <i class="bi bi-currency-dollar"></i> Amount (₱) <span class="required">*</span>
                    </label>
                    <div class="input-wrapper">
                        <span class="input-prefix">₱</span>
                        <input asp-for="Amount" type="number" step="0.01" class="form-control form-control-lg amount-input" 
                               min="0.01" required placeholder="0.00" />
                    </div>
                    <span asp-validation-for="Amount" class="field-validation"></span>
                </div>

                <!-- Enhanced Payment Method Dropdown -->
                <div class="form-group half">
                    <label asp-for="PaymentMethod" class="form-label">
                        <i class="bi bi-wallet2"></i> Payment Method <span class="required">*</span>
                    </label>
                    <div class="select-wrapper">
                        <select asp-for="PaymentMethod" class="form-select form-select-lg enhanced-select" required>
                            <option value="">-- Select Method --</option>
                            <option value="Cash">💵 Cash</option>
                            <option value="Bank Transfer">🏦 Bank Transfer</option>
                            <option value="Check">📝 Check</option>
                            <option value="GCash">📱 GCash</option>
                            <option value="PayMaya">💳 PayMaya</option>
                        </select>
                        <i class="bi bi-chevron-down select-arrow"></i>
                    </div>
                    <span asp-validation-for="PaymentMethod" class="field-validation"></span>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="ReferenceNumber" class="form-label">
                    <i class="bi bi-hash"></i> Reference Number
                </label>
                <input asp-for="ReferenceNumber" class="form-control" 
                       placeholder="Receipt #, Check #, Transaction ID" />
                <span asp-validation-for="ReferenceNumber" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label asp-for="Notes" class="form-label">
                    <i class="bi bi-chat-left-text"></i> Notes
                </label>
                <textarea asp-for="Notes" class="form-control" rows="3" 
                          placeholder="Payment notes, installment info, etc."></textarea>
                <span asp-validation-for="Notes" class="field-validation"></span>
            </div>

            <div class="form-group">
                <label class="form-label">
                    <i class="bi bi-person-circle"></i> Processed By
                </label>
                <input type="text" class="form-control readonly-field" value="@(User.Identity?.Name ?? "Unknown")" readonly />
            </div>

            <!-- Enhanced Action Buttons -->
            <div class="form-actions">
                <button type="submit" class="btn btn-pay btn-lg">
                    <i class="bi bi-check-circle-fill"></i>
                    <span>Record Payment</span>
                </button>
                <a asp-action="SupplierBalances" class="btn btn-cancel btn-lg">
                    <i class="bi bi-x-circle-fill"></i>
                    <span>Cancel</span>
                </a>
            </div>
        </form>
    </div>
</div>

@section Styles {
<style>
    .payment-page { 
        max-width: 600px; 
        margin: 2rem auto; 
        padding: 0 1rem; 
    }
    
    .form-card { 
        background: rgba(255,255,255,0.05); 
        border-radius: 20px; 
        padding: 2rem; 
        border: 1px solid rgba(255,255,255,0.1);
        box-shadow: 0 20px 60px rgba(0,0,0,0.3);
    }
    
    .form-header { 
        display: flex; 
        align-items: center; 
        gap: 1rem; 
        margin-bottom: 2rem; 
    }
    
    .header-icon { 
        width: 60px; 
        height: 60px; 
        border-radius: 16px; 
        display: flex; 
        align-items: center; 
        justify-content: center; 
        font-size: 1.75rem; 
    }
    
    .header-icon.payment { 
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        color: #fff;
        box-shadow: 0 8px 20px rgba(59, 130, 246, 0.4);
    }
    
    .form-title { 
        font-size: 1.5rem; 
        font-weight: 700; 
        margin: 0; 
        color: #fff; 
    }
    
    .form-subtitle { 
        color: #94a3b8; 
        margin: 0; 
    }

    /* Validation Summary - Only shows when rendered with content */
    .validation-summary {
        padding: 1rem 1.25rem;
        background: linear-gradient(135deg, rgba(239, 68, 68, 0.1), rgba(220, 38, 38, 0.05));
        border: 1px solid rgba(239, 68, 68, 0.3);
        border-radius: 10px;
        margin-bottom: 1.5rem;
        color: #f87171;
        font-size: 0.9rem;
    }

    .validation-summary ul {
        margin: 0;
        padding-left: 1.25rem;
        list-style: none;
    }

    .validation-summary li {
        position: relative;
        padding-left: 1.5rem;
        margin-bottom: 0.5rem;
    }

    .validation-summary li:last-child {
        margin-bottom: 0;
    }

    .validation-summary li::before {
        content: "⚠";
        position: absolute;
        left: 0;
        color: #ef4444;
    }

    /* Form Labels with Icons */
    .form-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 0.5rem; 
        font-weight: 600; 
        color: #e2e8f0;
        font-size: 0.9rem;
    }

    .form-label i {
        color: #3b82f6;
        font-size: 1rem;
    }
    
    .required { 
        color: #ef4444; 
    }

    /* Enhanced Select Dropdowns */
    .select-wrapper {
        position: relative;
    }

    .enhanced-select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background: rgba(255,255,255,0.08);
        border: 2px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        padding: 0.875rem 3rem 0.875rem 1rem;
        color: #f1f5f9;
        font-size: 1rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
        width: 100%;
    }

    .enhanced-select:hover {
        background: rgba(255,255,255,0.12);
        border-color: rgba(59, 130, 246, 0.5);
    }

    .enhanced-select:focus {
        background: rgba(255,255,255,0.15);
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        outline: none;
    }

    .enhanced-select option {
        background: #1e293b;
        color: #f1f5f9;
        padding: 0.75rem;
    }

    .select-arrow {
        position: absolute;
        right: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #64748b;
        font-size: 1.25rem;
        pointer-events: none;
        transition: transform 0.3s ease;
    }

    .select-wrapper:focus-within .select-arrow {
        transform: translateY(-50%) rotate(180deg);
        color: #3b82f6;
    }

    /* Amount Input with Prefix */
    .input-wrapper {
        position: relative;
    }

    .input-prefix {
        position: absolute;
        left: 1rem;
        top: 50%;
        transform: translateY(-50%);
        color: #22c55e;
        font-weight: 700;
        font-size: 1.25rem;
    }

    .amount-input {
        padding-left: 2.5rem !important;
        font-weight: 600;
        letter-spacing: 0.5px;
    }

    .form-control {
        background: rgba(255,255,255,0.08);
        border: 2px solid rgba(255,255,255,0.15);
        border-radius: 12px;
        padding: 0.875rem 1rem;
        color: #f1f5f9;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        background: rgba(255,255,255,0.15);
        border-color: #3b82f6;
        box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15);
        color: #f1f5f9;
        outline: none;
    }

    .form-control::placeholder {
        color: #64748b;
    }

    .readonly-field {
        background: rgba(255,255,255,0.03) !important;
        border-color: rgba(255,255,255,0.08);
        color: #94a3b8;
        cursor: not-allowed;
    }
    
    .form-group { 
        margin-bottom: 1.5rem; 
    }
    
    .form-row { 
        display: grid; 
        grid-template-columns: 1fr 1fr; 
        gap: 1rem; 
    }
    
    .form-group.half { 
        margin-bottom: 0; 
    }

    /* Field Validation - Only show when there's an error */
    .field-validation {
        display: none;
        color: #ef4444; 
        font-size: 0.875rem; 
        margin-top: 0.5rem;
        align-items: center;
        gap: 0.375rem;
    }

    .field-validation::before {
        content: "⚠ ";
    }

    /* Show validation message only when field has error */
    .input-validation-error ~ .field-validation,
    .field-validation:not(:empty) {
        display: flex;
    }

    /* Highlight input with error */
    .input-validation-error {
        border-color: #ef4444 !important;
        background: rgba(239, 68, 68, 0.05) !important;
    }

    .input-validation-error:focus {
        box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15) !important;
    }

    /* Enhanced Action Buttons */
    .form-actions { 
        display: flex; 
        gap: 1rem; 
        margin-top: 2.5rem;
    }

    /* Pay Button - Primary Action */
    .btn-pay {
        flex: 2;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        background: linear-gradient(135deg, #10b981, #059669);
        border: none;
        border-radius: 12px;
        color: #fff;
        font-weight: 700;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(16, 185, 129, 0.4);
        text-decoration: none;
    }

    .btn-pay:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(16, 185, 129, 0.5);
        background: linear-gradient(135deg, #34d399, #10b981);
    }

    .btn-pay:active {
        transform: translateY(-1px);
    }

    .btn-pay i {
        font-size: 1.25rem;
    }

    /* Cancel Button - Enhanced Secondary Action */
    .btn-cancel {
        flex: 1;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        padding: 1rem 2rem;
        background: transparent;
        border: 2px solid rgba(255,255,255,0.2);
        border-radius: 12px;
        color: #94a3b8;
        font-weight: 600;
        font-size: 1.1rem;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
    }

    .btn-cancel:hover {
        background: rgba(239, 68, 68, 0.1);
        border-color: rgba(239, 68, 68, 0.5);
        color: #f87171;
        transform: translateY(-3px);
        box-shadow: 0 8px 25px rgba(239, 68, 68, 0.2);
    }

    .btn-cancel:active {
        transform: translateY(-1px);
    }

    .btn-cancel i {
        font-size: 1.25rem;
        transition: transform 0.3s ease;
    }

    .btn-cancel:hover i {
        transform: rotate(90deg);
    }

    /* Responsive */
    @@media (max-width: 768px) {
        .form-row { 
            grid-template-columns: 1fr; 
        }
        .form-group.half { 
            margin-bottom: 1.5rem; 
        }
        .form-actions {
            flex-direction: column;
        }
        .btn-pay, .btn-cancel {
            width: 100%;
        }
    }
</style>
}