@{
    ViewData["Title"] = "Record Spoilage";
    Layout = "~/Views/Shared/_DashboardLayout.cshtml";
    var products       = ViewBag.Products as List<CRLFruitstandESS.Models.Product> ?? new();
    var recentSpoilage = ViewBag.RecentSpoilage as List<CRLFruitstandESS.Models.SpoilageRecord> ?? new();
    double spoilageRate  = ViewBag.SpoilageRate ?? 0.0;
    double benchmarkRate = ViewBag.BenchmarkRate ?? 30.5;
    decimal totalLoss    = ViewBag.TotalLoss30d ?? 0m;
}

@section Styles {
<style>
.page-content { background:#0f172a !important; min-height:100vh; }
.sp-header { background:linear-gradient(135deg,#1e293b,#0f172a); border:1px solid #334155; border-radius:14px; padding:2rem; margin-bottom:1.5rem; }
.dark-card  { background:#1e293b; border:1px solid #334155; border-radius:14px; padding:1.75rem; margin-bottom:1.5rem; }
.section-title { font-size:1rem; font-weight:700; color:#f1f5f9; display:flex; align-items:center; gap:.6rem; margin:0 0 1.25rem; }
.stat-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:1rem; margin-bottom:1.5rem; }
.stat-box  { background:#0f172a; border:1px solid #334155; border-radius:10px; padding:1rem 1.25rem; }
.stat-label { font-size:.68rem; font-weight:700; text-transform:uppercase; letter-spacing:.09em; color:#475569; margin-bottom:.3rem; }
.stat-value { font-size:1.6rem; font-weight:800; }
.sp-table { width:100%; border-collapse:collapse; font-size:.875rem; }
.sp-table thead th { padding:.75rem 1rem; text-align:left; font-size:.7rem; font-weight:700; text-transform:uppercase; color:#475569; border-bottom:1px solid #334155; background:#0f172a; }
.sp-table tbody tr { border-bottom:1px solid #1e293b; }
.sp-table tbody tr:hover { background:#0f172a; }
.sp-table tbody td { padding:.7rem 1rem; color:#cbd5e1; }
.form-dark { background:#0f172a; border:1px solid #334155; border-radius:8px; padding:.75rem 1rem; color:#f1f5f9; width:100%; font-size:.9rem; }
.form-dark:focus { outline:none; border-color:#6366f1; }
.btn-record { padding:.75rem 1.5rem; background:#ef4444; color:white; border:none; border-radius:8px; font-weight:700; cursor:pointer; transition:background .2s; }
.btn-record:hover { background:#dc2626; }
</style>
}

<div class="sp-header">
    <span style="font-size:.7rem;font-weight:800;text-transform:uppercase;letter-spacing:.12em;color:#ef4444;display:block;margin-bottom:.4rem;">Inventory</span>
    <h1 style="font-size:2rem;font-weight:800;color:#f1f5f9;margin:0 0 .4rem;">🗑️ Record Spoilage</h1>
    <p style="color:#94a3b8;margin:0;">Write off spoiled or damaged fruit and track losses against the 30.5% benchmark.</p>
</div>

@if (TempData["Success"] != null)
{
    <div style="padding:1rem 1.5rem;background:rgba(16,185,129,.1);border:1px solid rgba(16,185,129,.3);border-radius:10px;color:#34d399;margin-bottom:1.5rem;">
        <i class="bi bi-check-circle-fill"></i> @TempData["Success"]
    </div>
}
@if (TempData["Error"] != null)
{
    <div style="padding:1rem 1.5rem;background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);border-radius:10px;color:#fca5a5;margin-bottom:1.5rem;">
        <i class="bi bi-exclamation-triangle-fill"></i> @TempData["Error"]
    </div>
}

<!-- Stats -->
<div class="stat-grid">
    <div class="stat-box" style="border-top:3px solid #ef4444;">
        <div class="stat-label">Spoilage Rate (30d)</div>
        <div class="stat-value" style="color:@(spoilageRate > benchmarkRate ? "#fca5a5" : "#34d399");">@spoilageRate.ToString("F1")%</div>
        <div style="font-size:.75rem;color:#475569;">Benchmark: @benchmarkRate%</div>
    </div>
    <div class="stat-box" style="border-top:3px solid #fbbf24;">
        <div class="stat-label">Estimated Loss (30d)</div>
        <div class="stat-value" style="color:#fbbf24;">₱@totalLoss.ToString("N0")</div>
        <div style="font-size:.75rem;color:#475569;">Cost price × units spoiled</div>
    </div>
    <div class="stat-box" style="border-top:3px solid #6366f1;">
        <div class="stat-label">Events (30d)</div>
        <div class="stat-value" style="color:#a5b4fc;">@recentSpoilage.Count</div>
        <div style="font-size:.75rem;color:#475569;">Spoilage write-offs</div>
    </div>
</div>

<div style="display:grid;grid-template-columns:1fr 1.5fr;gap:1.5rem;">
    <!-- Record Form -->
    <div class="dark-card">
        <p class="section-title"><i class="bi bi-plus-circle-fill" style="color:#ef4444;"></i> Record New Spoilage</p>
        <form asp-action="RecordSpoilage" asp-controller="Inventory" method="post">
            @Html.AntiForgeryToken()
            <div style="margin-bottom:1rem;">
                <label style="font-size:.8rem;font-weight:700;color:#94a3b8;display:block;margin-bottom:.4rem;">Product</label>
                <select name="productId" class="form-dark" required>
                    <option value="">— Select product —</option>
                    @foreach (var p in products)
                    {
                        <option value="@p.Id">@p.Emoji @p.Name (Stock: @(p.Inventory?.Quantity ?? 0))</option>
                    }
                </select>
            </div>
            <div style="margin-bottom:1rem;">
                <label style="font-size:.8rem;font-weight:700;color:#94a3b8;display:block;margin-bottom:.4rem;">Quantity Spoiled</label>
                <input type="number" name="quantity" class="form-dark" min="1" placeholder="Units" required />
            </div>
            <div style="margin-bottom:1rem;">
                <label style="font-size:.8rem;font-weight:700;color:#94a3b8;display:block;margin-bottom:.4rem;">Reason</label>
                <select name="reason" class="form-dark">
                    <option value="Overripe">Overripe</option>
                    <option value="Damaged">Damaged in handling</option>
                    <option value="Expired">Expired</option>
                    <option value="Pest">Pest damage</option>
                    <option value="Other">Other</option>
                </select>
            </div>
            <div style="margin-bottom:1.25rem;">
                <label style="font-size:.8rem;font-weight:700;color:#94a3b8;display:block;margin-bottom:.4rem;">Notes (optional)</label>
                <textarea name="notes" class="form-dark" rows="2" placeholder="Additional details..."></textarea>
            </div>
            <button type="submit" class="btn-record" style="width:100%;">
                <i class="bi bi-trash3-fill"></i> Record Spoilage
            </button>
        </form>
    </div>

    <!-- Recent spoilage log -->
    <div class="dark-card">
        <p class="section-title"><i class="bi bi-clock-history" style="color:#f59e0b;"></i> Recent Spoilage (30 days)</p>
        @if (recentSpoilage.Any())
        {
            <div style="overflow-x:auto;border-radius:8px;border:1px solid #334155;">
                <table class="sp-table">
                    <thead>
                        <tr><th>Date</th><th>Product</th><th>Qty</th><th>Loss</th><th>Reason</th></tr>
                    </thead>
                    <tbody>
                        @foreach (var s in recentSpoilage)
                        {
                            <tr>
                                <td style="color:#64748b;font-size:.8rem;">@s.RecordedAt.ToString("MMM dd")</td>
                                <td style="font-weight:600;color:#f1f5f9;">@s.Product?.Emoji @s.Product?.Name</td>
                                <td style="color:#fca5a5;">@s.Quantity</td>
                                <td style="color:#fbbf24;">₱@s.EstimatedLoss.ToString("N0")</td>
                                <td style="color:#64748b;font-size:.8rem;">@s.Reason</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p style="color:#475569;text-align:center;padding:2rem 0;">No spoilage recorded in the last 30 days.</p>
        }
    </div>
</div>
